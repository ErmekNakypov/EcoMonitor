@model CreateContainerViewModel
@{
    ViewData["Title"] = "Add container";
}

<section class="py-5">
    <div class="container">
        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-plus-circle"></i>
                <span>Add container</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">Add a waste container</h1>
            <p class="text-muted mb-0">Pin the location and fill in the details.</p>
        </div>

        <form asp-area="Admin" asp-controller="Containers" asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <div class="col-md-7">
                    <div class="auth-card">
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-500"></label>
                            <div class="input-group">
                                <input asp-for="Code" class="form-control form-control-lg" placeholder="C-00001" />
                                <button type="button" id="auto-code-btn" class="btn btn-outline-secondary" data-no-loading>
                                    <i class="bi bi-magic me-2"></i>Auto-generate
                                </button>
                            </div>
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-500"></label>
                            <input asp-for="Address" class="form-control form-control-lg" placeholder="e.g. Чуйский проспект 100" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-7">
                                <label asp-for="Type" class="form-label fw-500"></label>
                                <select asp-for="Type" class="form-select form-select-lg">
                                    @foreach (var t in Enum.GetValues<ContainerType>())
                                    {
                                        <option value="@t">@t.GetDisplayName()</option>
                                    }
                                </select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="Capacity" class="form-label fw-500">Capacity (L)</label>
                                <input asp-for="Capacity" type="number" min="1" max="10000" step="1" class="form-control form-control-lg" />
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InstalledAt" class="form-label fw-500"></label>
                            <input asp-for="InstalledAt" type="date" class="form-control form-control-lg" />
                            <span asp-validation-for="InstalledAt" class="text-danger small"></span>
                        </div>

                        <input type="hidden" name="Latitude" id="Latitude" value="" />
                        <input type="hidden" name="Longitude" id="Longitude" value="" />

                        <div class="mb-4">
                            <span class="form-label fw-500 d-block">Location</span>
                            <span id="coords-text" class="text-muted small">Click on the map to set the location.</span>
                            <span asp-validation-for="Latitude" class="text-danger small d-block"></span>
                            <span asp-validation-for="Longitude" class="text-danger small d-block"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-area="Admin" asp-controller="Containers" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check2 me-2"></i>Add container
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div id="dumpsite-map"></div>
                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mt-3">
                        <span class="text-muted small">Click on the map to set the location, or use the locate button.</span>
                        <button type="button" id="locate-btn" class="btn btn-outline-secondary" data-no-loading>
                            <i class="bi bi-geo-alt-fill me-2"></i>Use my location
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const map = L.map('dumpsite-map').setView([42.876, 74.602], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            const latInput = document.getElementById('Latitude');
            const lngInput = document.getElementById('Longitude');
            const coordText = document.getElementById('coords-text');
            let marker = null;

            function updateInputs(latlng) {
                latInput.value = latlng.lat.toString();
                lngInput.value = latlng.lng.toString();
                coordText.textContent = 'Location: ' + latlng.lat.toFixed(6) + ', ' + latlng.lng.toFixed(6);
                coordText.classList.remove('text-muted');
                coordText.classList.add('text-body');
            }

            function placeMarker(latlng) {
                if (marker) {
                    marker.setLatLng(latlng);
                } else {
                    marker = L.marker(latlng, { draggable: true }).addTo(map);
                    marker.on('dragend', function (e) { updateInputs(e.target.getLatLng()); });
                }
                updateInputs(latlng);
            }

            map.on('click', function (e) { placeMarker(e.latlng); });
            document.getElementById('locate-btn').addEventListener('click', function () {
                map.locate({ setView: true, maxZoom: 16 });
            });
            map.on('locationfound', function (e) { placeMarker(e.latlng); });
            map.on('locationerror', function () { alert('Could not determine your location.'); });

            document.getElementById('auto-code-btn').addEventListener('click', function () {
                fetch('/Admin/Containers/NextCode')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        var input = document.getElementById('Code');
                        if (input && data && data.code) input.value = data.code;
                    });
            });
        })();
    </script>
}
