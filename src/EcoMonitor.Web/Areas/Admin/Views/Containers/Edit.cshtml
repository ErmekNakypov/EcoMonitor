@model EditContainerViewModel
@{
    ViewData["Title"] = "Edit container";
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Dashboard", Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = "Containers", Url = Url.Action("Index", "Containers", new { area = "Admin" }) },
        new BreadcrumbItem { Label = Model.Code },
        new BreadcrumbItem { Label = "Edit" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-pencil-square"></i>
                <span>Edit container</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">
                Edit @Model.Code
                @if (Model.IsImported)
                {
                    <span class="role-badge role-badge-inspector ms-2" title="Imported from OpenStreetMap">
                        <i class="bi bi-cloud-download me-1"></i>Imported from OSM
                    </span>
                }
            </h1>
            <p class="text-muted mb-0">Update the container's details, status, or move its pin.</p>
            @if (Model.IsImported && Model.OsmId.HasValue)
            {
                <p class="text-muted small mt-2 mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    Linked to OpenStreetMap node
                    <a href="https://www.openstreetmap.org/node/@Model.OsmId" target="_blank" rel="noopener">#@Model.OsmId</a>.
                    Editing is allowed but may be overwritten on next import.
                </p>
            }
        </div>

        <form asp-area="Admin" asp-controller="Containers" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <div class="col-md-7">
                    <div class="auth-card">
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-500"></label>
                            <input asp-for="Code" class="form-control form-control-lg" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-500"></label>
                            <input asp-for="Address" class="form-control form-control-lg" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-500"></label>
                                <select asp-for="Type" class="form-select form-select-lg">
                                    @foreach (var t in Enum.GetValues<ContainerType>())
                                    {
                                        <option value="@t">@t.GetDisplayName()</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-500"></label>
                                <select asp-for="Status" class="form-select form-select-lg">
                                    @foreach (var s in Enum.GetValues<ContainerStatus>())
                                    {
                                        <option value="@s">@s.GetDisplayName()</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-500">Capacity (L)</label>
                                <input asp-for="Capacity" type="number" min="1" max="10000" step="1" class="form-control form-control-lg" />
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InstalledAt" class="form-label fw-500"></label>
                                <input asp-for="InstalledAt" type="date" class="form-control form-control-lg" />
                                <span asp-validation-for="InstalledAt" class="text-danger small"></span>
                            </div>
                        </div>

                        <input type="hidden" name="Latitude" id="Latitude" value="@Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        <input type="hidden" name="Longitude" id="Longitude" value="@Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)" />

                        <div class="mb-4">
                            <span class="form-label fw-500 d-block">Location</span>
                            <span id="coords-text" class="text-muted small">@Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")</span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-area="Admin" asp-controller="Containers" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check2 me-2"></i>Save changes
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div id="dumpsite-map"></div>
                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mt-3">
                        <span class="text-muted small">Click on the map or drag the marker to move the container.</span>
                        <button type="button" id="locate-btn" class="btn btn-outline-secondary" data-no-loading>
                            <i class="bi bi-geo-alt-fill me-2"></i>Use my location
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const map = L.map('dumpsite-map').setView([lat, lng], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            const latInput = document.getElementById('Latitude');
            const lngInput = document.getElementById('Longitude');
            const coordText = document.getElementById('coords-text');

            function updateInputs(latlng) {
                latInput.value = latlng.lat.toString();
                lngInput.value = latlng.lng.toString();
                coordText.textContent = latlng.lat.toFixed(6) + ', ' + latlng.lng.toFixed(6);
            }

            const marker = L.marker([lat, lng], { draggable: true }).addTo(map);
            marker.on('dragend', function (e) { updateInputs(e.target.getLatLng()); });
            map.on('click', function (e) { marker.setLatLng(e.latlng); updateInputs(e.latlng); });

            document.getElementById('locate-btn').addEventListener('click', function () {
                map.locate({ setView: true, maxZoom: 16 });
            });
            map.on('locationfound', function (e) { marker.setLatLng(e.latlng); updateInputs(e.latlng); });
            map.on('locationerror', function () { alert('Could not determine your location.'); });
        })();
    </script>
}
