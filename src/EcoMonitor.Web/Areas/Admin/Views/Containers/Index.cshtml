@model ContainerListViewModel
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = Localizer["Title"].Value;

    string TypePill(ContainerType t) => t switch
    {
        ContainerType.General => "type-pill type-general",
        ContainerType.Plastic => "type-pill type-plastic",
        ContainerType.Glass => "type-pill type-glass",
        ContainerType.Paper => "type-pill type-paper",
        ContainerType.Organic => "type-pill type-organic",
        _ => "type-pill type-general"
    };

    string StatusPill(ContainerStatus s) => s switch
    {
        ContainerStatus.Active => "status-pill container-status-active",
        ContainerStatus.Maintenance => "status-pill container-status-maintenance",
        ContainerStatus.Removed => "status-pill container-status-removed",
        _ => "status-pill container-status-active"
    };

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value,   Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Containers"].Value });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-trash3"></i>
                    <span>@Localizer["BadgeRole"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
                <p class="text-muted mb-0">@Localizer["HeaderSummary", Model.TotalCount, Model.Page, Model.TotalPages]</p>
            </div>
            <div class="mt-3 mt-sm-0 d-flex gap-2">
                <a asp-area="Admin" asp-controller="Containers" asp-action="Map" class="btn btn-outline-secondary">
                    <i class="bi bi-map me-2"></i>@Localizer["ViewOnMapButton"]
                </a>
                <a asp-area="Admin" asp-controller="Containers" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>@Localizer["AddButton"]
                </a>
            </div>
        </div>

        <form method="get" asp-area="Admin" asp-controller="Containers" asp-action="Index" class="auth-card mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-500" for="search">@Localizer["SearchLabel"]</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input id="search" name="search" value="@Model.SearchQuery" class="form-control" placeholder="@Localizer["SearchPlaceholder"]" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500" for="type">@Localizer["TypeLabel"]</label>
                    <select id="type" name="type" class="form-select">
                        <option value="">@Localizer["TypeAll"]</option>
                        @foreach (var t in Enum.GetValues<ContainerType>())
                        {
                            @* ContainerType.GetDisplayName() returns an English label
                               from the enum's [Display] attributes — same documented
                               gap as FlagCleanupReasons. Localising enum displays needs
                               a separate Application-layer commit. *@
                            <option value="@t" selected="@(Model.TypeFilter == t)">@t.GetDisplayName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500" for="status">@Localizer["StatusLabel"]</label>
                    <select id="status" name="status" class="form-select">
                        <option value="">@Localizer["StatusAll"]</option>
                        @foreach (var s in Enum.GetValues<ContainerStatus>())
                        {
                            <option value="@s" selected="@(Model.StatusFilter == s)">@s.GetDisplayName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100" data-no-loading>@SharedLocalizer["Common.Apply"]</button>
                </div>
            </div>
        </form>

        <div class="auth-card @(Model.Items.Count == 0 ? "p-4" : "p-0 overflow-hidden")">
            @if (Model.Items.Count == 0)
            {
                var hasFilters = !string.IsNullOrWhiteSpace(Model.SearchQuery)
                    || Model.TypeFilter.HasValue
                    || Model.StatusFilter.HasValue;

                if (hasFilters)
                {
                    var emptyState = new EmptyStateViewModel
                    {
                        Icon = "bi-trash3",
                        Title = Localizer["EmptyFilteredTitle"].Value,
                        Subtitle = Localizer["EmptyFilteredSubtitle"].Value,
                        CtaText = Localizer["EmptyFilteredCta"].Value,
                        CtaUrl = Url.Action("Create", "Containers", new { area = "Admin" }),
                        CtaIcon = "bi-plus-circle"
                    };
                    <partial name="_EmptyState" model="emptyState" />
                }
                else
                {
                    <div class="empty-state text-center py-5">
                        <div class="empty-icon mb-3"><i class="bi bi-trash3"></i></div>
                        <h3 class="h5 fw-700 mb-2">@Localizer["EmptyFirstTimeTitle"]</h3>
                        <p class="text-muted mb-4" style="max-width: 560px; margin: 0 auto;">
                            @Localizer["EmptyFirstTimeBody"]
                        </p>
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="ImportContainers" method="post" class="d-inline m-0">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-cloud-download me-2"></i>@Localizer["ImportFromOsmButton"]
                                </button>
                            </form>
                            <a asp-action="Create" class="btn btn-outline-secondary">
                                <i class="bi bi-plus-circle me-2"></i>@Localizer["AddManuallyButton"]
                            </a>
                        </div>
                        <p class="text-muted small mt-3 mb-0">
                            @Localizer["OsmImportTip"]
                        </p>
                    </div>
                }
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["TableCode"]</th>
                                <th>@Localizer["TableAddress"]</th>
                                <th>@Localizer["TableType"]</th>
                                <th>@Localizer["TableCapacity"]</th>
                                <th>@Localizer["TableStatus"]</th>
                                <th>@Localizer["TableInstalled"]</th>
                                <th class="text-end">@Localizer["TableActions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Items)
                            {
                                var deleteUrl = Url.Action("Delete", "Containers", new { area = "Admin", id = c.Id });
                                <tr>
                                    <td class="fw-500">@c.Code</td>
                                    <td>@c.Address</td>
                                    <td><span class="@TypePill(c.Type)">@c.Type.GetDisplayName()</span></td>
                                    <td class="text-muted small">@Localizer["CapacityCell", c.Capacity]</td>
                                    <td><span class="@StatusPill(c.Status)">@c.Status.GetDisplayName()</span></td>
                                    <td class="text-muted small">@DateHelpers.FormatDate(c.InstalledAt)</td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Containers" asp-action="Edit" asp-route-id="@c.Id">
                                                        <i class="bi bi-pencil me-2"></i>@Localizer["ActionEdit"]
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button type="button" class="dropdown-item"
                                                            data-bs-toggle="modal" data-bs-target="#confirmModal"
                                                            data-confirm-url="@deleteUrl"
                                                            data-confirm-title="@Localizer["ConfirmRemoveTitle"]"
                                                            data-confirm-message="@Localizer["ConfirmRemoveMessage", c.Code]"
                                                            data-confirm-button-class="btn btn-danger"
                                                            data-confirm-button-text="@Localizer["ActionRemove"]">
                                                        <i class="bi bi-trash me-2"></i>@Localizer["ActionRemove"]
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="@Localizer["PaginationAriaLabel"]">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Containers" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-type="@Model.TypeFilter"
                           asp-route-status="@Model.StatusFilter">@SharedLocalizer["Common.Previous"]</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" asp-area="Admin" asp-controller="Containers" asp-action="Index"
                               asp-route-page="@p"
                               asp-route-search="@Model.SearchQuery"
                               asp-route-type="@Model.TypeFilter"
                               asp-route-status="@Model.StatusFilter">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Containers" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-type="@Model.TypeFilter"
                           asp-route-status="@Model.StatusFilter">@SharedLocalizer["Common.Next"]</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="confirmForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 id="confirmTitle" class="h5 fw-700 modal-title mb-0">@Localizer["ModalDefaultTitle"]</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Close"]"></button>
                </div>
                <div class="modal-body" id="confirmMessage">@Localizer["ModalDefaultMessage"]</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                    <button type="submit" id="confirmButton" class="btn btn-primary">@Localizer["ModalDefaultButtonText"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* JSON i18n bridge for the modal-show fallback values (defensive
       path). Per-row data-confirm-* attributes are already localised
       server-side. *@
    <script>
        window.__containersIndexI18n = {
            defaultTitle:      @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultTitle"].Value)),
            defaultMessage:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultMessage"].Value)),
            defaultButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultButtonText"].Value))
        };
    </script>
    <script>
        (function () {
            var i18n = window.__containersIndexI18n;
            var modalEl = document.getElementById('confirmModal');
            if (!modalEl) return;
            var form = document.getElementById('confirmForm');
            var titleEl = document.getElementById('confirmTitle');
            var messageEl = document.getElementById('confirmMessage');
            var buttonEl = document.getElementById('confirmButton');

            modalEl.addEventListener('show.bs.modal', function (event) {
                var trigger = event.relatedTarget;
                if (!trigger) return;
                form.action = trigger.dataset.confirmUrl || form.action;
                titleEl.textContent = trigger.dataset.confirmTitle || i18n.defaultTitle;
                messageEl.textContent = trigger.dataset.confirmMessage || i18n.defaultMessage;
                buttonEl.textContent = trigger.dataset.confirmButtonText || i18n.defaultButtonText;
                buttonEl.className = trigger.dataset.confirmButtonClass || 'btn btn-primary';
            });
        })();
    </script>
}
