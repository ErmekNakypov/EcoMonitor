@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = Localizer["Title"].Value;

    // Legend entries pulled from per-view keys so translators control
    // the user-facing label per ContainerType (the enum's GetDisplayName
    // returns English).
    var legendEntries = new (string Type, string Color, string Label)[]
    {
        ("General", "#6B7280", Localizer["LegendGeneral"].Value),
        ("Plastic", "#3B82F6", Localizer["LegendPlastic"].Value),
        ("Glass",   "#14B8A6", Localizer["LegendGlass"].Value),
        ("Paper",   "#D97706", Localizer["LegendPaper"].Value),
        ("Organic", "#16A34A", Localizer["LegendOrganic"].Value)
    };

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value,  Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Containers"].Value, Url = Url.Action("Index", "Containers", new { area = "Admin" }) },
        new BreadcrumbItem { Label = Localizer["BreadcrumbLeaf"].Value });
}

<section class="py-5">
    <div class="container-fluid px-4">
        <div class="container px-0 mb-4">
            <partial name="_Breadcrumbs" model="breadcrumbs" />
            <span class="hero-badge mb-2">
                <i class="bi bi-map"></i>
                <span>@Localizer["BadgeRole"]</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
            <p class="text-muted mb-0">@Localizer["Subtitle"]</p>
        </div>

        <div class="map-frame">
            <div id="containers-map"></div>
            <div class="map-legend">
                <h6 class="fw-700 mb-2 small text-uppercase text-muted">@Localizer["LegendHeading"]</h6>
                @foreach (var entry in legendEntries)
                {
                    <div class="legend-row">
                        <span class="legend-dot" style="background: @entry.Color"></span>
                        <span>@entry.Label</span>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    @* JSON i18n bridge for the popup line prefixes. Container code,
       address, type and capacity are model values; only "Status:" and
       "Installed:" prefixes are localised text. *@
    <script>
        window.__containersMapI18n = {
            statusPrefix:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsPopupStatusPrefix"].Value)),
            installedPrefix: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsPopupInstalledPrefix"].Value))
        };
    </script>
    <script>
        (function () {
            const i18n = window.__containersMapI18n;
            const map = L.map('containers-map').setView([42.876, 74.602], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            const colors = {
                General: '#6B7280',
                Plastic: '#3B82F6',
                Glass:   '#14B8A6',
                Paper:   '#D97706',
                Organic: '#16A34A'
            };

            function escapeHtml(s) {
                return String(s ?? '')
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            fetch('/api/map/containers')
                .then(function (r) { return r.json(); })
                .then(function (points) {
                    const bounds = [];
                    points.forEach(function (c) {
                        const color = colors[c.type] || '#6B7280';
                        const installed = new Date(c.installedAt).toLocaleDateString();
                        const popup =
                            '<strong>' + escapeHtml(c.code) + '</strong><br>' +
                            escapeHtml(c.address) + '<br>' +
                            escapeHtml(c.type) + ' &middot; ' + c.capacity + ' L<br>' +
                            i18n.statusPrefix + escapeHtml(c.status) + '<br>' +
                            i18n.installedPrefix + installed;

                        L.circleMarker([c.latitude, c.longitude], {
                            radius: 8,
                            fillColor: color,
                            color: '#FFFFFF',
                            weight: 2,
                            opacity: 1,
                            fillOpacity: 0.85
                        })
                        .bindPopup(popup)
                        .addTo(map);

                        bounds.push([c.latitude, c.longitude]);
                    });

                    if (bounds.length > 0) {
                        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 14 });
                    }
                });
        })();
    </script>
}
