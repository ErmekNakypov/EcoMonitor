@{
    ViewData["Title"] = "Containers map";

    var legendEntries = new (string Type, string Color, string Label)[]
    {
        ("General", "#6B7280", "General waste"),
        ("Plastic", "#3B82F6", "Plastic"),
        ("Glass",   "#14B8A6", "Glass"),
        ("Paper",   "#D97706", "Paper"),
        ("Organic", "#16A34A", "Organic")
    };
}

<section class="py-5">
    <div class="container-fluid px-4">
        <div class="container px-0 mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-map"></i>
                <span>Containers map</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">All containers</h1>
            <p class="text-muted mb-0">Real-time view of waste container network</p>
        </div>

        <div class="map-frame">
            <div id="containers-map"></div>
            <div class="map-legend">
                <h6 class="fw-700 mb-2 small text-uppercase text-muted">Container types</h6>
                @foreach (var entry in legendEntries)
                {
                    <div class="legend-row">
                        <span class="legend-dot" style="background: @entry.Color"></span>
                        <span>@entry.Label</span>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const map = L.map('containers-map').setView([42.876, 74.602], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            const colors = {
                General: '#6B7280',
                Plastic: '#3B82F6',
                Glass:   '#14B8A6',
                Paper:   '#D97706',
                Organic: '#16A34A'
            };

            function escapeHtml(s) {
                return String(s ?? '')
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            fetch('/api/map/containers')
                .then(function (r) { return r.json(); })
                .then(function (points) {
                    const bounds = [];
                    points.forEach(function (c) {
                        const color = colors[c.type] || '#6B7280';
                        const installed = new Date(c.installedAt).toLocaleDateString();
                        const popup =
                            '<strong>' + escapeHtml(c.code) + '</strong><br>' +
                            escapeHtml(c.address) + '<br>' +
                            escapeHtml(c.type) + ' &middot; ' + c.capacity + ' L<br>' +
                            'Status: ' + escapeHtml(c.status) + '<br>' +
                            'Installed: ' + installed;

                        L.circleMarker([c.latitude, c.longitude], {
                            radius: 8,
                            fillColor: color,
                            color: '#FFFFFF',
                            weight: 2,
                            opacity: 1,
                            fillOpacity: 0.85
                        })
                        .bindPopup(popup)
                        .addTo(map);

                        bounds.push([c.latitude, c.longitude]);
                    });

                    if (bounds.length > 0) {
                        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 14 });
                    }
                });
        })();
    </script>
}
