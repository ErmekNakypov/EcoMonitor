@model CreateDeviceViewModel
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = Localizer["Title"].Value;

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value, Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.System.IotDevices"].Value, Url = Url.Action("Index", "Devices", new { area = "Admin" }) },
        new BreadcrumbItem { Label = Localizer["Title"].Value });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-cpu"></i>
                <span>@Localizer["BadgeRole"]</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
            <p class="text-muted mb-0">@Localizer["Subtitle"]</p>
        </div>

        <div class="auth-card" style="max-width: 720px;">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-500"></label>
                    <input asp-for="Name" class="form-control" placeholder="@Localizer["NamePlaceholder"]" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-500">@Localizer["DescriptionLabel"]</label>
                    <textarea asp-for="Description" rows="2" class="form-control"
                              placeholder="@Localizer["DescriptionPlaceholder"]"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Latitude" class="form-label fw-500"></label>
                        <input asp-for="Latitude" type="text" class="form-control" />
                        <span asp-validation-for="Latitude" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Longitude" class="form-label fw-500"></label>
                        <input asp-for="Longitude" type="text" class="form-control" />
                        <span asp-validation-for="Longitude" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-key me-2"></i>@Localizer["SubmitButton"]
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">@SharedLocalizer["Common.Cancel"]</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
