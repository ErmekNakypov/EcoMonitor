@model DeviceListViewModel
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Nav.System.IotDevices"].Value;

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value, Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.System.IotDevices"].Value });

    string StatusPill(IotDeviceStatus s) => s switch
    {
        IotDeviceStatus.Active         => "status-pill status-resolved",
        IotDeviceStatus.Suspended      => "status-pill status-inreview",
        IotDeviceStatus.Decommissioned => "status-pill status-rejected",
        _ => "status-pill"
    };
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-cpu"></i>
                    <span>@Localizer["BadgeRole"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
                <p class="text-muted mb-0">@Localizer["HeaderSummary", Model.TotalCount]</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-area="Admin" asp-controller="Devices" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>@Localizer["RegisterButton"]
                </a>
            </div>
        </div>

        <div class="auth-card @(Model.Items.Count == 0 ? "p-4" : "p-0 overflow-hidden")">
            @if (Model.Items.Count == 0)
            {
                var emptyState = new EmptyStateViewModel
                {
                    Icon = "bi-cpu",
                    Title = Localizer["EmptyTitle"].Value,
                    Subtitle = Localizer["EmptySubtitle"].Value,
                    CtaText = Localizer["EmptyCta"].Value,
                    CtaUrl = Url.Action("Create", "Devices", new { area = "Admin" }),
                    CtaIcon = "bi-plus-circle"
                };
                <partial name="_EmptyState" model="emptyState" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["TableName"]</th>
                                <th>@Localizer["TableDeviceId"]</th>
                                <th>@Localizer["TableStatus"]</th>
                                <th>@Localizer["TableLastSeen"]</th>
                                <th>@Localizer["TableLocation"]</th>
                                <th class="text-end">@Localizer["TableActions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Items)
                            {
                                <tr>
                                    <td class="fw-500">@d.Name</td>
                                    <td><code>@d.DeviceId</code></td>
                                    <td>
                                        <span class="@StatusPill(d.Status)">@d.Status.GetDisplayName()</span>
                                        @if (d.IsOffline)
                                        {
                                            <span class="ms-2 small text-warning" title="@Localizer["OfflineTitle"]">
                                                <i class="bi bi-exclamation-triangle"></i> @Localizer["OfflineLabel"]
                                            </span>
                                        }
                                    </td>
                                    <td class="text-muted small">
                                        @if (d.LastSeenAt.HasValue)
                                        {
                                            <text>@DateHelpers.FormatRelative(d.LastSeenAt.Value)</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Localizer["LastSeenNever"]</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@d.Latitude.ToString("F4"), @d.Longitude.ToString("F4")</td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item"
                                                       asp-area="Admin" asp-controller="Devices"
                                                       asp-action="Edit" asp-route-id="@d.Id">
                                                        <i class="bi bi-pencil me-2"></i>@Localizer["ActionEdit"]
                                                    </a>
                                                </li>
                                                <li>
                                                    <button type="button" class="dropdown-item"
                                                            data-bs-toggle="modal" data-bs-target="#confirmModal"
                                                            data-confirm-url="@Url.Action("RegenerateToken", "Devices", new { area = "Admin", id = d.Id })"
                                                            data-confirm-title="@Localizer["ConfirmRegenerateTitle"]"
                                                            data-confirm-message="@Localizer["ConfirmRegenerateMessage", d.DeviceId]"
                                                            data-confirm-button-class="btn btn-primary"
                                                            data-confirm-button-text="@Localizer["ConfirmRegenerateButton"]">
                                                        <i class="bi bi-arrow-repeat me-2"></i>@Localizer["ActionRegenerateToken"]
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button type="button" class="dropdown-item"
                                                            data-bs-toggle="modal" data-bs-target="#confirmModal"
                                                            data-confirm-url="@Url.Action("Delete", "Devices", new { area = "Admin", id = d.Id })"
                                                            data-confirm-title="@Localizer["ConfirmDecommissionTitle"]"
                                                            data-confirm-message="@Localizer["ConfirmDecommissionMessage", d.DeviceId]"
                                                            data-confirm-button-class="btn btn-danger"
                                                            data-confirm-button-text="@Localizer["ActionDecommission"]">
                                                        <i class="bi bi-trash me-2"></i>@Localizer["ActionDecommission"]
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="confirmForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 id="confirmTitle" class="h5 fw-700 modal-title mb-0">@Localizer["ModalDefaultTitle"]</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Cancel"]"></button>
                </div>
                <div class="modal-body" id="confirmMessage">@Localizer["ModalDefaultMessage"]</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                    <button type="submit" id="confirmButton" class="btn btn-primary">@Localizer["ModalDefaultButtonText"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* JSON i18n bridge — modal defaults fall back to these localised
       strings if a trigger button forgot to set its data-confirm-* attrs. *@
    <script>
        window.__devicesIndexI18n = {
            defaultTitle:      @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultTitle"].Value)),
            defaultMessage:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultMessage"].Value)),
            defaultButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultButtonText"].Value))
        };
    </script>
    <script>
        (function () {
            var i18n = window.__devicesIndexI18n;
            var modalEl = document.getElementById('confirmModal');
            if (!modalEl) return;
            var form = document.getElementById('confirmForm');
            var titleEl = document.getElementById('confirmTitle');
            var messageEl = document.getElementById('confirmMessage');
            var buttonEl = document.getElementById('confirmButton');

            modalEl.addEventListener('show.bs.modal', function (event) {
                var trigger = event.relatedTarget;
                if (!trigger) return;
                form.action = trigger.dataset.confirmUrl || form.action;
                titleEl.textContent = trigger.dataset.confirmTitle || i18n.defaultTitle;
                messageEl.textContent = trigger.dataset.confirmMessage || i18n.defaultMessage;
                buttonEl.textContent = trigger.dataset.confirmButtonText || i18n.defaultButtonText;
                buttonEl.className = trigger.dataset.confirmButtonClass || 'btn btn-primary';
            });
        })();
    </script>
}
