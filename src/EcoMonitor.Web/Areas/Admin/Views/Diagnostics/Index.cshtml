@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value, Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = Localizer["Title"].Value });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-tools"></i>
                <span>@Localizer["BadgeRole"]</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
            <p class="text-muted mb-0">@Localizer["Subtitle"]</p>
        </div>

        <div class="auth-card mb-4" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">@Localizer["IngestionHeading"]</h2>
            <p class="text-muted mb-2">@Localizer["IngestionBody"]</p>
            <p class="text-muted small mb-4">@Localizer["IngestionFootnote"]</p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="RunIngest" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-arrow-clockwise me-2"></i>@Localizer["IngestionButton"]
                </button>
            </form>
        </div>

        <div class="auth-card" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">@Localizer["ContainerImportHeading"]</h2>
            <p class="text-muted mb-2">@Localizer["ContainerImportBody"]</p>
            <p class="text-muted small mb-4">@Localizer["ContainerImportFootnote"]</p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="ImportContainers" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-cloud-download me-2"></i>@Localizer["ContainerImportButton"]
                </button>
            </form>
        </div>

        <div class="auth-card mt-4" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">@Localizer["BackfillReportsHeading"]</h2>
            <p class="text-muted mb-4">@Localizer["BackfillReportsBody"]</p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="BackfillDistricts" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-bounding-box me-2"></i>@Localizer["BackfillReportsButton"]
                </button>
            </form>
        </div>

        <div class="auth-card mt-4" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">@Localizer["BackfillContainersHeading"]</h2>
            <p class="text-muted mb-4">@Localizer["BackfillContainersBody"]</p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="BackfillContainerDistricts" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-trash3 me-2"></i>@Localizer["BackfillContainersButton"]
                </button>
            </form>
        </div>

        <div class="auth-card mt-4" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">@Localizer["ReseedBoundariesHeading"]</h2>
            <p class="text-muted mb-2">@Localizer["ReseedBoundariesBody"]</p>
            <p class="text-muted small mb-4">@Localizer["ReseedBoundariesFootnote"]</p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="ReseedDistrictBoundaries" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-bounding-box-circles me-2"></i>@Localizer["ReseedBoundariesButton"]
                </button>
            </form>
        </div>

        <div class="auth-card mt-4" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">@Localizer["ReseedFromGeoJsonHeading"]</h2>
            <p class="text-muted mb-2">@Localizer["ReseedFromGeoJsonBody"]</p>
            <p class="text-muted small mb-4">@Localizer["ReseedFromGeoJsonFootnote"]</p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="ReseedDistrictBoundariesFromGeoJson" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-globe2 me-2"></i>@Localizer["ReseedFromGeoJsonButton"]
                </button>
            </form>
        </div>
    </div>
</section>
