@{
    ViewData["Title"] = "Diagnostics";
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Dashboard", Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = "Diagnostics" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-tools"></i>
                <span>Diagnostics</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">System diagnostics</h1>
            <p class="text-muted mb-0">Tools for testing and verifying system components.</p>
        </div>

        <div class="auth-card" style="max-width: 720px;">
            <h2 class="h5 fw-700 mb-2">Air quality ingestion</h2>
            <p class="text-muted mb-4">
                Trigger one ingestion cycle right now. Normally this runs automatically every 30 minutes.
            </p>
            <form asp-area="Admin" asp-controller="Diagnostics" asp-action="RunIngest" method="post" class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-arrow-clockwise me-2"></i>Run ingestion now
                </button>
            </form>
        </div>
    </div>
</section>
