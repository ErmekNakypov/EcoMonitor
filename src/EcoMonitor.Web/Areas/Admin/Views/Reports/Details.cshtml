@model AdminReportViewModel
@{
    var headline = Model.Description.Length > 80 ? Model.Description[..80] + "…" : Model.Description;
    if (string.IsNullOrWhiteSpace(headline)) headline = "Dumpsite report";
    ViewData["Title"] = "Report details";

    static string TruncateForBreadcrumb(string text, int max) =>
        string.IsNullOrEmpty(text) ? "Report" :
        text.Length > max ? text[..max] + "…" : text;

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Dashboard", Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = "Reports", Url = Url.Action("Index", "Reports", new { area = "Admin" }) },
        new BreadcrumbItem { Label = TruncateForBreadcrumb(Model.Description, 40) });

    int currentStage = Model.Status switch
    {
        DumpsiteStatus.New                  => 1,
        DumpsiteStatus.InReview             => 2,
        DumpsiteStatus.Confirmed            => 3,
        DumpsiteStatus.CleanupInProgress    => 4,
        DumpsiteStatus.AwaitingVerification => 4,
        DumpsiteStatus.FlaggedByCleanupCrew => 4,
        DumpsiteStatus.Resolved             => 5,
        DumpsiteStatus.Appealed             => 5,
        DumpsiteStatus.Closed               => 5,
        _                                   => 1
    };
    bool isRejected = Model.Status == DumpsiteStatus.Rejected;
    int rejectionStage = isRejected
        ? (Model.CleanupFlaggedAt is not null ? 4 : 2)
        : -1;

    string StepClass(int step)
    {
        if (isRejected)
        {
            if (step < rejectionStage) return "done";
            if (step == rejectionStage) return "rejected-stage";
            return "faded";
        }
        if (step < currentStage) return "done";
        if (step == currentStage) return "active";
        return string.Empty;
    }
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-flag-fill"></i>
                <span>Report details</span>
            </span>
            <div class="mt-3 mb-2 d-flex flex-wrap gap-2">
                <partial name="_StatusBadge" model="Model.Status" />
                <partial name="_SourceBadge" model="Model.Source" />
            </div>
            <h1 class="h3 fw-700 mb-1">@headline</h1>
            <p class="text-muted small mb-0">
                @if (Model.Source == ReportSource.Telegram)
                {
                    var handle = string.IsNullOrWhiteSpace(Model.TelegramUserName) ? "(anonymous)" : "@" + Model.TelegramUserName;
                    <text>Reported via Telegram by <span class="fw-500">@handle</span></text>
                }
                else
                {
                    <text>Reported by <span class="fw-500">@(Model.ReporterFullName ?? "(unknown)")</span> (@Model.ReporterEmail)</text>
                }
                on @DateHelpers.FormatShort(Model.CreatedAt),
                last updated @DateHelpers.FormatRelative(Model.UpdatedAt)
            </p>
        </div>

        <div class="auth-card mb-4">
            <h2 class="h6 fw-700 mb-3">Progress</h2>
            <div class="status-stepper">
                <div class="status-step @StepClass(1)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 1 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)1)</span>
                    <div class="status-step-label">Submitted</div>
                </div>
                <div class="status-step @StepClass(2)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 2 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)2)</span>
                    <div class="status-step-label">In review</div>
                </div>
                <div class="status-step @StepClass(3)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 3 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)3)</span>
                    <div class="status-step-label">Confirmed</div>
                </div>
                <div class="status-step @StepClass(4)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 4 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)4)</span>
                    <div class="status-step-label">
                        Cleanup
                        @if (Model.Status == DumpsiteStatus.FlaggedByCleanupCrew)
                        {
                            <div class="text-muted small mt-1">Flagged — awaiting decision</div>
                        }
                        else if (Model.Status == DumpsiteStatus.AwaitingVerification)
                        {
                            <div class="text-muted small mt-1">Awaiting inspector verification</div>
                        }
                    </div>
                </div>
                <div class="status-step @StepClass(5)">
                    <span class="status-step-bullet">5</span>
                    <div class="status-step-label">
                        @(Model.Status == DumpsiteStatus.Closed ? "Closed" : "Resolved")
                        @if (Model.Status == DumpsiteStatus.Appealed)
                        {
                            <span class="badge ms-1" style="background:#FEE2E2;color:#991B1B;">Appealed</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (isRejected)
        {
            <div class="alert-rejected mb-4">
                <i class="bi bi-x-circle-fill"></i>
                <div>
                    <div class="fw-700">Report rejected</div>
                    @if (!string.IsNullOrWhiteSpace(Model.ResolutionNotes))
                    {
                        <div style="font-size:0.875rem;margin-top:0.25rem;">@Model.ResolutionNotes</div>
                    }
                    @if (Model.ResolvedAt.HasValue)
                    {
                        <div class="text-muted small mt-2">Closed on @DateHelpers.FormatShort(Model.ResolvedAt.Value)</div>
                    }
                </div>
            </div>
        }

        <div class="row g-4">
            <div class="col-md-7">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-2">Description</h2>
                    <p class="mb-0">@Model.Description</p>
                </div>

                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-3">Photos (@Model.PhotoPaths.Count)</h2>
                    @if (Model.PhotoPaths.Count == 0)
                    {
                        <p class="text-muted mb-0">No photos attached.</p>
                    }
                    else
                    {
                        <div class="photo-gallery">
                            @for (int i = 0; i < Model.PhotoPaths.Count; i++)
                            {
                                var path = Model.PhotoPaths[i];
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="Report photo @(i + 1)" />
                                </a>
                            }
                        </div>
                    }
                </div>

                @if ((Model.Status == DumpsiteStatus.Resolved || Model.Status == DumpsiteStatus.Rejected) && !string.IsNullOrWhiteSpace(Model.ResolutionNotes))
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">@(Model.Status == DumpsiteStatus.Rejected ? "Rejection reason" : "Resolution")</h2>
                        <p class="mb-2">@Model.ResolutionNotes</p>
                        @if (Model.ResolvedAt.HasValue)
                        {
                            <p class="text-muted small mb-0">Closed on @DateHelpers.FormatShort(Model.ResolvedAt.Value)</p>
                        }
                    </div>
                }
            </div>

            <div class="col-md-5">
                <div class="auth-card mb-3">
                    <h2 class="h6 fw-700 mb-3">Location</h2>
                    <div id="details-map"></div>
                    <dl class="row mt-3 mb-0 small">
                        <dt class="col-5 text-muted fw-500">Coordinates</dt>
                        <dd class="col-7 mb-1">@Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")</dd>
                        <dt class="col-5 text-muted fw-500">Photos</dt>
                        <dd class="col-7 mb-0">@Model.PhotoPaths.Count attached</dd>
                    </dl>
                </div>

                <div class="auth-card mb-3">
                    <h2 class="h6 fw-700 mb-3">Reporter</h2>
                    @if (Model.Source == ReportSource.Telegram)
                    {
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-telegram" style="font-size: 2rem; color: #0088cc;"></i>
                            <div>
                                <div class="fw-500">
                                    @if (string.IsNullOrWhiteSpace(Model.TelegramUserName))
                                    {
                                        <text>Telegram user</text>
                                    }
                                    else
                                    {
                                        <text>@@@Model.TelegramUserName</text>
                                    }
                                </div>
                                <div class="text-muted small">Submitted via the Telegram bot</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-person-circle" style="font-size: 2rem; color: var(--brand-primary);"></i>
                            <div>
                                <div class="fw-500">@(Model.ReporterFullName ?? "(unknown)")</div>
                                <div class="text-muted small mb-1">@Model.ReporterEmail</div>
                                @if (Model.ReporterRegisteredAt.HasValue)
                                {
                                    <div class="text-muted small">Registered @DateHelpers.FormatRelative(Model.ReporterRegisteredAt.Value)</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="auth-card mb-3">
                    <h2 class="h6 fw-700 mb-3">Assigned inspector</h2>
                    @if (Model.AssignedInspectorId is null)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-person-dash me-2"></i>Not assigned yet.
                        </p>
                    }
                    else
                    {
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-person-check" style="font-size: 2rem; color: var(--brand-primary);"></i>
                            <div>
                                <div class="fw-500">@(Model.AssignedInspectorFullName ?? "(unknown)")</div>
                                <div class="text-muted small">@Model.AssignedInspectorEmail</div>
                            </div>
                        </div>
                    }
                </div>

                <div class="auth-card mb-3">
                    <h2 class="h6 fw-700 mb-3"><i class="bi bi-clock-history me-1"></i>Activity timeline</h2>
                    @await Html.PartialAsync("_ReportTimeline", Model.Events)
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back to all reports
            </a>
        </div>
    </div>
</section>

<div class="modal fade" id="photo-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img id="photo-modal-img" src="" alt="Report photo" class="w-100 rounded" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const map = L.map('details-map', {
                zoomControl: true,
                scrollWheelZoom: false
            }).setView([lat, lng], 15);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map);

            const photoModal = document.getElementById('photo-modal');
            if (photoModal) {
                photoModal.addEventListener('show.bs.modal', function (event) {
                    const trigger = event.relatedTarget;
                    const src = trigger ? trigger.getAttribute('data-photo-src') : null;
                    if (src) {
                        document.getElementById('photo-modal-img').setAttribute('src', src);
                    }
                });
            }
        })();
    </script>
}
