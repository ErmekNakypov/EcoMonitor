@model AdminReportListViewModel
@{
    ViewData["Title"] = "Reports";

    string ChipClass(DumpsiteStatus? value) =>
        Model.StatusFilter == value ? "filter-chip active" : "filter-chip";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Dashboard", Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = "Reports" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-flag"></i>
                    <span>All citizen reports</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Reports</h1>
                <p class="text-muted mb-0">@Model.TotalCount total &middot; page @Model.Page of @Model.TotalPages</p>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="@ChipClass(null)">All</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.New" class="@ChipClass(DumpsiteStatus.New)">New</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.InReview" class="@ChipClass(DumpsiteStatus.InReview)">In review</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.Confirmed" class="@ChipClass(DumpsiteStatus.Confirmed)">Confirmed</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.Resolved" class="@ChipClass(DumpsiteStatus.Resolved)">Resolved</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.Rejected" class="@ChipClass(DumpsiteStatus.Rejected)">Rejected</a>
        </div>

        <div class="auth-card p-0 overflow-hidden">
            @if (Model.Items.Count == 0)
            {
                var emptyState = new EmptyStateViewModel
                {
                    Icon = "bi-flag",
                    Title = "No reports here",
                    Subtitle = "Try a different status filter, or check back when citizens submit new reports."
                };
                <partial name="_EmptyState" model="emptyState" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Description</th>
                                <th>Reporter</th>
                                <th>Assigned to</th>
                                <th class="text-center">Photos</th>
                                <th>When</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Items)
                            {
                                var detailsUrl = Url.Action("Details", "Reports", new { area = "Admin", id = r.Id });
                                <tr class="clickable-row" data-href="@detailsUrl">
                                    <td><partial name="_StatusBadge" model="r.Status" /></td>
                                    <td class="fw-500">@r.ShortDescription</td>
                                    <td>
                                        <div>@r.ReporterFullName</div>
                                        <div class="text-muted small">@r.ReporterEmail</div>
                                    </td>
                                    <td class="text-muted small">@(r.AssignedInspectorEmail ?? "—")</td>
                                    <td class="text-center text-muted small">
                                        @if (r.PhotoCount > 0)
                                        {
                                            <span title="@r.PhotoCount photo@(r.PhotoCount == 1 ? "" : "s")">
                                                <i class="bi bi-camera me-1"></i>@r.PhotoCount
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-muted small">
                                        <div>Reported @DateHelpers.FormatRelative(r.CreatedAt)</div>
                                        <div class="text-muted">Updated @DateHelpers.FormatRelative(r.UpdatedAt)</div>
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary" href="@detailsUrl">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="Reports pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)" asp-route-status="@Model.StatusFilter">Previous</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"
                               asp-route-page="@p" asp-route-status="@Model.StatusFilter">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)" asp-route-status="@Model.StatusFilter">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>
