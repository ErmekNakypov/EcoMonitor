@model AdminReportListViewModel
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Nav.Reports"].Value;

    string ChipClass(DumpsiteStatus? value) =>
        Model.StatusFilter == value ? "filter-chip active" : "filter-chip";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value, Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Reports"].Value });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-flag"></i>
                    <span>@Localizer["BadgeRole"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
                <p class="text-muted mb-0">@Localizer["HeaderSummary", Model.TotalCount, Model.Page, Model.TotalPages]</p>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="@ChipClass(null)">@Localizer["ChipAll"]</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.New" class="@ChipClass(DumpsiteStatus.New)">@Localizer["ChipNew"]</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.InReview" class="@ChipClass(DumpsiteStatus.InReview)">@Localizer["ChipInReview"]</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.Confirmed" class="@ChipClass(DumpsiteStatus.Confirmed)">@Localizer["ChipConfirmed"]</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.Resolved" class="@ChipClass(DumpsiteStatus.Resolved)">@Localizer["ChipResolved"]</a>
            <a asp-area="Admin" asp-controller="Reports" asp-action="Index" asp-route-status="@DumpsiteStatus.Rejected" class="@ChipClass(DumpsiteStatus.Rejected)">@Localizer["ChipRejected"]</a>
        </div>

        <div class="auth-card p-0 overflow-hidden">
            @if (Model.Items.Count == 0)
            {
                var emptyState = new EmptyStateViewModel
                {
                    Icon = "bi-flag",
                    Title = Localizer["EmptyTitle"].Value,
                    Subtitle = Localizer["EmptySubtitle"].Value
                };
                <partial name="_EmptyState" model="emptyState" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["TableStatus"]</th>
                                <th>@Localizer["TableDescription"]</th>
                                <th>@Localizer["TableReporter"]</th>
                                <th>@Localizer["TableAssignedTo"]</th>
                                <th class="text-center">@Localizer["TablePhotos"]</th>
                                <th>@Localizer["TableWhen"]</th>
                                <th class="text-end">@Localizer["TableActions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Items)
                            {
                                var detailsUrl = Url.Action("Details", "Reports", new { area = "Admin", id = r.Id });
                                <tr class="clickable-row" data-href="@detailsUrl">
                                    <td><partial name="_StatusBadge" model="r.Status" /></td>
                                    <td class="fw-500">@r.ShortDescription</td>
                                    <td>
                                        @if (r.Source == ReportSource.Telegram)
                                        {
                                            <div class="fw-500">
                                                @if (string.IsNullOrWhiteSpace(r.TelegramUserName))
                                                {
                                                    <text>@Localizer["TelegramUserFallback"]</text>
                                                }
                                                else
                                                {
                                                    <text>@@@r.TelegramUserName</text>
                                                }
                                            </div>
                                            <div><partial name="_SourceBadge" model="r.Source" /></div>
                                        }
                                        else
                                        {
                                            <div>@(r.ReporterFullName ?? Localizer["UnknownReporter"].Value)</div>
                                            <div class="text-muted small">@r.ReporterEmail</div>
                                        }
                                    </td>
                                    <td class="text-muted small">@(r.AssignedInspectorEmail ?? "—")</td>
                                    <td class="text-center text-muted small">
                                        @if (r.PhotoCount > 0)
                                        {
                                            var photoTitleKey = r.PhotoCount == 1 ? "PhotoCountSingular" : "PhotoCountPlural";
                                            <span title="@Localizer[photoTitleKey, r.PhotoCount]">
                                                <i class="bi bi-camera me-1"></i>@r.PhotoCount
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-muted small">
                                        <div>@Localizer["ReportedAgo", DateHelpers.FormatRelative(r.CreatedAt)]</div>
                                        <div class="text-muted">@Localizer["UpdatedAgo", DateHelpers.FormatRelative(r.UpdatedAt)]</div>
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary" href="@detailsUrl">
                                            <i class="bi bi-eye me-1"></i>@Localizer["ViewButton"]
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="@Localizer["PaginationAriaLabel"]">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)" asp-route-status="@Model.StatusFilter">@SharedLocalizer["Common.Previous"]</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"
                               asp-route-page="@p" asp-route-status="@Model.StatusFilter">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)" asp-route-status="@Model.StatusFilter">@SharedLocalizer["Common.Next"]</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>
