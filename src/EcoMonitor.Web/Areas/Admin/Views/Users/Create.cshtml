@model CreateUserViewModel
@{
    ViewData["Title"] = "Add user";
}

<section class="py-5">
    <div class="container" style="max-width: 640px;">
        <div class="auth-card">
            <span class="hero-badge mb-3">
                <i class="bi bi-person-plus"></i>
                <span>Create user</span>
            </span>
            <h1 class="h3 fw-700 mt-3 mb-2">Add a new user</h1>
            <p class="text-muted mb-4">The new user will be able to sign in immediately.</p>

            <form asp-area="Admin" asp-controller="Users" asp-action="Create" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-500"></label>
                    <input asp-for="FullName" class="form-control form-control-lg" autocomplete="name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-500"></label>
                    <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-500"></label>
                    <div class="input-group input-group-lg">
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-target="Password" aria-label="Toggle password visibility">
                            <i class="bi bi-eye" data-icon-for="Password"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label fw-500"></label>
                    <select asp-for="Role" class="form-select form-select-lg">
                        <option value="">Select a role…</option>
                        <option value="@RoleNames.Administrator">Administrator</option>
                        <option value="@RoleNames.Inspector">Inspector</option>
                        <option value="@RoleNames.Citizen">Citizen</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="SendWelcomeEmail" class="form-check-input" disabled />
                    <label asp-for="SendWelcomeEmail" class="form-check-label">
                        Send welcome email
                        <span class="text-muted small d-block">Email sending will be enabled later.</span>
                    </label>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-person-plus me-2"></i>Create user
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>
