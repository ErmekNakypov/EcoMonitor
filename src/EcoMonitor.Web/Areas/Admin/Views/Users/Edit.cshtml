@model EditUserViewModel
@{
    ViewData["Title"] = "Edit user";
}

<section class="py-5">
    <div class="container" style="max-width: 640px;">
        <div class="auth-card">
            <span class="hero-badge mb-3">
                <i class="bi bi-pencil-square"></i>
                <span>Edit user</span>
            </span>
            <h1 class="h3 fw-700 mt-3 mb-2">Edit @Model.Email</h1>
            <p class="text-muted mb-4">Update the user's profile, role, and account status.</p>

            <form asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                <input asp-for="Id" type="hidden" />
                <input asp-for="Email" type="hidden" />
                <input asp-for="CurrentRole" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label class="form-label fw-500">Email</label>
                    <div>
                        <span class="role-badge role-badge-citizen">@Model.Email</span>
                        <span class="text-muted small ms-2">read-only</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-500"></label>
                    <input asp-for="FullName" class="form-control form-control-lg" autocomplete="name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label fw-500"></label>
                    <select asp-for="Role" class="form-select form-select-lg">
                        <option value="@RoleNames.Administrator">Administrator</option>
                        <option value="@RoleNames.Inspector">Inspector</option>
                        <option value="@RoleNames.Citizen">Citizen</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="IsActive" class="form-check-input" role="switch" />
                    <label asp-for="IsActive" class="form-check-label">
                        Active
                        <span class="text-muted small d-block">Inactive users cannot sign in.</span>
                    </label>
                    <span asp-validation-for="IsActive" class="text-danger small d-block"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check2 me-2"></i>Save changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>
