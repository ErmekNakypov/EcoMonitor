@model UserListViewModel
@{
    ViewData["Title"] = "Users";

    string RoleBadgeClass(string role) => role switch
    {
        RoleNames.Administrator => "role-badge role-badge-admin",
        RoleNames.Inspector => "role-badge role-badge-inspector",
        RoleNames.Citizen => "role-badge role-badge-citizen",
        _ => "role-badge role-badge-citizen"
    };
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-people"></i>
                    <span>User management</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Users</h1>
                <p class="text-muted mb-0">@Model.TotalCount total &middot; page @Model.Page of @Model.TotalPages</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus me-2"></i>Add user
                </a>
            </div>
        </div>

        <form method="get" asp-area="Admin" asp-controller="Users" asp-action="Index" class="auth-card mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-500" for="search">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input id="search" name="search" value="@Model.SearchQuery" class="form-control" placeholder="Email or full name" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500" for="role">Role</label>
                    <select id="role" name="role" class="form-select">
                        <option value="">All roles</option>
                        <option value="@RoleNames.Administrator" selected="@(Model.RoleFilter == RoleNames.Administrator)">Administrator</option>
                        <option value="@RoleNames.Inspector" selected="@(Model.RoleFilter == RoleNames.Inspector)">Inspector</option>
                        <option value="@RoleNames.Citizen" selected="@(Model.RoleFilter == RoleNames.Citizen)">Citizen</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-500" for="active">Status</label>
                    <select id="active" name="active" class="form-select">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.ActiveFilter == true)">Active</option>
                        <option value="false" selected="@(Model.ActiveFilter == false)">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100" data-no-loading>Apply</button>
                </div>
            </div>
        </form>

        <div class="auth-card p-0 overflow-hidden">
            @if (Model.Users.Count == 0)
            {
                var emptyState = new EmptyStateViewModel
                {
                    Icon = "bi-search",
                    Title = "No users found",
                    Subtitle = "Try removing filters or adding a new user."
                };
                <partial name="_EmptyState" model="emptyState" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Full name</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                var actionVerb = user.IsActive ? "deactivate" : "activate";
                                var actionTitle = user.IsActive ? "Deactivate user" : "Activate user";
                                var actionLabel = user.IsActive ? "Deactivate" : "Activate";
                                var actionMessage = user.IsActive
                                    ? $"Are you sure you want to deactivate {user.Email}? They will not be able to sign in."
                                    : $"Are you sure you want to activate {user.Email}? They will be able to sign in again.";
                                var actionBtnClass = user.IsActive ? "btn btn-danger" : "btn btn-primary";
                                var toggleUrl = Url.Action("ToggleActive", "Users", new { area = "Admin", id = user.Id });

                                <tr>
                                    <td class="fw-500">@user.Email</td>
                                    <td>@user.FullName</td>
                                    <td>
                                        @if (user.Roles.Count > 0)
                                        {
                                            foreach (var roleName in user.Roles)
                                            {
                                                <span class="@RoleBadgeClass(roleName) me-1">@roleName</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">No role</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="status-pill status-pill-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill status-pill-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@DateHelpers.FormatShort(user.CreatedAt)</td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id">
                                                        <i class="bi bi-pencil me-2"></i>Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="ResetPassword" asp-route-id="@user.Id">
                                                        <i class="bi bi-key me-2"></i>Reset password
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button type="button" class="dropdown-item"
                                                            data-bs-toggle="modal" data-bs-target="#confirmModal"
                                                            data-confirm-url="@toggleUrl"
                                                            data-confirm-title="@actionTitle"
                                                            data-confirm-message="@actionMessage"
                                                            data-confirm-button-class="@actionBtnClass"
                                                            data-confirm-button-text="@actionLabel">
                                                        @if (user.IsActive)
                                                        {
                                                            <i class="bi bi-toggle-off me-2"></i><span>Deactivate</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-toggle-on me-2"></i><span>Activate</span>
                                                        }
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="Users pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-role="@Model.RoleFilter"
                           asp-route-active="@Model.ActiveFilter">Previous</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                               asp-route-page="@p"
                               asp-route-search="@Model.SearchQuery"
                               asp-route-role="@Model.RoleFilter"
                               asp-route-active="@Model.ActiveFilter">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-role="@Model.RoleFilter"
                           asp-route-active="@Model.ActiveFilter">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="confirmForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 id="confirmTitle" class="h5 fw-700 modal-title mb-0">Confirm</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="confirmMessage">Are you sure?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="confirmButton" class="btn btn-primary">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var modalEl = document.getElementById('confirmModal');
            if (!modalEl) return;
            var form = document.getElementById('confirmForm');
            var titleEl = document.getElementById('confirmTitle');
            var messageEl = document.getElementById('confirmMessage');
            var buttonEl = document.getElementById('confirmButton');

            modalEl.addEventListener('show.bs.modal', function (event) {
                var trigger = event.relatedTarget;
                if (!trigger) return;
                form.action = trigger.dataset.confirmUrl || form.action;
                titleEl.textContent = trigger.dataset.confirmTitle || 'Confirm';
                messageEl.textContent = trigger.dataset.confirmMessage || 'Are you sure?';
                buttonEl.textContent = trigger.dataset.confirmButtonText || 'Confirm';
                buttonEl.className = trigger.dataset.confirmButtonClass || 'btn btn-primary';
            });
        })();
    </script>
}
