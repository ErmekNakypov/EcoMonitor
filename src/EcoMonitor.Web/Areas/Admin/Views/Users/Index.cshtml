@model UserListViewModel
@{
    ViewData["Title"] = "Users";

    string RoleBadgeClass(string role) => role switch
    {
        RoleNames.Administrator => "role-badge role-badge-admin",
        RoleNames.Inspector => "role-badge role-badge-inspector",
        RoleNames.Citizen => "role-badge role-badge-citizen",
        _ => "role-badge role-badge-citizen"
    };
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-people"></i>
                    <span>User management</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Users</h1>
                <p class="text-muted mb-0">@Model.TotalCount total &middot; page @Model.Page of @Model.TotalPages</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus me-2"></i>Add user
                </a>
            </div>
        </div>

        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@success
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@error
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="get" asp-area="Admin" asp-controller="Users" asp-action="Index" class="auth-card mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-500" for="search">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input id="search" name="search" value="@Model.SearchQuery" class="form-control" placeholder="Email or full name" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500" for="role">Role</label>
                    <select id="role" name="role" class="form-select">
                        <option value="">All roles</option>
                        <option value="@RoleNames.Administrator" selected="@(Model.RoleFilter == RoleNames.Administrator)">Administrator</option>
                        <option value="@RoleNames.Inspector" selected="@(Model.RoleFilter == RoleNames.Inspector)">Inspector</option>
                        <option value="@RoleNames.Citizen" selected="@(Model.RoleFilter == RoleNames.Citizen)">Citizen</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-500" for="active">Status</label>
                    <select id="active" name="active" class="form-select">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.ActiveFilter == true)">Active</option>
                        <option value="false" selected="@(Model.ActiveFilter == false)">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100">Apply</button>
                </div>
            </div>
        </form>

        <div class="auth-card p-0 overflow-hidden">
            @if (Model.Users.Count == 0)
            {
                <div class="text-center py-5">
                    <div class="feature-icon mx-auto mb-3"><i class="bi bi-search"></i></div>
                    <h2 class="h6 fw-700 mb-1">No users found</h2>
                    <p class="text-muted small mb-0">Try removing filters or adding a new user.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Full name</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                var roleLabel = user.Roles.FirstOrDefault() ?? "-";
                                <tr>
                                    <td class="fw-500">@user.Email</td>
                                    <td>@user.FullName</td>
                                    <td>
                                        @if (user.Roles.Count > 0)
                                        {
                                            foreach (var roleName in user.Roles)
                                            {
                                                <span class="@RoleBadgeClass(roleName) me-1">@roleName</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">No role</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="status-pill status-pill-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill status-pill-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@user.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id">
                                                        <i class="bi bi-pencil me-2"></i>Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="ResetPassword" asp-route-id="@user.Id">
                                                        <i class="bi bi-key me-2"></i>Reset password
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <form asp-area="Admin" asp-controller="Users" asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="m-0">
                                                        <button type="submit" class="dropdown-item">
                                                            @if (user.IsActive)
                                                            {
                                                                <i class="bi bi-toggle-off me-2"></i><span>Deactivate</span>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-toggle-on me-2"></i><span>Activate</span>
                                                            }
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="Users pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-role="@Model.RoleFilter"
                           asp-route-active="@Model.ActiveFilter">Previous</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                               asp-route-page="@p"
                               asp-route-search="@Model.SearchQuery"
                               asp-route-role="@Model.RoleFilter"
                               asp-route-active="@Model.ActiveFilter">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-role="@Model.RoleFilter"
                           asp-route-active="@Model.ActiveFilter">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>
