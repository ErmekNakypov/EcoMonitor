@model UserListViewModel
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Nav.Users"].Value;

    string RoleBadgeClass(string role) => role switch
    {
        RoleNames.Administrator => "role-badge role-badge-admin",
        RoleNames.Inspector => "role-badge role-badge-inspector",
        RoleNames.Citizen => "role-badge role-badge-citizen",
        _ => "role-badge role-badge-citizen"
    };

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Dashboard"].Value, Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Users"].Value });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-people"></i>
                    <span>@Localizer["BadgeRole"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@SharedLocalizer["Nav.Users"]</h1>
                <p class="text-muted mb-0">@Localizer["HeaderSummary", Model.TotalCount, Model.Page, Model.TotalPages]</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus me-2"></i>@Localizer["AddUserButton"]
                </a>
            </div>
        </div>

        <form method="get" asp-area="Admin" asp-controller="Users" asp-action="Index" class="auth-card mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-500" for="search">@Localizer["SearchLabel"]</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input id="search" name="search" value="@Model.SearchQuery" class="form-control" placeholder="@Localizer["SearchPlaceholder"]" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500" for="role">@Localizer["RoleLabel"]</label>
                    <select id="role" name="role" class="form-select">
                        <option value="">@Localizer["RoleAll"]</option>
                        <option value="@RoleNames.Administrator" selected="@(Model.RoleFilter == RoleNames.Administrator)">@Localizer["RoleAdministrator"]</option>
                        <option value="@RoleNames.Inspector" selected="@(Model.RoleFilter == RoleNames.Inspector)">@Localizer["RoleInspector"]</option>
                        <option value="@RoleNames.Citizen" selected="@(Model.RoleFilter == RoleNames.Citizen)">@Localizer["RoleCitizen"]</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-500" for="active">@Localizer["StatusLabel"]</label>
                    <select id="active" name="active" class="form-select">
                        <option value="">@Localizer["StatusAll"]</option>
                        <option value="true" selected="@(Model.ActiveFilter == true)">@Localizer["StatusActive"]</option>
                        <option value="false" selected="@(Model.ActiveFilter == false)">@Localizer["StatusInactive"]</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100" data-no-loading>@SharedLocalizer["Common.Apply"]</button>
                </div>
            </div>
        </form>

        <div class="auth-card p-0 overflow-hidden">
            @if (Model.Users.Count == 0)
            {
                var emptyState = new EmptyStateViewModel
                {
                    Icon = "bi-search",
                    Title = Localizer["EmptyTitle"].Value,
                    Subtitle = Localizer["EmptySubtitle"].Value
                };
                <partial name="_EmptyState" model="emptyState" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["TableEmail"]</th>
                                <th>@Localizer["TableFullName"]</th>
                                <th>@Localizer["TableRole"]</th>
                                <th>@Localizer["TableStatus"]</th>
                                <th>@Localizer["TableCreated"]</th>
                                <th class="text-end">@Localizer["TableActions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                // Per-row action labels (deactivate vs activate) derived
                                // from the user's current state. Each branch maps to its
                                // own resource key; the data-confirm-* attributes are
                                // pre-localised so the modal-show JS just copies the
                                // strings into the modal without further i18n logic.
                                var actionTitleKey   = user.IsActive ? "ConfirmActionDeactivateTitle"   : "ConfirmActionActivateTitle";
                                var actionLabelKey   = user.IsActive ? "ActionDeactivate"              : "ActionActivate";
                                var actionMessageKey = user.IsActive ? "ConfirmActionDeactivateMessage" : "ConfirmActionActivateMessage";
                                var actionBtnClass   = user.IsActive ? "btn btn-danger"                : "btn btn-primary";
                                var toggleUrl = Url.Action("ToggleActive", "Users", new { area = "Admin", id = user.Id });

                                <tr>
                                    <td class="fw-500">@user.Email</td>
                                    <td>@user.FullName</td>
                                    <td>
                                        @if (user.Roles.Count > 0)
                                        {
                                            foreach (var roleName in user.Roles)
                                            {
                                                <span class="@RoleBadgeClass(roleName) me-1">@roleName</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Localizer["NoRoleLabel"]</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="status-pill status-pill-active">@Localizer["StatusActive"]</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill status-pill-inactive">@Localizer["StatusInactive"]</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@DateHelpers.FormatShort(user.CreatedAt)</td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id">
                                                        <i class="bi bi-pencil me-2"></i>@Localizer["ActionEdit"]
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="ResetPassword" asp-route-id="@user.Id">
                                                        <i class="bi bi-key me-2"></i>@Localizer["ActionResetPassword"]
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button type="button" class="dropdown-item"
                                                            data-bs-toggle="modal" data-bs-target="#confirmModal"
                                                            data-confirm-url="@toggleUrl"
                                                            data-confirm-title="@Localizer[actionTitleKey]"
                                                            data-confirm-message="@Localizer[actionMessageKey, user.Email ?? string.Empty]"
                                                            data-confirm-button-class="@actionBtnClass"
                                                            data-confirm-button-text="@Localizer[actionLabelKey]">
                                                        @if (user.IsActive)
                                                        {
                                                            <i class="bi bi-toggle-off me-2"></i><span>@Localizer["ActionDeactivate"]</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-toggle-on me-2"></i><span>@Localizer["ActionActivate"]</span>
                                                        }
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="@Localizer["PaginationAriaLabel"]">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-role="@Model.RoleFilter"
                           asp-route-active="@Model.ActiveFilter">@SharedLocalizer["Common.Previous"]</a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                               asp-route-page="@p"
                               asp-route-search="@Model.SearchQuery"
                               asp-route-role="@Model.RoleFilter"
                               asp-route-active="@Model.ActiveFilter">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-role="@Model.RoleFilter"
                           asp-route-active="@Model.ActiveFilter">@SharedLocalizer["Common.Next"]</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="confirmForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 id="confirmTitle" class="h5 fw-700 modal-title mb-0">@Localizer["ModalDefaultTitle"]</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Close"]"></button>
                </div>
                <div class="modal-body" id="confirmMessage">@Localizer["ModalDefaultMessage"]</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                    <button type="submit" id="confirmButton" class="btn btn-primary">@Localizer["ModalDefaultButtonText"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* JSON i18n bridge for the modal-show fallback values. The per-row
       data-confirm-* attributes are already localised server-side; the
       i18n bridge only matters when a trigger button has no data-* hints
       (defensive path that shouldn't fire in practice). *@
    <script>
        window.__usersIndexI18n = {
            defaultTitle:      @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultTitle"].Value)),
            defaultMessage:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultMessage"].Value)),
            defaultButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ModalDefaultButtonText"].Value))
        };
    </script>
    <script>
        (function () {
            var i18n = window.__usersIndexI18n;
            var modalEl = document.getElementById('confirmModal');
            if (!modalEl) return;
            var form = document.getElementById('confirmForm');
            var titleEl = document.getElementById('confirmTitle');
            var messageEl = document.getElementById('confirmMessage');
            var buttonEl = document.getElementById('confirmButton');

            modalEl.addEventListener('show.bs.modal', function (event) {
                var trigger = event.relatedTarget;
                if (!trigger) return;
                form.action = trigger.dataset.confirmUrl || form.action;
                titleEl.textContent = trigger.dataset.confirmTitle || i18n.defaultTitle;
                messageEl.textContent = trigger.dataset.confirmMessage || i18n.defaultMessage;
                buttonEl.textContent = trigger.dataset.confirmButtonText || i18n.defaultButtonText;
                buttonEl.className = trigger.dataset.confirmButtonClass || 'btn btn-primary';
            });
        })();
    </script>
}
