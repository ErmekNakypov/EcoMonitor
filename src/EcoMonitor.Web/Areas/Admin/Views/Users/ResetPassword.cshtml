@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Dashboard", Url = Url.Action("Index", "Dashboard", new { area = "" }) },
        new BreadcrumbItem { Label = "Users", Url = Url.Action("Index", "Users", new { area = "Admin" }) },
        new BreadcrumbItem { Label = Model.UserEmail },
        new BreadcrumbItem { Label = "Reset password" });
}

<section class="py-5">
    <div class="container" style="max-width: 640px;">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="auth-card">
            <span class="hero-badge mb-3">
                <i class="bi bi-key"></i>
                <span>Reset password</span>
            </span>
            <h1 class="h3 fw-700 mt-3 mb-2">Reset password for @Model.UserEmail</h1>

            <div class="alert alert-warning d-flex align-items-start gap-2" role="alert">
                <i class="bi bi-info-circle mt-1"></i>
                <span>The user will need to use the new password on next sign-in.</span>
            </div>

            <form asp-area="Admin" asp-controller="Users" asp-action="ResetPassword" method="post" novalidate>
                <input asp-for="UserId" type="hidden" />
                <input asp-for="UserEmail" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-500"></label>
                    <div class="input-group input-group-lg">
                        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-target="NewPassword" aria-label="Toggle password visibility">
                            <i class="bi bi-eye" data-icon-for="NewPassword"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-500"></label>
                    <div class="input-group input-group-lg">
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-target="ConfirmPassword" aria-label="Toggle password visibility">
                            <i class="bi bi-eye" data-icon-for="ConfirmPassword"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-key me-2"></i>Reset password
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>
