@model CleanupReportDto
@using EcoMonitor.Domain.Enums
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var currentUserId = (Guid)ViewData["CurrentUserId"]!;
    var isMine = Model.CleanupCrewId == currentUserId;

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Home"].Value,        Url = Url.Action("Index", "Home", new { area = "" }) },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.MyCleanups"].Value,  Url = Url.Action("MyReports", "Reports", new { area = "CleanupCrew" }) },
        new BreadcrumbItem { Label = Localizer["BreadcrumbReport"].Value });

    var headline = Model.Description.Length > 80 ? Model.Description[..80] + "…" : Model.Description;

    string ReporterInitial()
    {
        var name = Model.ReporterFullName ?? string.Empty;
        return name.Length > 0 ? name.Substring(0, 1).ToUpperInvariant() : "?";
    }
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-3">
            <div class="mb-2 d-flex flex-wrap gap-2 align-items-center">
                <partial name="_StatusBadge" model="Model.Status" />
                @if (!string.IsNullOrEmpty(Model.DistrictNameRu))
                {
                    <span class="district-badge" style="background:@Model.DistrictColorHex;">
                        <i class="bi bi-geo-alt-fill"></i>@Model.DistrictNameRu
                    </span>
                }
            </div>
            <h1 class="h3 fw-700 mt-2 mb-1">@headline</h1>
            <p class="text-muted small mb-0">
                @Localizer["ReportedAt",
                    DateHelpers.FormatRelative(Model.CreatedAt),
                    DateHelpers.FormatShort(Model.CreatedAt)]
            </p>
        </div>

        <div class="submission-channel-card mb-3">
            @if (Model.Source == ReportSource.Telegram)
            {
                var handle = string.IsNullOrWhiteSpace(Model.TelegramUserName) ? Localizer["AnonymousFallback"].Value : "@" + Model.TelegramUserName;
                <div class="d-flex align-items-center gap-3">
                    <div class="channel-icon channel-icon-telegram">
                        <i class="bi bi-telegram"></i>
                    </div>
                    <div>
                        <div class="fw-600">@Localizer["ChannelTelegramTitle"]</div>
                        <div class="text-muted small">
                            @handle
                            @if (Model.TelegramUserId.HasValue)
                            {
                                <text>&middot; @Localizer["ChannelTelegramUserIdSuffix", Model.TelegramUserId]</text>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex align-items-center gap-3">
                    <div class="channel-icon channel-icon-web">
                        <i class="bi bi-globe2"></i>
                    </div>
                    <div>
                        <div class="fw-600">@Localizer["ChannelWebTitle"]</div>
                        <div class="text-muted small">
                            @Localizer["ChannelWebBy", Model.ReporterFullName ?? Localizer["UnknownFallback"].Value]
                            @if (!string.IsNullOrEmpty(Model.ReporterEmail))
                            {
                                <text>&middot; @Model.ReporterEmail</text>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (string.IsNullOrWhiteSpace(Model.AutoTriageReason))
        {
            <div class="alert-triage mb-3" style="background:#D1FAE5;border-color:#10B981;color:#064E3B;">
                <i class="bi bi-lightning-charge-fill"></i>
                <div>
                    <div class="fw-600">@Localizer["TriageAutoTitle"]</div>
                    <div style="font-size:0.875rem;">@Localizer["TriageAutoBody"]</div>
                </div>
            </div>
        }
        else
        {
            <div class="alert-triage alert-triage-neutral mb-3">
                <i class="bi bi-info-circle-fill"></i>
                <div>
                    <div class="fw-600">@Localizer["TriageManualTitle"]</div>
                    <div style="font-size:0.875rem;">@Localizer["TriageManualBody", Model.AutoTriageReason]</div>
                </div>
            </div>
        }

        <div class="reporter-card mb-3">
            <div class="reporter-header">
                <div class="reporter-avatar">
                    @if (Model.Source == ReportSource.Telegram)
                    {
                        <i class="bi bi-telegram"></i>
                    }
                    else
                    {
                        @ReporterInitial()
                    }
                </div>
                <div>
                    <div class="fw-600">@Localizer["ReporterLabel"]</div>
                    <div class="reporter-name">
                        @if (Model.Source == ReportSource.Telegram)
                        {
                            @(string.IsNullOrWhiteSpace(Model.TelegramUserName) ? Localizer["AnonymousFallback"].Value : "@" + Model.TelegramUserName)
                        }
                        else
                        {
                            @(Model.ReporterFullName ?? Localizer["UnknownFallback"].Value)
                        }
                    </div>
                    @if (Model.Source != ReportSource.Telegram && !string.IsNullOrEmpty(Model.ReporterEmail))
                    {
                        <div class="text-muted small">@Model.ReporterEmail</div>
                    }
                </div>
            </div>
            @if (Model.ReporterTotalReports > 0)
            {
                <div class="reporter-stats">
                    <div class="reporter-stat-item">
                        <div class="reporter-stat-value">@Model.ReporterTotalReports</div>
                        <div class="reporter-stat-label">@Localizer["ReporterStatTotal"]</div>
                    </div>
                    <div class="reporter-stat-item reporter-stat-pending">
                        <div class="reporter-stat-value">@Model.ReporterPendingReports</div>
                        <div class="reporter-stat-label">@Localizer["ReporterStatInProgress"]</div>
                    </div>
                    <div class="reporter-stat-item reporter-stat-confirmed">
                        <div class="reporter-stat-value">@Model.ReporterResolvedReports</div>
                        <div class="reporter-stat-label">@Localizer["ReporterStatResolved"]</div>
                    </div>
                    <div class="reporter-stat-item reporter-stat-rejected">
                        <div class="reporter-stat-value">@Model.ReporterRejectedReports</div>
                        <div class="reporter-stat-label">@Localizer["ReporterStatRejected"]</div>
                    </div>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.ConfirmingInspectorName) || Model.ConfirmedAt.HasValue)
        {
            <div class="auth-card mb-3" style="border-left:4px solid #2D6A4F;">
                <h2 class="h6 fw-700 mb-2"><i class="bi bi-shield-check text-success me-2"></i>@Localizer["ConfirmedByInspectorHeading"]</h2>
                <p class="mb-1">
                    @if (!string.IsNullOrEmpty(Model.ConfirmingInspectorName))
                    {
                        <strong>@Model.ConfirmingInspectorName</strong>
                    }
                    else
                    {
                        <text>@Localizer["InspectorFallback"]</text>
                    }
                    @if (Model.ConfirmedAt.HasValue)
                    {
                        <text> &middot; @DateHelpers.FormatShort(Model.ConfirmedAt.Value) (@DateHelpers.FormatRelative(Model.ConfirmedAt.Value))</text>
                    }
                </p>
                @if (!string.IsNullOrWhiteSpace(Model.InspectorObservations))
                {
                    <p class="mb-0 text-muted small"><em>"@Model.InspectorObservations"</em></p>
                }
            </div>
        }

        @if (Model.Status == DumpsiteStatus.Confirmed && isMine
            && Model.CleanupFlaggedAt is not null
            && Model.CleanupFlaggedByCrewId == currentUserId)
        {
            <div class="alert alert-info d-flex align-items-start gap-2 mb-3">
                <i class="bi bi-arrow-clockwise mt-1"></i>
                <div>
                    <strong>@Localizer["RecheckOnSiteTitle"]</strong>
                    <div class="small text-muted">@Localizer["RecheckOnSiteBody"]</div>
                </div>
            </div>
        }
        else if (Model.Status == DumpsiteStatus.Confirmed && Model.ReassignCount > 0 && (Model.CleanupCrewId is null || Model.CleanupCrewId == currentUserId))
        {
            <div class="alert alert-warning d-flex align-items-start gap-2 mb-3">
                <i class="bi bi-flag-fill mt-1"></i>
                <div>
                    <strong>@Localizer["PreviouslyFlaggedTitle"]</strong>
                    <div class="small text-muted">@Localizer["PreviouslyFlaggedBody"]</div>
                </div>
            </div>
        }

        @if (Model.ReworkCount > 0 && Model.Status == DumpsiteStatus.CleanupInProgress)
        {
            <div class="alert alert-warning d-flex align-items-start gap-2 mb-3">
                <i class="bi bi-arrow-counterclockwise mt-1"></i>
                <div>
                    <strong>@Localizer["ReworkRequired", Model.ReworkCount + 1]</strong>
                    @if (Model.ReworkStartedAt.HasValue)
                    {
                        <div class="small text-muted">@Localizer["ReworkReturnedAt", Model.ReworkStartedAt.Value.ToString("dd MMM HH:mm")]</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.AppealResolutionNotes))
                    {
                        <div class="mt-2"><strong>@Localizer["InspectorNotePrefix"]</strong> @Model.AppealResolutionNotes</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.AppealReason))
                    {
                        <div class="mt-1"><strong>@Localizer["CitizenReasonPrefix"]</strong> @Model.AppealReason</div>
                    }
                </div>
            </div>
        }

        <div class="row g-4">
            <div class="col-md-7">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-2">@Localizer["DescriptionHeading"]</h2>
                    <p class="mb-0">@Model.Description</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.CleanupNotes))
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">@Localizer["CleanupNotesHeading"]</h2>
                        <p class="mb-0" style="white-space: pre-wrap;">@Model.CleanupNotes</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.AppealReason))
                {
                    <div class="auth-card mb-4" style="border-left:4px solid #F59E0B;">
                        <h2 class="h6 fw-700 mb-2"><i class="bi bi-flag-fill me-1" style="color:#F59E0B;"></i>@Localizer["CitizenAppealHeading"]</h2>
                        <p class="mb-1">@Model.AppealReason</p>
                        @if (Model.AppealedAt.HasValue)
                        {
                            <div class="text-muted small">@Localizer["AppealedAt", Model.AppealedAt.Value.ToString("dd MMM HH:mm")]</div>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.AppealResolutionNotes))
                {
                    <div class="auth-card mb-4" style="border-left:4px solid #2D6A4F;">
                        <h2 class="h6 fw-700 mb-2"><i class="bi bi-shield-check text-success me-1"></i>@Localizer["InspectorAppealDecisionHeading"]</h2>
                        <p class="mb-1">@Model.AppealResolutionNotes</p>
                        <div class="text-muted small">
                            @if (Model.AppealOutcome == AppealOutcome.Upheld)
                            {
                                <text>@Localizer["AppealUpheld"]</text>
                            }
                            else
                            {
                                <text>@Localizer["AppealDismissed"]</text>
                            }
                            @if (Model.AppealReviewedAt.HasValue)
                            {
                                <text>@Localizer["AppealReviewedAtSuffix", Model.AppealReviewedAt.Value.ToString("dd MMM HH:mm")]</text>
                            }
                        </div>
                    </div>
                }

                @if (Model.CitizenPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">@Localizer["CitizenPhotosHeading", Model.CitizenPhotos.Count]</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.CitizenPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="@Localizer["CitizenPhotoAlt"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.InspectionPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">@Localizer["InspectorPhotosHeading", Model.InspectionPhotos.Count]</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.InspectionPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="@Localizer["InspectorPhotoAlt"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.CleanupBeforePhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">@Localizer["BeforeCleanupHeading", Model.CleanupBeforePhotos.Count]</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.CleanupBeforePhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="@Localizer["BeforeCleanupAlt"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.CleanupAfterPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">@Localizer["AfterCleanupHeading", Model.CleanupAfterPhotos.Count]</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.CleanupAfterPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="@Localizer["AfterCleanupAlt"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.AppealPhotos.Count > 0)
                {
                    <div class="auth-card photo-section-warning mb-4">
                        <h2 class="h6 fw-700 mb-1"><i class="bi bi-flag-fill me-1" style="color:#F59E0B;"></i>@Localizer["AppealPhotosHeading", Model.AppealPhotos.Count]</h2>
                        <p class="text-muted small mb-3">@Localizer["AppealPhotosCaption"]</p>
                        <div class="photo-gallery">
                            @foreach (var p in Model.AppealPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="@Localizer["AppealPhotoAlt"]" />
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-5">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-3">@Localizer["LocationHeading"]</h2>
                    <div id="report-map" style="height:300px;border-radius:8px;margin-bottom:0.75rem"></div>
                    <p class="text-muted small mb-0">@Model.Latitude.ToString("F6", System.Globalization.CultureInfo.InvariantCulture), @Model.Longitude.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)</p>
                </div>

                <div class="action-panel">
                    <h2 class="h6 fw-700 mb-3">@Localizer["ActionsHeading"]</h2>

                    @if (Model.Status == DumpsiteStatus.Confirmed && Model.CleanupCrewId is null)
                    {
                        <form asp-area="CleanupCrew" asp-controller="Reports" asp-action="Take" asp-route-id="@Model.Id" method="post" class="d-grid">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-hand-thumbs-up me-2"></i>@Localizer["TakeReportButton"]
                            </button>
                        </form>
                    }
                    else if (Model.Status == DumpsiteStatus.Confirmed && isMine)
                    {
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary btn-lg w-100"
                                    data-bs-toggle="modal" data-bs-target="#startModal">
                                <i class="bi bi-play-circle me-2"></i>@Localizer["StartCleanupButton"]
                            </button>
                            <button type="button" class="btn btn-outline-warning w-100"
                                    data-bs-toggle="modal" data-bs-target="#flagModal">
                                <i class="bi bi-flag me-2"></i>@Localizer["FlagButton"]
                            </button>
                        </div>
                    }
                    else if (Model.Status == DumpsiteStatus.CleanupInProgress && isMine)
                    {
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary btn-lg w-100"
                                    data-bs-toggle="modal" data-bs-target="#completeModal">
                                <i class="bi bi-check2-all me-2"></i>@Localizer["MarkDoneButton"]
                            </button>
                            <button type="button" class="btn btn-outline-warning w-100"
                                    data-bs-toggle="modal" data-bs-target="#flagModal">
                                <i class="bi bi-flag me-2"></i>@Localizer["FlagButton"]
                            </button>
                        </div>
                    }
                    else if (Model.Status == DumpsiteStatus.FlaggedByCleanupCrew && isMine)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-hourglass-split me-2"></i>@Localizer["FlagWaitingMessage"]
                        </p>
                    }
                    else if (Model.Status == DumpsiteStatus.AwaitingVerification)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-hourglass-split me-2"></i>@Localizer["AwaitingVerificationMessage"]
                        </p>
                    }
                    else if (Model.CleanupCrewId is not null && !isMine)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-person-check me-2"></i>@Localizer["HandledByOtherCrewMessage"]
                        </p>
                    }
                </div>

                <div class="auth-card mt-4">
                    <h2 class="h6 fw-700 mb-3"><i class="bi bi-clock-history me-1"></i>@Localizer["ActivityTimelineHeading"]</h2>
                    @await Html.PartialAsync("_ReportTimeline", (List<EcoMonitor.Web.Models.Reports.ReportEventViewModel>)(ViewData["Events"] ?? new List<EcoMonitor.Web.Models.Reports.ReportEventViewModel>()))
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model.Status == DumpsiteStatus.Confirmed && isMine)
{
    <div class="modal fade" id="startModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-area="CleanupCrew" asp-controller="Reports" asp-action="StartCleanup" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">@Localizer["StartModalTitle"]</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Close"]"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">@Localizer["StartModalBody"]</p>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="beforePhotos">@Localizer["StartModalPhotosLabel"]</label>
                            <input id="beforePhotos" name="BeforePhotos" type="file" class="form-control" multiple accept="image/*" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-play-circle me-2"></i>@Localizer["StartModalSubmit"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (isMine && (Model.Status == DumpsiteStatus.Confirmed || Model.Status == DumpsiteStatus.CleanupInProgress))
{
    <div class="modal fade" id="flagModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-area="CleanupCrew" asp-controller="Reports" asp-action="Flag" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">@Localizer["FlagModalTitle"]</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Close"]"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">@Localizer["FlagModalBody"]</p>

                        <div class="mb-3">
                            <label class="form-label fw-500" for="flag-reason-select">@Localizer["FlagReasonLabel"]</label>
                            <select id="flag-reason-select" name="Reason" class="form-select" required>
                                <option value="">@Localizer["FlagReasonPlaceholder"]</option>
                                <option value="NoDumpsiteFound">@Localizer["FlagReasonNoDumpsiteFound"]</option>
                                <option value="AlreadyClean">@Localizer["FlagReasonAlreadyClean"]</option>
                                <option value="OutsideJurisdiction">@Localizer["FlagReasonOutsideJurisdiction"]</option>
                                <option value="PhotoMismatch">@Localizer["FlagReasonPhotoMismatch"]</option>
                                <option value="Other">@Localizer["FlagReasonOther"]</option>
                            </select>
                        </div>

                        <div class="mb-3" id="flag-notes-wrap" style="display:none;">
                            <label class="form-label fw-500" for="flag-notes">@Localizer["FlagNotesLabel"]</label>
                            <textarea id="flag-notes" name="AdditionalNotes" class="form-control" rows="3" minlength="10" maxlength="500"></textarea>
                            <div class="form-text">@Localizer["FlagNotesHelp"]</div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label fw-500" for="flag-photos">@Localizer["FlagPhotosLabel"] <span class="text-danger">*</span></label>
                            <input id="flag-photos" name="Photos" type="file" class="form-control" multiple accept="image/jpeg,image/png,image/webp" required />
                            <div class="form-text">@Localizer["FlagPhotosHelp"]</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-flag-fill me-2"></i>@Localizer["FlagSubmitButton"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.Status == DumpsiteStatus.CleanupInProgress && isMine)
{
    <div class="modal fade" id="completeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-area="CleanupCrew" asp-controller="Reports" asp-action="CompleteCleanup" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">@Localizer["CompleteModalTitle"]</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Close"]"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">@Localizer["CompleteModalBody"]</p>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="afterPhotos">@Localizer["CompletePhotosLabel"]</label>
                            <input id="afterPhotos" name="AfterPhotos" type="file" class="form-control" multiple accept="image/*" required />
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="notes">@Localizer["CompleteNotesLabel"]</label>
                            <textarea id="notes" name="Notes" rows="3" class="form-control" maxlength="1000" placeholder="@Localizer["CompleteNotesPlaceholder"]"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-all me-2"></i>@Localizer["CompleteSubmitButton"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="photo-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img id="photo-modal-img" src="" alt="@Localizer["PhotoModalAlt"]" class="w-100 rounded" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            var lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            var map = L.map('report-map', {
                zoomControl: true,
                scrollWheelZoom: false
            }).setView([lat, lng], 16);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map);

            var flagSelect = document.getElementById('flag-reason-select');
            if (flagSelect) {
                flagSelect.addEventListener('change', function () {
                    var wrap = document.getElementById('flag-notes-wrap');
                    if (!wrap) return;
                    wrap.style.display = this.value === 'Other' ? 'block' : 'none';
                });
            }

            var photoModal = document.getElementById('photo-modal');
            if (photoModal) {
                photoModal.addEventListener('show.bs.modal', function (e) {
                    var src = e.relatedTarget ? e.relatedTarget.getAttribute('data-photo-src') : null;
                    if (src) document.getElementById('photo-modal-img').setAttribute('src', src);
                });
            }
        })();
    </script>
}
