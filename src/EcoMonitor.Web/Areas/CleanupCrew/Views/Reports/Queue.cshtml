@model CleanupQueueResult
@{
    ViewData["Title"] = "Cleanup queue";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home", new { area = "" }) },
        new BreadcrumbItem { Label = "Cleanup queue" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-bucket"></i>
                    <span>Cleanup crew</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Confirmed reports awaiting cleanup</h1>
                <p class="text-muted mb-0">@Model.TotalCount in queue &middot; oldest first</p>
            </div>
        </div>

        <div class="d-flex gap-2 mb-3">
            <a asp-area="CleanupCrew" asp-controller="Reports" asp-action="Queue" class="filter-chip active">
                <i class="bi bi-inboxes"></i><span>Queue</span>
            </a>
            <a asp-area="CleanupCrew" asp-controller="Reports" asp-action="MyReports" class="filter-chip">
                <i class="bi bi-clipboard-check"></i><span>My cleanups</span>
            </a>
        </div>

        <form method="get" asp-area="CleanupCrew" asp-controller="Reports" asp-action="Queue" class="queue-toolbar">
            <div class="filter-group">
                <input type="search" name="search" placeholder="Search by description…" class="form-control" value="@ViewBag.Search" />
                <select name="sortBy" class="form-select">
                    <option value="oldest" selected="@(ViewBag.Sort == "oldest" || string.IsNullOrEmpty((string?)ViewBag.Sort))">Oldest first</option>
                    <option value="newest" selected="@(ViewBag.Sort == "newest")">Newest first</option>
                </select>
                <select name="source" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty((string?)ViewBag.Source))">All sources</option>
                    <option value="web" selected="@(ViewBag.Source == "web")">Web only</option>
                    <option value="telegram" selected="@(ViewBag.Source == "telegram")">Telegram only</option>
                </select>
                <button type="submit" class="btn btn-primary">Apply</button>
            </div>
        </form>

        @if (Model.Items.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-check2-circle",
                Title = "All clear",
                Subtitle = "No reports are waiting for cleanup right now."
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <form asp-area="CleanupCrew" asp-controller="Reports" asp-action="BuildRoute" method="post" id="route-form">
                @Html.AntiForgeryToken()
                <div class="route-select-bar">
                    <span class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i>Tick 2–15 reports to plan a cleanup route.
                    </span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small" id="route-selected-count">0 selected</span>
                        <button type="submit" class="btn btn-primary btn-sm" id="route-build-btn" disabled>
                            <i class="bi bi-signpost-split me-1"></i>Build cleanup route
                        </button>
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model.Items)
                    {
                        <div class="report-card">
                            <div class="row g-3 align-items-center">
                                <div class="col-md-1 d-flex justify-content-center">
                                    <input class="form-check-input route-checkbox" type="checkbox" name="selectedIds" value="@item.Id" aria-label="Select report for route" />
                                </div>
                                <div class="col-md-2">
                                    @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                    {
                                        <img src="@item.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                    }
                                    else
                                    {
                                        <div class="report-thumb report-thumb-placeholder">
                                            <i class="bi bi-camera"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-6">
                                    <p class="mb-2 fw-500">@item.ShortDescription</p>
                                    <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                                        <span><i class="bi bi-geo-alt me-1"></i>@item.Latitude.ToString("F4"), @item.Longitude.ToString("F4")</span>
                                        <span><i class="bi bi-clock me-1"></i>Confirmed @DateHelpers.FormatRelative(item.ConfirmedAt)</span>
                                        <partial name="_SourceBadge" model="item.Source" />
                                    </div>
                                </div>
                                <div class="col-md-3 text-md-end">
                                    <a asp-area="CleanupCrew" asp-controller="Reports" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                        Open <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </form>
        }
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const checkboxes = document.querySelectorAll('.route-checkbox');
            const btn = document.getElementById('route-build-btn');
            const counter = document.getElementById('route-selected-count');
            if (!btn || !counter) return;
            function update() {
                const count = document.querySelectorAll('.route-checkbox:checked').length;
                counter.textContent = count + ' selected';
                btn.disabled = count < 2 || count > 15;
            }
            checkboxes.forEach(cb => cb.addEventListener('change', update));
        })();
    </script>
}
