<?xml version="1.0" encoding="utf-8"?>
<root>
  <resheader name="resmimetype"><value>text/microsoft-resx</value></resheader>
  <resheader name="version"><value>2.0</value></resheader>
  <resheader name="reader"><value>System.Resources.ResXResourceReader, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089</value></resheader>
  <resheader name="writer"><value>System.Resources.ResXResourceWriter, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089</value></resheader>

  <!-- Page chrome -->
  <data name="Title" xml:space="preserve"><value>City map</value></data>
  <data name="BadgeRole" xml:space="preserve"><value>City overview</value></data>
  <data name="Heading" xml:space="preserve"><value>Bishkek environmental map</value></data>
  <data name="Subtitle" xml:space="preserve"><value>Air quality, waste containers, and active dumpsite reports — all in one view.</value></data>
  <data name="DataSourcesLabel" xml:space="preserve"><value>Data sources:</value></data>

  <!-- Filter pills + sub-pills -->
  <data name="FilterAirQuality" xml:space="preserve"><value>Air quality</value></data>
  <data name="FilterContainers" xml:space="preserve"><value>Containers</value></data>
  <data name="FilterReports" xml:space="preserve"><value>Reports</value></data>
  <data name="FilterDistricts" xml:space="preserve"><value>Districts</value></data>
  <data name="FilterRefresh" xml:space="preserve"><value>Refresh</value></data>
  <data name="FilterRefreshTitle" xml:space="preserve"><value>Reload containers and reports</value></data>
  <data name="SubOwnSensors" xml:space="preserve"><value>Own sensors</value></data>

  <!-- Legend "What's on the map" — &lt;strong&gt; emphasis preserved verbatim. -->
  <data name="LegendWhatHeading" xml:space="preserve"><value>What's on the map</value></data>
  <data name="LegendAirStationFormat" xml:space="preserve"><value>&lt;strong&gt;Air quality station&lt;/strong&gt; — colored circle with AQI value.</value></data>
  <data name="LegendOwnSensorFormat" xml:space="preserve"><value>&lt;strong&gt;Own IoT sensor&lt;/strong&gt; — same as above with a green ring + broadcast dot.</value></data>
  <data name="LegendContainerFormat" xml:space="preserve"><value>&lt;strong&gt;Waste container&lt;/strong&gt; — small bin icon, color by type.</value></data>
  <data name="LegendDumpsiteFormat" xml:space="preserve"><value>&lt;strong&gt;Dumpsite report&lt;/strong&gt; — flag pin (red = confirmed, green = resolved).</value></data>

  <!-- AQI legend: heading + 6 range pills. EPA AQI bucket boundaries
       stay literal (0–50 etc.) since they're numeric ranges. -->
  <data name="LegendAqiHeading" xml:space="preserve"><value>Air quality (AQI US)</value></data>
  <data name="LegendAqiRangeGood" xml:space="preserve"><value>Good 0–50</value></data>
  <data name="LegendAqiRangeModerate" xml:space="preserve"><value>Moderate 51–100</value></data>
  <data name="LegendAqiRangeUSG" xml:space="preserve"><value>USG 101–150</value></data>
  <data name="LegendAqiRangeUnhealthy" xml:space="preserve"><value>Unhealthy 151–200</value></data>
  <data name="LegendAqiRangeVeryUnhealthy" xml:space="preserve"><value>Very unhealthy 201–300</value></data>
  <data name="LegendAqiRangeHazardous" xml:space="preserve"><value>Hazardous 300+</value></data>

  <!-- Container types legend chips. Shorter wording than the enum
       GetDisplayName values (no "waste" suffix on the first chip) — kept
       as a separate set of keys so legend chips can vary independently
       from form select options. -->
  <data name="LegendContainerTypesHeading" xml:space="preserve"><value>Container types</value></data>
  <data name="LegendContainerGeneral" xml:space="preserve"><value>General</value></data>
  <data name="LegendContainerPlastic" xml:space="preserve"><value>Plastic</value></data>
  <data name="LegendContainerGlass" xml:space="preserve"><value>Glass</value></data>
  <data name="LegendContainerPaper" xml:space="preserve"><value>Paper</value></data>
  <data name="LegendContainerOrganic" xml:space="preserve"><value>Organic</value></data>

  <!-- Dumpsite status legend -->
  <data name="LegendDumpsiteStatusHeading" xml:space="preserve"><value>Dumpsite status</value></data>
  <data name="LegendDumpsiteConfirmedActive" xml:space="preserve"><value>Confirmed (active)</value></data>
  <data name="LegendDumpsiteResolved" xml:space="preserve"><value>Resolved</value></data>

  <!-- Footer note under the legend -->
  <data name="StationsDataNote" xml:space="preserve"><value>Stations data: &lt;strong&gt;OpenAQ&lt;/strong&gt; (web pull), &lt;strong&gt;IQAir&lt;/strong&gt; (web pull), &lt;strong&gt;Own sensors&lt;/strong&gt; (push). Real-time data from registered IoT devices.</value></data>

  <!-- Stat strip -->
  <data name="StatAirLabel" xml:space="preserve"><value>Air quality</value></data>
  <!-- {0} = stations count, rendered as a server-injected &lt;span id="stat-air-stations"&gt;…&lt;/span&gt; -->
  <data name="StatAirCaptionFormat" xml:space="preserve"><value>AQI US average · {0} stations in last 24h</value></data>
  <data name="StatContainersLabel" xml:space="preserve"><value>Containers</value></data>
  <data name="StatContainersCaption" xml:space="preserve"><value>Active across the city</value></data>
  <data name="StatConfirmedLabel" xml:space="preserve"><value>Confirmed reports</value></data>
  <data name="StatLinkReportDumpsite" xml:space="preserve"><value>Report a dumpsite</value></data>
  <data name="StatLinkInspectorQueue" xml:space="preserve"><value>Inspector queue</value></data>
  <data name="StatLinkAllActiveReports" xml:space="preserve"><value>All active reports</value></data>
  <data name="StatLinkActiveDumpsiteReports" xml:space="preserve"><value>Active dumpsite reports</value></data>
  <data name="StatResolvedLabel" xml:space="preserve"><value>Resolved</value></data>
  <data name="StatResolvedCaption" xml:space="preserve"><value>Cleaned-up reports</value></data>

  <!-- Data-table tabs -->
  <data name="TabAirStations" xml:space="preserve"><value>Air quality stations</value></data>
  <data name="TabContainers" xml:space="preserve"><value>Containers</value></data>
  <data name="TabReports" xml:space="preserve"><value>Reports</value></data>

  <!-- Search inputs + select options -->
  <data name="SearchAirPlaceholder" xml:space="preserve"><value>Search by name or locality...</value></data>
  <data name="SearchContainersPlaceholder" xml:space="preserve"><value>Search by code or address...</value></data>
  <data name="SearchReportsPlaceholder" xml:space="preserve"><value>Search by description...</value></data>

  <data name="FilterAllSources" xml:space="preserve"><value>All sources</value></data>
  <data name="FilterAllTypes" xml:space="preserve"><value>All types</value></data>
  <data name="FilterAllStatuses" xml:space="preserve"><value>All statuses</value></data>

  <!-- "Own sensors" filter option (the OpenAQ/IQAir option labels stay
       literal as brand names). -->
  <data name="FilterSourceOwnSensors" xml:space="preserve"><value>Own sensors</value></data>

  <!-- ContainerType options for the form selects — "General waste"
       (long form) vs. legend "General" (short form). -->
  <data name="FilterTypeGeneral" xml:space="preserve"><value>General waste</value></data>
  <data name="FilterTypePlastic" xml:space="preserve"><value>Plastic</value></data>
  <data name="FilterTypeGlass" xml:space="preserve"><value>Glass</value></data>
  <data name="FilterTypePaper" xml:space="preserve"><value>Paper</value></data>
  <data name="FilterTypeOrganic" xml:space="preserve"><value>Organic</value></data>

  <data name="FilterStatusConfirmed" xml:space="preserve"><value>Confirmed</value></data>
  <data name="FilterStatusResolved" xml:space="preserve"><value>Resolved</value></data>

  <!-- Table headers — single set serves all 3 tables. AQI / PM2.5 stay literal. -->
  <data name="TableAirName" xml:space="preserve"><value>Name</value></data>
  <data name="TableAirLocality" xml:space="preserve"><value>Locality</value></data>
  <data name="TableAirUpdated" xml:space="preserve"><value>Updated</value></data>
  <data name="TableAirSource" xml:space="preserve"><value>Source</value></data>
  <data name="TableContainerCode" xml:space="preserve"><value>Code</value></data>
  <data name="TableContainerAddress" xml:space="preserve"><value>Address</value></data>
  <data name="TableContainerType" xml:space="preserve"><value>Type</value></data>
  <data name="TableContainerCapacity" xml:space="preserve"><value>Capacity</value></data>
  <data name="TableContainerStatus" xml:space="preserve"><value>Status</value></data>
  <data name="TableReportDescription" xml:space="preserve"><value>Description</value></data>
  <data name="TableReportStatus" xml:space="preserve"><value>Status</value></data>
  <data name="TableReportReported" xml:space="preserve"><value>Reported</value></data>
  <data name="TableReportPhotos" xml:space="preserve"><value>Photos</value></data>

  <!-- Empty-state messages -->
  <data name="EmptyAir" xml:space="preserve"><value>No stations match the filter.</value></data>
  <data name="EmptyContainers" xml:space="preserve"><value>No containers match the filter.</value></data>
  <data name="EmptyReports" xml:space="preserve"><value>No reports match the filter.</value></data>

  <!-- JS i18n bridge keys (window.__mapI18n) — every literal string the
       Leaflet popup/tooltip / dynamic HTML below sets on the DOM. -->
  <data name="JsDetailsButton" xml:space="preserve"><value>Details</value></data>
  <data name="JsNoAqi" xml:space="preserve"><value>No AQI</value></data>
  <data name="JsLastSeenPrefix" xml:space="preserve"><value>Last seen</value></data>
  <data name="JsPopupReportedPrefix" xml:space="preserve"><value>Reported</value></data>
  <data name="JsPopupDumpsiteSuffix" xml:space="preserve"><value>dumpsite</value></data>
  <data name="JsPopupPm25Prefix" xml:space="preserve"><value>PM2.5:</value></data>
  <!-- Photo-count title attr; {0} = count. Binary singular/plural split
       (richer plural categories handled by translators inside the resource
       strings — Russian / Kyrgyz happen to collapse to one form). -->
  <data name="JsPhotoCountSingular" xml:space="preserve"><value>{0} photo</value></data>
  <data name="JsPhotoCountPlural" xml:space="preserve"><value>{0} photos</value></data>
  <data name="JsShapeOwnSensor" xml:space="preserve"><value>Own sensor</value></data>
</root>
