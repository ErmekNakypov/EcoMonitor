@inject IViewLocalizer Localizer
@{
    // Title key doubles as the H1; same word in every culture, single entry.
    ViewData["Title"] = Localizer["Title"].Value;
}

<section class="py-5">
    <div class="container" style="max-width: 480px;">
        <div class="auth-card text-center">
            <div class="mb-4">
                <i class="bi bi-shield-x text-danger" style="font-size: 64px;"></i>
            </div>
            <h1 class="h3 fw-700 mb-2">@Localizer["Title"]</h1>
            <p class="text-muted mb-4">@Localizer["Subtitle"]</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="bi bi-house me-2"></i>@Localizer["GoHomeButton"]
            </a>
        </div>
    </div>
</section>
