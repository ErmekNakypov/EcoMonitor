@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="py-5">
    <div class="container" style="max-width: 480px;">
        <div class="auth-card">
            <span class="hero-badge mb-3">
                <i class="bi bi-shield-lock"></i>
                <span>Welcome back</span>
            </span>
            <h1 class="h3 fw-700 mb-2 mt-3">Sign in to EcoMonitor</h1>
            <p class="text-muted mb-4">Continue monitoring your city's environment.</p>

            <form asp-action="Login" asp-controller="Account" method="post" novalidate>
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-500"></label>
                    <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-500"></label>
                    <div class="input-group input-group-lg">
                        <input asp-for="Password" class="form-control" autocomplete="current-password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-target="Password" aria-label="Toggle password visibility">
                            <i class="bi bi-eye" data-icon-for="Password"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
                </button>
            </form>

            <p class="text-center text-muted mt-4 mb-0 small">
                Don't have an account? <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
            </p>
        </div>
    </div>
</section>
