@{
    ViewData["Title"] = "Confirm sign out";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card text-center">
                    <div class="mb-3">
                        <i class="bi bi-box-arrow-right" style="font-size:3rem;color:var(--brand-primary,#2D6A4F)"></i>
                    </div>
                    <h1 class="h4 fw-700 mb-2">Sign out of EcoMonitor?</h1>
                    <p class="text-muted mb-4">You will need to sign in again to access the system.</p>

                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-box-arrow-right me-2"></i>Sign out
                        </button>
                    </form>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 ms-2">
                        Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
