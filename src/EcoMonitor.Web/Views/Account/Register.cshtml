@model RegisterViewModel
@{
    ViewData["Title"] = "Create account";
}

<section class="py-5">
    <div class="container" style="max-width: 480px;">
        <div class="auth-card">
            <span class="hero-badge mb-3">
                <i class="bi bi-person-plus"></i>
                <span>Join EcoMonitor</span>
            </span>
            <h1 class="h3 fw-700 mb-2 mt-3">Create your account</h1>
            <p class="text-muted mb-4">Help make Bishkek cleaner.</p>

            <form asp-action="Register" asp-controller="Account" method="post" novalidate>
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-500"></label>
                    <input asp-for="FullName" class="form-control form-control-lg" autocomplete="name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-500"></label>
                    <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-500"></label>
                    <div class="input-group input-group-lg">
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-target="Password" aria-label="Toggle password visibility">
                            <i class="bi bi-eye" data-icon-for="Password"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-500"></label>
                    <div class="input-group input-group-lg">
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-target="ConfirmPassword" aria-label="Toggle password visibility">
                            <i class="bi bi-eye" data-icon-for="ConfirmPassword"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-person-plus me-2"></i>Create account
                </button>
            </form>

            <p class="text-center text-muted mt-4 mb-0 small">
                Already have an account? <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
            </p>
        </div>
    </div>
</section>
