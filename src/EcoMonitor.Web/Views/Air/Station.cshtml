@model StationDetailsViewModel
@using System.Globalization
@using System.Text.Json
@{
    var s = Model.Station;
    ViewData["Title"] = s.Name;

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "City map", Url = Url.Action("Index", "Map") },
        new BreadcrumbItem { Label = s.Name });

    var aqi = s.AqiUs.HasValue
        ? AqiHelper.ClassifyAqiUs(s.AqiUs)
        : AqiHelper.ClassifyPm25(s.Pm25);
    var aqiColor = AqiHelper.GetColorHex(aqi);
    var aqiLabel = AqiHelper.GetLabel(aqi);
    var freshness = FreshnessHelper.Classify(s.MeasuredAt);
    var measuredRelative = s.MeasuredAt.HasValue ? DateHelpers.FormatRelative(s.MeasuredAt.Value) : "no data";
    var isStale = freshness == ReadingFreshness.Stale || freshness == ReadingFreshness.VeryStale;
    var darkAqiText = aqi == AqiLevel.Moderate;

    var hasAqiHistory = Model.Last24Hours.Any(r => r.AqiUs.HasValue);
    var chartLabel = hasAqiHistory ? "AQI US" : "PM2.5 (µg/m³)";
    var chartPoints = hasAqiHistory
        ? Model.Last24Hours
            .Where(r => r.AqiUs.HasValue)
            .OrderBy(r => r.MeasuredAt)
            .Select(r => new
            {
                t = r.MeasuredAt.ToLocalTime().ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture),
                v = r.AqiUs
            })
            .ToArray()
        : Model.Last24Hours
            .Where(r => r.Pm25.HasValue)
            .OrderBy(r => r.MeasuredAt)
            .Select(r => new
            {
                t = r.MeasuredAt.ToLocalTime().ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture),
                v = r.Pm25
            })
            .ToArray();
    var chartJson = JsonSerializer.Serialize(chartPoints);

    string Pretty(double? v, string units, string format = "0.0") =>
        v.HasValue ? v.Value.ToString(format, CultureInfo.InvariantCulture) + " " + units : "n/a";
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-4">
            <span class="aqi-pill" style="background:@aqiColor; color:@(darkAqiText ? "#78350F" : "#fff")">@aqiLabel</span>
            <h1 class="h2 fw-700 mt-3 mb-1">@s.Name</h1>
            <p class="text-muted small mb-0">
                Provider: @(string.IsNullOrWhiteSpace(s.ProviderName) ? "—" : s.ProviderName)
                &middot; Coordinates: @s.Latitude.ToString("F4"), @s.Longitude.ToString("F4")
                @if (!string.IsNullOrWhiteSpace(s.Locality))
                {
                    <span> &middot; @s.Locality</span>
                }
            </p>
        </div>

        <div class="auth-card mb-4" style="border-left: 4px solid @aqiColor">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3">
                <div>
                    <div class="text-muted text-uppercase small fw-600">Current AQI US</div>
                    <div class="d-flex align-items-baseline gap-2 mt-2">
                        <span class="display-3 fw-800" style="color:@aqiColor">@(s.AqiUs.HasValue ? Math.Round(s.AqiUs.Value).ToString("0", CultureInfo.InvariantCulture) : "—")</span>
                        <span class="text-muted">AQI</span>
                    </div>
                    @if (s.Pm25.HasValue)
                    {
                        <div class="text-muted small mt-2">PM2.5: <strong>@s.Pm25.Value.ToString("0.0", CultureInfo.InvariantCulture)</strong> µg/m³</div>
                    }
                </div>
                <div class="text-md-end">
                    <span class="aqi-pill" style="background:@aqiColor; color:@(darkAqiText ? "#78350F" : "#fff")">@aqiLabel</span>
                    <div class="text-muted small mt-2">Measured @measuredRelative</div>
                </div>
            </div>
        </div>

        @if (isStale)
        {
            <div class="alert alert-warning d-flex align-items-start gap-2 mb-4">
                <i class="bi bi-exclamation-triangle mt-1"></i>
                <div>This station last reported @measuredRelative. Data may not reflect current conditions.</div>
            </div>
        }

        <div class="row g-4">
            <div class="col-md-7">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-3">Last 24 hours @(hasAqiHistory ? "(AQI US)" : "(PM2.5)")</h2>
                    @if (chartPoints.Length == 0)
                    {
                        <p class="text-muted mb-0">No readings in the last 24 hours.</p>
                    }
                    else
                    {
                        <canvas id="pm25-chart" height="120"></canvas>
                    }
                </div>

                <div class="auth-card">
                    <h2 class="h6 fw-700 mb-3">Recent readings</h2>
                    @if (Model.Last24Hours.Count == 0)
                    {
                        <p class="text-muted mb-0">No readings yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Time</th>
                                        <th>PM2.5</th>
                                        <th>PM10</th>
                                        <th>Temp</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Model.Last24Hours.OrderByDescending(x => x.MeasuredAt).Take(10))
                                    {
                                        <tr>
                                            <td class="text-muted small">@DateHelpers.FormatShort(r.MeasuredAt)</td>
                                            <td>@(r.Pm25?.ToString("0.0", CultureInfo.InvariantCulture) ?? "n/a")</td>
                                            <td>@(r.Pm10?.ToString("0.0", CultureInfo.InvariantCulture) ?? "n/a")</td>
                                            <td>@(r.Temperature?.ToString("0.0", CultureInfo.InvariantCulture) ?? "n/a")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-5">
                <div class="auth-card mb-3">
                    <h2 class="h6 fw-700 mb-3">Current values</h2>
                    <dl class="row mb-0 small">
                        <dt class="col-5 text-muted fw-500">AQI US</dt>
                        <dd class="col-7 mb-2">@(s.AqiUs.HasValue ? Math.Round(s.AqiUs.Value).ToString("0", CultureInfo.InvariantCulture) : "n/a")</dd>
                        <dt class="col-5 text-muted fw-500">PM2.5</dt>
                        <dd class="col-7 mb-2">@Pretty(s.Pm25, "µg/m³")</dd>
                        <dt class="col-5 text-muted fw-500">PM10</dt>
                        <dd class="col-7 mb-2">@Pretty(s.Pm10, "µg/m³")</dd>
                        <dt class="col-5 text-muted fw-500">Temperature</dt>
                        <dd class="col-7 mb-2">@Pretty(s.Temperature, "°C")</dd>
                        <dt class="col-5 text-muted fw-500">Humidity</dt>
                        <dd class="col-7 mb-2">@Pretty(s.Humidity, "%")</dd>
                        <dt class="col-5 text-muted fw-500">Pressure</dt>
                        <dd class="col-7 mb-0">@Pretty(s.Pressure, "hPa", "0")</dd>
                    </dl>
                </div>

                <div class="auth-card">
                    <h2 class="h6 fw-700 mb-3">Location</h2>
                    <div id="station-map" style="height: 280px; border-radius: 14px; border: 1px solid var(--brand-border);"></div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const lat = @s.Latitude.ToString(CultureInfo.InvariantCulture);
            const lng = @s.Longitude.ToString(CultureInfo.InvariantCulture);

            const map = L.map('station-map', { scrollWheelZoom: false }).setView([lat, lng], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);
            L.circleMarker([lat, lng], {
                radius: 12,
                color: '#fff',
                weight: 2,
                fillColor: '@aqiColor',
                fillOpacity: 0.9
            }).addTo(map);

            const points = @Html.Raw(chartJson);
            const canvas = document.getElementById('pm25-chart');
            if (canvas && points.length > 0 && typeof Chart !== 'undefined') {
                new Chart(canvas.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: points.map(p => p.t),
                        datasets: [{
                            label: '@chartLabel',
                            data: points.map(p => p.v),
                            borderColor: '#2D6A4F',
                            backgroundColor: 'rgba(45, 106, 79, 0.12)',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: {
                                ticks: {
                                    callback: function (val) {
                                        var label = this.getLabelForValue(val);
                                        return label ? label.substring(11, 16) : '';
                                    },
                                    autoSkip: true,
                                    maxTicksLimit: 8
                                }
                            },
                            y: { beginAtZero: true }
                        }
                    }
                });
            }
        })();
    </script>
}
