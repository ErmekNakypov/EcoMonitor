@model CreateReportViewModel
@{
    ViewData["Title"] = "Report a dumpsite";
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "My reports", Url = Url.Action("Reports", "Citizen") },
        new BreadcrumbItem { Label = "New report" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-camera"></i>
                <span>Report a dumpsite</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">Report an unauthorized dumpsite</h1>
            <p class="text-muted mb-0">Pin the location, describe what you see, attach photos.</p>
        </div>

        <form asp-controller="Citizen" asp-action="Create" method="post" enctype="multipart/form-data" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <div class="col-md-7">
                    <div class="auth-card">
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-500"></label>
                            <textarea asp-for="Description" rows="5" class="form-control"
                                      placeholder="What did you see? Approximate size, type of waste, anything noteworthy."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-500" for="photos-input">Photos</label>
                            <input id="photos-input" name="photos" type="file" multiple accept="image/jpeg,image/png,image/webp"
                                   class="form-control" />
                            <div class="form-text">JPEG, PNG, or WEBP. Up to 5 photos, 5 MB each.</div>
                            <ul id="photos-list" class="list-unstyled mt-2 mb-0"></ul>
                        </div>

                        <input type="hidden" name="Latitude" id="Latitude" value="" />
                        <input type="hidden" name="Longitude" id="Longitude" value="" />

                        <div class="mb-3">
                            <span class="form-label fw-500 d-block">Location</span>
                            <span id="coords-text" class="text-muted small">Click on the map to set the location.</span>
                            <span asp-validation-for="Latitude" class="text-danger small d-block"></span>
                            <span asp-validation-for="Longitude" class="text-danger small d-block"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-between align-items-center">
                            <a asp-controller="Citizen" asp-action="Reports" class="btn btn-outline-secondary btn-lg">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="bi bi-send me-2"></i>Submit report
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div id="dumpsite-map"></div>
                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mt-3">
                        <span class="text-muted small">Click on the map to set the location, or use the locate button.</span>
                        <button type="button" id="locate-btn" class="btn btn-outline-secondary">
                            <i class="bi bi-geo-alt-fill me-2"></i>Use my location
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const map = L.map('dumpsite-map').setView([42.8746, 74.5698], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            const latInput = document.getElementById('Latitude');
            const lngInput = document.getElementById('Longitude');
            const coordText = document.getElementById('coords-text');
            let marker = null;

            function updateInputs(latlng) {
                latInput.value = latlng.lat.toString();
                lngInput.value = latlng.lng.toString();
                coordText.textContent = 'Location: ' + latlng.lat.toFixed(6) + ', ' + latlng.lng.toFixed(6);
                coordText.classList.remove('text-muted');
                coordText.classList.add('text-body');
            }

            function placeMarker(latlng) {
                if (marker) {
                    marker.setLatLng(latlng);
                } else {
                    marker = L.marker(latlng, { draggable: true }).addTo(map);
                    marker.on('dragend', function (e) {
                        updateInputs(e.target.getLatLng());
                    });
                }
                updateInputs(latlng);
            }

            map.on('click', function (e) { placeMarker(e.latlng); });

            document.getElementById('locate-btn').addEventListener('click', function () {
                map.locate({ setView: true, maxZoom: 16 });
            });

            map.on('locationfound', function (e) { placeMarker(e.latlng); });
            map.on('locationerror', function () {
                alert('Could not determine your location.');
            });

            document.getElementById('photos-input').addEventListener('change', function () {
                const list = document.getElementById('photos-list');
                list.innerHTML = '';
                Array.from(this.files).forEach(function (f) {
                    const li = document.createElement('li');
                    li.className = 'small text-muted';
                    li.innerHTML = '<i class="bi bi-paperclip me-1"></i>' + f.name + ' (' + (f.size / 1024).toFixed(1) + ' KB)';
                    list.appendChild(li);
                });
            });
        })();
    </script>
}
