@model ReportDetailsViewModel
@using EcoMonitor.Domain.Enums
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    var headline = Model.Description.Length > 80 ? Model.Description[..80] + "…" : Model.Description;
    if (string.IsNullOrWhiteSpace(headline)) headline = Localizer["FallbackHeadline"].Value;
    ViewData["Title"] = Localizer["Title"].Value;

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Home"].Value,      Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.MyReports"].Value, Url = Url.Action("Reports", "Citizen") },
        new BreadcrumbItem { Label = headline });

    int currentStage = Model.Status switch
    {
        DumpsiteStatus.New => 1,
        DumpsiteStatus.InReview => 2,
        DumpsiteStatus.Confirmed => 3,
        DumpsiteStatus.CleanupInProgress => 4,
        DumpsiteStatus.AwaitingVerification => 4,
        DumpsiteStatus.FlaggedByCleanupCrew => 4,
        DumpsiteStatus.Resolved => 5,
        DumpsiteStatus.Appealed => 5,
        DumpsiteStatus.Closed => 5,
        _ => 1
    };

    bool isRejected = Model.Status == DumpsiteStatus.Rejected;

    // For a Rejected report, find at which stage the rejection happened so
    // the stepper can show partial progress. If a cleanup crew was ever
    // recorded the rejection landed at the Cleanup stage (4); otherwise
    // rejection happened during inspector review (stage 2). The citizen
    // DTO doesn't expose CleanupFlaggedAt, so "crew was assigned" is the
    // available proxy.
    int rejectionStage = isRejected
        ? (Model.CleanupCrewName is not null ? 4 : 2)
        : -1;

    string StepClass(int step)
    {
        if (isRejected)
        {
            if (step < rejectionStage) return "done";
            if (step == rejectionStage) return "rejected-stage";
            return "faded";
        }
        if (step < currentStage) return "done";
        if (step == currentStage) return "active";
        return string.Empty;
    }

    // Per-status stage-5 label is picked here so the markup stays branch-free.
    string stage5LabelKey = Model.Status == DumpsiteStatus.Closed ? "Step5Closed" : "Step5Resolved";

    var remaining = Model.AppealTimeRemaining;
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-4">
            <div>
                <div class="mb-2 d-flex flex-wrap gap-2 align-items-center">
                    <partial name="_StatusBadge" model="Model.Status" />
                    @if (!string.IsNullOrEmpty(Model.DistrictNameRu))
                    {
                        <span class="district-badge" style="background:@Model.DistrictColorHex;">
                            <i class="bi bi-geo-alt-fill"></i>@Model.DistrictNameRu
                        </span>
                    }
                </div>
                <h1 class="h3 fw-700 mt-2 mb-1">@headline</h1>
                <p class="text-muted small mb-0">
                    @Localizer["ReportedAndUpdated",
                        DateHelpers.FormatRelative(Model.CreatedAt),
                        DateHelpers.FormatShort(Model.CreatedAt),
                        DateHelpers.FormatRelative(Model.UpdatedAt)]
                </p>
            </div>
            @if (Model.CanAppeal && Model.AppealedAt is null)
            {
                <div>
                    <button type="button" class="btn btn-outline-danger"
                            data-bs-toggle="modal" data-bs-target="#appeal-modal">
                        <i class="bi bi-flag-fill me-1"></i>
                        @Localizer["AppealButton"]
                    </button>
                    @if (remaining is { } left)
                    {
                        <div class="text-muted small mt-1 text-end">
                            @Localizer["AppealTimeRemaining", Math.Max(0, (int)left.TotalDays), left.Hours]
                        </div>
                    }
                </div>
            }
        </div>

        <div class="auth-card mb-4">
            <h2 class="h6 fw-700 mb-3">@Localizer["Progress"]</h2>
            <div class="status-stepper">
                <div class="status-step @StepClass(1)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 1 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)1)</span>
                    <div class="status-step-label">@Localizer["Step1Submitted"]</div>
                </div>
                <div class="status-step @StepClass(2)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 2 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)2)</span>
                    <div class="status-step-label">@Localizer["Step2InReview"]</div>
                </div>
                <div class="status-step @StepClass(3)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 3 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)3)</span>
                    <div class="status-step-label">@Localizer["Step3Confirmed"]</div>
                </div>
                <div class="status-step @StepClass(4)">
                    <span class="status-step-bullet">@(isRejected && rejectionStage == 4 ? Html.Raw("<i class=\"bi bi-x-lg\"></i>") : (object)4)</span>
                    <div class="status-step-label">
                        @Localizer["Step4Cleanup"]
                        @if (Model.Status == DumpsiteStatus.AwaitingVerification)
                        {
                            <div class="text-muted small mt-1">@Localizer["Step4SubAwaitingVerification"]</div>
                        }
                        else if (Model.Status == DumpsiteStatus.FlaggedByCleanupCrew)
                        {
                            <div class="text-muted small mt-1">@Localizer["Step4SubFlagged"]</div>
                        }
                    </div>
                </div>
                <div class="status-step @StepClass(5)">
                    <span class="status-step-bullet">5</span>
                    <div class="status-step-label">
                        @Localizer[stage5LabelKey]
                        @if (Model.Status == DumpsiteStatus.Appealed)
                        {
                            <span class="badge ms-1" style="background:#FEE2E2;color:#991B1B;">@Localizer["Step5BadgeAppealed"]</span>
                        }
                    </div>
                </div>
            </div>
            @if (Model.Status == DumpsiteStatus.Appealed)
            {
                <div class="alert alert-info small mb-0 mt-3">
                    <i class="bi bi-flag-fill me-1"></i> @Localizer["AppealUnderReview"]
                </div>
            }
        </div>

        @if (isRejected)
        {
            <div class="alert-rejected mb-4">
                <i class="bi bi-x-circle-fill"></i>
                <div>
                    <div class="fw-700">@Localizer["ReportRejected"]</div>
                    @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                    {
                        <div style="font-size:0.875rem;margin-top:0.25rem;">@Model.RejectionReason</div>
                    }
                    @if (Model.ResolvedAt.HasValue)
                    {
                        <div class="text-muted small mt-2">@Localizer["ClosedOn", DateHelpers.FormatShort(Model.ResolvedAt.Value)]</div>
                    }
                </div>
            </div>
        }

        <div class="row g-4">
            <div class="col-md-7">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-2">@Localizer["DescriptionHeading"]</h2>
                    <p class="mb-0">@Model.Description</p>
                </div>

                @if (Model.PhotoPaths.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-1">@Localizer["YourPhotos", Model.PhotoPaths.Count]</h2>
                        <p class="text-muted small mb-3">@Localizer["YourPhotosCaption"]</p>
                        <div class="photo-gallery">
                            @for (int i = 0; i < Model.PhotoPaths.Count; i++)
                            {
                                var path = Model.PhotoPaths[i];
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="@Localizer["AltReportPhoto", i + 1]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.InspectionPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-1">@Localizer["InspectorPhotos", Model.InspectionPhotos.Count]</h2>
                        <p class="text-muted small mb-3">@Localizer["InspectorPhotosCaption"]</p>
                        <div class="photo-gallery">
                            @foreach (var path in Model.InspectionPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="@Localizer["AltInspectorPhoto"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.BeforeCleanupPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-1">@Localizer["BeforeCleanup", Model.BeforeCleanupPhotos.Count]</h2>
                        <p class="text-muted small mb-3">@Localizer["BeforeCleanupCaption"]</p>
                        <div class="photo-gallery">
                            @foreach (var path in Model.BeforeCleanupPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="@Localizer["AltBeforeCleanup"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.AfterCleanupPhotos.Count > 0)
                {
                    <div class="auth-card photo-section-highlight mb-4">
                        <h2 class="h6 fw-700 mb-1">@Localizer["AfterCleanup", Model.AfterCleanupPhotos.Count]</h2>
                        @* AfterCleanupCaption contains a <strong>...</strong> emphasis span
                           kept inside the resource value; IHtmlLocalizer renders it without
                           re-encoding so the bold passes through. *@
                        <p class="text-muted small mb-3">@Localizer["AfterCleanupCaption"]</p>
                        <div class="photo-gallery">
                            @foreach (var path in Model.AfterCleanupPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="@Localizer["AltAfterCleanup"]" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if ((Model.Status == DumpsiteStatus.Resolved || Model.Status == DumpsiteStatus.Appealed || Model.Status == DumpsiteStatus.Closed)
                    && Model.ResolvedAt.HasValue)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">@Localizer["Resolution"]</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.ResolutionNotes))
                        {
                            <p class="mb-2">@Model.ResolutionNotes</p>
                        }
                        <div class="resolution-meta">
                            @if (!string.IsNullOrEmpty(Model.CleanupCrewName))
                            {
                                <div><i class="bi bi-people-fill me-1"></i> @Localizer["CleanedUpBy", Model.CleanupCrewName]</div>
                            }
                            @if (Model.CleanupCompletedAt.HasValue)
                            {
                                <div><i class="bi bi-clock me-1"></i> @Localizer["CleanupCompleted", DateHelpers.FormatShort(Model.CleanupCompletedAt.Value)]</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.VerifiedByInspectorName))
                            {
                                <div><i class="bi bi-shield-check me-1"></i> @Localizer["VerifiedByInspectorOn", Model.VerifiedByInspectorName, DateHelpers.FormatShort(Model.ResolvedAt.Value)]</div>
                            }
                            else
                            {
                                <div><i class="bi bi-shield-check me-1"></i> @Localizer["VerifiedOn", DateHelpers.FormatShort(Model.ResolvedAt.Value)]</div>
                            }
                        </div>
                    </div>
                }

                @if (Model.AppealedAt is not null)
                {
                    <div class="auth-card mb-4" style="border-left:4px solid #DC2626;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h2 class="h6 fw-700 mb-0">@Localizer["YourAppeal"]</h2>
                            <span class="text-muted small">@Localizer["Filed", DateHelpers.FormatShort(Model.AppealedAt.Value)]</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.AppealReason))
                        {
                            <p class="mb-2">@Model.AppealReason</p>
                        }
                        @if (Model.AppealPhotos.Count > 0)
                        {
                            <div class="photo-gallery mb-2">
                                @for (int i = 0; i < Model.AppealPhotos.Count; i++)
                                {
                                    var path = Model.AppealPhotos[i];
                                    <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                        <img src="@path" alt="@Localizer["AltAppealPhoto", i + 1]" />
                                    </a>
                                }
                            </div>
                        }
                        @if (Model.AppealReviewedAt is null)
                        {
                            <p class="text-muted small mb-0">
                                <i class="bi bi-hourglass-split me-1"></i>
                                @Localizer["WaitingForReview"]
                            </p>
                        }
                        else
                        {
                            var outcomeClass = Model.AppealOutcome == AppealOutcome.Upheld ? "text-success" : "text-secondary";
                            var outcomeLabelKey = Model.AppealOutcome == AppealOutcome.Upheld ? "AppealUpheld" : "AppealDismissed";
                            <div class="mt-2 pt-2 border-top">
                                <strong class="@outcomeClass d-block mb-1">@Localizer[outcomeLabelKey]</strong>
                                @if (!string.IsNullOrWhiteSpace(Model.AppealResolutionNotes))
                                {
                                    <p class="mb-1">@Model.AppealResolutionNotes</p>
                                }
                                <p class="text-muted small mb-0">@Localizer["ReviewedOn", DateHelpers.FormatShort(Model.AppealReviewedAt.Value)]</p>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="col-md-5">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-3">@Localizer["Location"]</h2>
                    <div id="details-map"></div>
                    <p class="text-muted small mb-0 mt-2">@Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")</p>
                </div>

                <div class="auth-card">
                    <h2 class="h6 fw-700 mb-3"><i class="bi bi-clock-history me-1"></i>@Localizer["ActivityTimeline"]</h2>
                    @await Html.PartialAsync("_ReportTimeline", Model.Events)
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="photo-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img id="photo-modal-img" src="" alt="@Localizer["AltPhotoModal"]" class="w-100 rounded" />
            </div>
        </div>
    </div>
</div>

@if (Model.CanAppeal && Model.AppealedAt is null)
{
    <div class="modal fade" id="appeal-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="post" enctype="multipart/form-data"
                  action="@Url.Action("Appeal", "Citizen", new { id = Model.Id })">
                @Html.AntiForgeryToken()
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@Localizer["AppealButton"]</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@SharedLocalizer["Common.Close"]"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">
                            @Localizer["ModalBodyExplain"]
                        </p>
                        <div class="mb-3">
                            <label for="appeal-reason" class="form-label fw-700">@Localizer["ModalReasonLabel"]</label>
                            <textarea id="appeal-reason" name="appealReason" class="form-control"
                                      rows="4" minlength="10" maxlength="500" required></textarea>
                            <div class="form-text">@Localizer["ModalReasonHelp"]</div>
                        </div>
                        <div class="mb-2">
                            <label for="appeal-photos" class="form-label fw-700">@Localizer["ModalPhotosLabel"]</label>
                            <input id="appeal-photos" name="appealPhotos" type="file" class="form-control"
                                   accept="image/jpeg,image/png,image/webp" multiple />
                            <div class="form-text">@Localizer["ModalPhotosHelp"]</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@SharedLocalizer["Common.Cancel"]</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-flag-fill me-1"></i>
                            @Localizer["ModalSubmitButton"]
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const map = L.map('details-map', {
                zoomControl: true,
                scrollWheelZoom: false
            }).setView([lat, lng], 15);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map);

            const modal = document.getElementById('photo-modal');
            modal.addEventListener('show.bs.modal', function (event) {
                const trigger = event.relatedTarget;
                const src = trigger ? trigger.getAttribute('data-photo-src') : null;
                if (src) {
                    document.getElementById('photo-modal-img').setAttribute('src', src);
                }
            });
        })();
    </script>
}
