@model ReportDetailsViewModel
@using EcoMonitor.Domain.Enums
@{
    var headline = Model.Description.Length > 80 ? Model.Description[..80] + "…" : Model.Description;
    if (string.IsNullOrWhiteSpace(headline)) headline = "Dumpsite report";
    ViewData["Title"] = "Report details";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "My reports", Url = Url.Action("Reports", "Citizen") },
        new BreadcrumbItem { Label = headline });

    int currentStage = Model.Status switch
    {
        DumpsiteStatus.New => 1,
        DumpsiteStatus.InReview => 2,
        DumpsiteStatus.Confirmed => 3,
        DumpsiteStatus.CleanupInProgress => 4,
        DumpsiteStatus.AwaitingVerification => 4,
        DumpsiteStatus.Resolved => 5,
        DumpsiteStatus.Appealed => 5,
        DumpsiteStatus.Closed => 5,
        _ => 1
    };

    bool isRejected = Model.Status == DumpsiteStatus.Rejected;

    string StepClass(int step)
    {
        if (step < currentStage) return "done";
        if (step == currentStage) return "active";
        return string.Empty;
    }

    string Stage5Label = Model.Status == DumpsiteStatus.Closed ? "Closed" : "Resolved";

    var remaining = Model.AppealTimeRemaining;
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-4">
            <div>
                <div class="mb-2">
                    <partial name="_StatusBadge" model="Model.Status" />
                </div>
                <h1 class="h3 fw-700 mt-2 mb-1">@headline</h1>
                <p class="text-muted small mb-0">
                    Reported @DateHelpers.FormatRelative(Model.CreatedAt) (@DateHelpers.FormatShort(Model.CreatedAt))
                    &middot; updated @DateHelpers.FormatRelative(Model.UpdatedAt)
                </p>
            </div>
            @if (Model.CanAppeal && Model.AppealedAt is null)
            {
                <div>
                    <button type="button" class="btn btn-outline-danger"
                            data-bs-toggle="modal" data-bs-target="#appeal-modal">
                        <i class="bi bi-flag-fill me-1"></i>
                        Appeal this resolution
                    </button>
                    @if (remaining is { } left)
                    {
                        <div class="text-muted small mt-1 text-end">
                            @Math.Max(0, (int)left.TotalDays)d @left.Hours h left to appeal
                        </div>
                    }
                </div>
            }
        </div>

        @if (isRejected)
        {
            <div class="alert-rejected mb-4">
                <i class="bi bi-x-circle-fill"></i>
                <div>
                    <div class="fw-700">Report rejected</div>
                    @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                    {
                        <div style="font-size:0.875rem;margin-top:0.25rem;">@Model.RejectionReason</div>
                    }
                    @if (Model.ResolvedAt.HasValue)
                    {
                        <div class="text-muted small mt-2">Closed on @DateHelpers.FormatShort(Model.ResolvedAt.Value)</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="auth-card mb-4">
                <h2 class="h6 fw-700 mb-3">Progress</h2>
                <div class="status-stepper">
                    <div class="status-step @StepClass(1)">
                        <span class="status-step-bullet">1</span>
                        <div class="status-step-label">Submitted</div>
                    </div>
                    <div class="status-step @StepClass(2)">
                        <span class="status-step-bullet">2</span>
                        <div class="status-step-label">In review</div>
                    </div>
                    <div class="status-step @StepClass(3)">
                        <span class="status-step-bullet">3</span>
                        <div class="status-step-label">Confirmed</div>
                    </div>
                    <div class="status-step @StepClass(4)">
                        <span class="status-step-bullet">4</span>
                        <div class="status-step-label">
                            Cleanup
                            @if (Model.Status == DumpsiteStatus.AwaitingVerification)
                            {
                                <div class="text-muted small mt-1">Awaiting inspector verification</div>
                            }
                        </div>
                    </div>
                    <div class="status-step @StepClass(5)">
                        <span class="status-step-bullet">5</span>
                        <div class="status-step-label">
                            @Stage5Label
                            @if (Model.Status == DumpsiteStatus.Appealed)
                            {
                                <span class="badge ms-1" style="background:#FEE2E2;color:#991B1B;">Appealed</span>
                            }
                        </div>
                    </div>
                </div>
                @if (Model.Status == DumpsiteStatus.Appealed)
                {
                    <div class="alert alert-info small mb-0 mt-3">
                        <i class="bi bi-flag-fill me-1"></i> Your appeal is under review by an inspector.
                    </div>
                }
            </div>
        }

        <div class="row g-4">
            <div class="col-md-7">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-2">Description</h2>
                    <p class="mb-0">@Model.Description</p>
                </div>

                @if (Model.PhotoPaths.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-1">Your photos (@Model.PhotoPaths.Count)</h2>
                        <p class="text-muted small mb-3">Photos you submitted with this report.</p>
                        <div class="photo-gallery">
                            @for (int i = 0; i < Model.PhotoPaths.Count; i++)
                            {
                                var path = Model.PhotoPaths[i];
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="Report photo @(i + 1)" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.InspectionPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-1">Inspector verification photos (@Model.InspectionPhotos.Count)</h2>
                        <p class="text-muted small mb-3">Photos taken by the inspector when confirming the dumpsite.</p>
                        <div class="photo-gallery">
                            @foreach (var path in Model.InspectionPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="Inspector photo" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.BeforeCleanupPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-1">Before cleanup (@Model.BeforeCleanupPhotos.Count)</h2>
                        <p class="text-muted small mb-3">State of the site when the cleanup crew arrived.</p>
                        <div class="photo-gallery">
                            @foreach (var path in Model.BeforeCleanupPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="Before cleanup" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.AfterCleanupPhotos.Count > 0)
                {
                    <div class="auth-card photo-section-highlight mb-4">
                        <h2 class="h6 fw-700 mb-1">After cleanup (@Model.AfterCleanupPhotos.Count)</h2>
                        <p class="text-muted small mb-3">State of the site after cleanup. <strong>This is what was reported as resolved.</strong></p>
                        <div class="photo-gallery">
                            @foreach (var path in Model.AfterCleanupPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="After cleanup" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if ((Model.Status == DumpsiteStatus.Resolved || Model.Status == DumpsiteStatus.Appealed || Model.Status == DumpsiteStatus.Closed)
                    && Model.ResolvedAt.HasValue)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">Resolution</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.ResolutionNotes))
                        {
                            <p class="mb-2">@Model.ResolutionNotes</p>
                        }
                        <div class="resolution-meta">
                            @if (!string.IsNullOrEmpty(Model.CleanupCrewName))
                            {
                                <div><i class="bi bi-people-fill me-1"></i> Cleaned up by <strong>@Model.CleanupCrewName</strong></div>
                            }
                            @if (Model.CleanupCompletedAt.HasValue)
                            {
                                <div><i class="bi bi-clock me-1"></i> Cleanup completed @DateHelpers.FormatShort(Model.CleanupCompletedAt.Value)</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.VerifiedByInspectorName))
                            {
                                <div><i class="bi bi-shield-check me-1"></i> Verified by inspector <strong>@Model.VerifiedByInspectorName</strong> on @DateHelpers.FormatShort(Model.ResolvedAt.Value)</div>
                            }
                            else
                            {
                                <div><i class="bi bi-shield-check me-1"></i> Verified @DateHelpers.FormatShort(Model.ResolvedAt.Value)</div>
                            }
                        </div>
                    </div>
                }

                @if (Model.AppealedAt is not null)
                {
                    <div class="auth-card mb-4" style="border-left:4px solid #DC2626;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h2 class="h6 fw-700 mb-0">Your appeal</h2>
                            <span class="text-muted small">Filed @DateHelpers.FormatShort(Model.AppealedAt.Value)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.AppealReason))
                        {
                            <p class="mb-2">@Model.AppealReason</p>
                        }
                        @if (Model.AppealPhotos.Count > 0)
                        {
                            <div class="photo-gallery mb-2">
                                @for (int i = 0; i < Model.AppealPhotos.Count; i++)
                                {
                                    var path = Model.AppealPhotos[i];
                                    <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                        <img src="@path" alt="Appeal photo @(i + 1)" />
                                    </a>
                                }
                            </div>
                        }
                        @if (Model.AppealReviewedAt is null)
                        {
                            <p class="text-muted small mb-0">
                                <i class="bi bi-hourglass-split me-1"></i>
                                Waiting for an inspector to review.
                            </p>
                        }
                        else
                        {
                            var outcomeClass = Model.AppealOutcome == AppealOutcome.Upheld ? "text-success" : "text-secondary";
                            var outcomeLabel = Model.AppealOutcome == AppealOutcome.Upheld ? "Appeal upheld — cleanup will be redone" : "Appeal dismissed";
                            <div class="mt-2 pt-2 border-top">
                                <strong class="@outcomeClass d-block mb-1">@outcomeLabel</strong>
                                @if (!string.IsNullOrWhiteSpace(Model.AppealResolutionNotes))
                                {
                                    <p class="mb-1">@Model.AppealResolutionNotes</p>
                                }
                                <p class="text-muted small mb-0">Reviewed @DateHelpers.FormatShort(Model.AppealReviewedAt.Value)</p>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="col-md-5">
                <div class="auth-card">
                    <h2 class="h6 fw-700 mb-3">Location</h2>
                    <div id="details-map"></div>
                    <p class="text-muted small mb-0 mt-2">@Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="photo-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img id="photo-modal-img" src="" alt="Report photo" class="w-100 rounded" />
            </div>
        </div>
    </div>
</div>

@if (Model.CanAppeal && Model.AppealedAt is null)
{
    <div class="modal fade" id="appeal-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="post" enctype="multipart/form-data"
                  action="@Url.Action("Appeal", "Citizen", new { id = Model.Id })">
                @Html.AntiForgeryToken()
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Appeal this resolution</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">
                            Explain what's still wrong. An inspector will revisit the site. You have 7 days from
                            the resolution to appeal.
                        </p>
                        <div class="mb-3">
                            <label for="appeal-reason" class="form-label fw-700">Reason</label>
                            <textarea id="appeal-reason" name="appealReason" class="form-control"
                                      rows="4" minlength="10" maxlength="500" required></textarea>
                            <div class="form-text">10–500 characters.</div>
                        </div>
                        <div class="mb-2">
                            <label for="appeal-photos" class="form-label fw-700">Photos (optional, up to 5)</label>
                            <input id="appeal-photos" name="appealPhotos" type="file" class="form-control"
                                   accept="image/jpeg,image/png,image/webp" multiple />
                            <div class="form-text">JPEG, PNG, or WEBP. Max 5 MB each.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-flag-fill me-1"></i>
                            Submit appeal
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const map = L.map('details-map', {
                zoomControl: true,
                scrollWheelZoom: false
            }).setView([lat, lng], 15);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map);

            const modal = document.getElementById('photo-modal');
            modal.addEventListener('show.bs.modal', function (event) {
                const trigger = event.relatedTarget;
                const src = trigger ? trigger.getAttribute('data-photo-src') : null;
                if (src) {
                    document.getElementById('photo-modal-img').setAttribute('src', src);
                }
            });
        })();
    </script>
}
