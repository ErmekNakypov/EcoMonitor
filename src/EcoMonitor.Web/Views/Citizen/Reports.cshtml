@model ReportListViewModel
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Nav.MyReports"].Value;
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Home"].Value,      Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.MyReports"].Value });

    string TabClass(string t) => Model.Tab == t ? "nav-link active" : "nav-link";

    // Per-tab empty-state copy. Keys live in this view's per-view .resx;
    // looked up via the IViewLocalizer at render time. Pulled to .Value
    // because EmptyStateViewModel takes plain strings, not LocalizedHtmlString.
    var (emptyTitleKey, emptySubtitleKey) = Model.Tab switch
    {
        "active"   => ("EmptyActiveTitle",   "EmptyActiveSubtitle"),
        "resolved" => ("EmptyResolvedTitle", "EmptyResolvedSubtitle"),
        "rejected" => ("EmptyRejectedTitle", "EmptyRejectedSubtitle"),
        _          => ("EmptyDefaultTitle",  "EmptyDefaultSubtitle")
    };
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-list-task"></i>
                    <span>@Localizer["Badge"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@SharedLocalizer["Nav.MyReports"]</h1>
                <p class="text-muted mb-0">@Localizer["TotalCount", Model.OverallCount]</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-controller="Citizen" asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>@SharedLocalizer["Nav.ReportDumpsite"]
                </a>
            </div>
        </div>

        <ul class="nav nav-pills role-tabs mb-3" role="tablist">
            <li class="nav-item">
                <a class="@TabClass("active")" asp-controller="Citizen" asp-action="Reports" asp-route-tab="active">
                    @Localizer["TabActive"] <span class="role-tab-count">@Model.ActiveCount</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="@TabClass("resolved")" asp-controller="Citizen" asp-action="Reports" asp-route-tab="resolved">
                    @Localizer["TabResolved"] <span class="role-tab-count">@Model.ResolvedCount</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="@TabClass("rejected")" asp-controller="Citizen" asp-action="Reports" asp-route-tab="rejected">
                    @Localizer["TabRejected"] <span class="role-tab-count">@Model.RejectedCount</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="@TabClass("all")" asp-controller="Citizen" asp-action="Reports" asp-route-tab="all">
                    @Localizer["TabAll"] <span class="role-tab-count">@Model.OverallCount</span>
                </a>
            </li>
        </ul>

        @if (Model.Reports.Count == 0)
        {
            var emptyState = Model.OverallCount == 0
                ? new EmptyStateViewModel
                {
                    Icon = "bi-clipboard-plus",
                    Title = Localizer["EmptyDefaultTitle"].Value,
                    Subtitle = Localizer["EmptyDefaultSubtitle"].Value,
                    CtaText = Localizer["EmptyDefaultCta"].Value,
                    CtaUrl = Url.Action("Create", "Citizen"),
                    CtaIcon = "bi-plus-circle"
                }
                : new EmptyStateViewModel
                {
                    Icon = "bi-clipboard",
                    Title = Localizer[emptyTitleKey].Value,
                    Subtitle = Localizer[emptySubtitleKey].Value
                };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var report in Model.Reports)
                {
                    <div class="report-card">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(report.FirstPhotoPath))
                                {
                                    <img src="@report.FirstPhotoPath" alt="@Localizer["AltReportPhoto"]" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@report.ShortDescription</p>
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <partial name="_StatusBadge" model="report.Status" />
                                    <span class="text-muted small">@Localizer["ReportedAt", DateHelpers.FormatRelative(report.CreatedAt)]</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Citizen" asp-action="Details" asp-route-id="@report.Id" class="btn btn-outline-secondary">
                                    @Localizer["ViewDetails"] <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="@Localizer["PaginationAriaLabel"]">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Citizen" asp-action="Reports"
                               asp-route-page="@(Model.Page - 1)" asp-route-tab="@Model.Tab">@SharedLocalizer["Common.Previous"]</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Citizen" asp-action="Reports"
                                   asp-route-page="@p" asp-route-tab="@Model.Tab">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Citizen" asp-action="Reports"
                               asp-route-page="@(Model.Page + 1)" asp-route-tab="@Model.Tab">@SharedLocalizer["Common.Next"]</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
