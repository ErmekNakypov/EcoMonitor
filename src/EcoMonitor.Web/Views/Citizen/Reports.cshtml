@model ReportListViewModel
@{
    ViewData["Title"] = "My reports";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-list-task"></i>
                    <span>Your reports</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">My reports</h1>
                <p class="text-muted mb-0">@Model.TotalCount total &middot; page @Model.Page of @Model.TotalPages</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-controller="Citizen" asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>Report a dumpsite
                </a>
            </div>
        </div>

        @if (Model.Reports.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-clipboard-plus",
                Title = "You haven't reported any dumpsites yet",
                Subtitle = "When you submit your first report, it will appear here so you can track its progress.",
                CtaText = "Report your first dumpsite",
                CtaUrl = Url.Action("Create", "Citizen"),
                CtaIcon = "bi-plus-circle"
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var report in Model.Reports)
                {
                    <div class="report-card">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(report.FirstPhotoPath))
                                {
                                    <img src="@report.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@report.ShortDescription</p>
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <partial name="_StatusBadge" model="report.Status" />
                                    <span class="text-muted small">Reported @DateHelpers.FormatRelative(report.CreatedAt)</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Citizen" asp-action="Details" asp-route-id="@report.Id" class="btn btn-outline-secondary">
                                    View details <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Reports pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Citizen" asp-action="Reports" asp-route-page="@(Model.Page - 1)">Previous</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Citizen" asp-action="Reports" asp-route-page="@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Citizen" asp-action="Reports" asp-route-page="@(Model.Page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
