@model ReportListViewModel
@{
    ViewData["Title"] = "My reports";

    string StatusBadgeClass(DumpsiteStatus status) => status switch
    {
        DumpsiteStatus.New => "badge-status-new",
        DumpsiteStatus.InReview => "badge-status-review",
        DumpsiteStatus.Confirmed => "badge-status-confirmed",
        DumpsiteStatus.Resolved => "badge-status-resolved",
        DumpsiteStatus.Rejected => "badge-status-rejected",
        _ => "badge-status-new"
    };

    string Relative(DateTime dt)
    {
        var span = DateTime.UtcNow - dt.ToUniversalTime();
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} min ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays} d ago";
        return dt.ToLocalTime().ToString("d MMM yyyy");
    }
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-list-task"></i>
                    <span>Your reports</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">My reports</h1>
                <p class="text-muted mb-0">@Model.TotalCount total &middot; page @Model.Page of @Model.TotalPages</p>
            </div>
            <div class="mt-3 mt-sm-0">
                <a asp-controller="Citizen" asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>Report a dumpsite
                </a>
            </div>
        </div>

        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@success
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model.Reports.Count == 0)
        {
            <div class="auth-card text-center py-5">
                <div class="feature-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2.25rem;">
                    <i class="bi bi-clipboard-plus"></i>
                </div>
                <h2 class="h5 fw-700 mb-2">You haven't reported any dumpsites yet</h2>
                <p class="text-muted mb-4">When you submit your first report, it will appear here so you can track its progress.</p>
                <a asp-controller="Citizen" asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>Report your first dumpsite
                </a>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var report in Model.Reports)
                {
                    <div class="report-card">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(report.FirstPhotoPath))
                                {
                                    <img src="@report.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@report.ShortDescription</p>
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <span class="status-badge @StatusBadgeClass(report.Status)">@report.Status</span>
                                    <span class="text-muted small">Reported @Relative(report.CreatedAt)</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Citizen" asp-action="Details" asp-route-id="@report.Id" class="btn btn-outline-secondary">
                                    View details <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Reports pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Citizen" asp-action="Reports" asp-route-page="@(Model.Page - 1)">Previous</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Citizen" asp-action="Reports" asp-route-page="@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Citizen" asp-action="Reports" asp-route-page="@(Model.Page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
