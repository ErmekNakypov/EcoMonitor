@model AdministratorDashboardViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-shield-check"></i>
                    <span>@Localizer["BadgeRole"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
                <p class="text-muted mb-0">@Localizer["WelcomeBack", Model.FullName]</p>
            </div>
            <div class="text-muted small mt-3 mt-sm-0">@DateTime.Now.ToString("dddd, d MMMM yyyy")</div>
        </div>

        <section class="analytics-section mb-5">
            <h2 class="section-title">
                <i class="bi bi-bar-chart-line"></i>
                <span>@Localizer["AnalyticsHeading"]</span>
            </h2>
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3>@Localizer["Chart1Title"]</h3>
                            <span class="chart-subtitle">@Localizer["Chart1Subtitle"]</span>
                        </div>
                        <div class="chart-body">
                            <canvas id="chart-reports-by-day"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3>@Localizer["Chart2Title"]</h3>
                            <span class="chart-subtitle">@Localizer["Chart2Subtitle"]</span>
                        </div>
                        <div class="chart-body">
                            <canvas id="chart-status-breakdown"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-12">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3>@Localizer["Chart3Title"]</h3>
                            <span class="chart-subtitle">@Localizer["Chart3Subtitle"]</span>
                        </div>
                        <div class="chart-body">
                            <canvas id="chart-aqi-by-day"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <vc:air-quality-summary />

        @* Stat strip — single shared surface, hairline vertical dividers.
           Skill section "Dashboards and KPI stats (anti-AI patterns)":
           normal-case labels, no corner icons, no double accent borders;
           the three rate stats get a single semantic dot before the label. *@
        <div class="stat-strip mb-5">
            <div class="stat-strip__item">
                <span class="stat-strip__label">@Localizer["StatTotalUsersLabel"]</span>
                <div class="stat-strip__value">@Model.TotalUsers</div>
                <span class="stat-strip__caption">@Localizer["StatTotalUsersCaption"]</span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">@Localizer["StatTotalReportsLabel"]</span>
                <div class="stat-strip__value">@Model.TotalReports</div>
                <span class="stat-strip__caption">@Localizer["StatTotalReportsCaption"]</span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">@Localizer["StatTotalContainersLabel"]</span>
                <div class="stat-strip__value">@Model.TotalContainers</div>
                <span class="stat-strip__caption">@Localizer["StatTotalContainersCaption"]</span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">
                    <span class="stat-strip__dot" style="background: var(--em-ok);"></span>
                    @Localizer["StatAutoTriageLabel"]
                </span>
                <div class="stat-strip__value">@Model.AutoTriagePercentage30d.ToString("0.#")%</div>
                <span class="stat-strip__caption">
                    @if (Model.AutoTriageTotal30d == 0)
                    {
                        @Localizer["StatAutoTriageNoData"]
                    }
                    else
                    {
                        @Localizer["StatAutoTriageCaption", Model.AutoTriageAutoConfirmed30d, Model.AutoTriageTotal30d, Model.AutoTriageReviewed30d]
                    }
                </span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">
                    <span class="stat-strip__dot" style="background: var(--em-danger);"></span>
                    @Localizer["StatAppealsLabel"]
                </span>
                <div class="stat-strip__value">@Model.AppealsPercentage30d.ToString("0.#")%</div>
                <span class="stat-strip__caption">
                    @if (Model.AppealsTotalEligible30d == 0)
                    {
                        @Localizer["StatAppealsNoData"]
                    }
                    else
                    {
                        @Localizer["StatAppealsCaption", Model.AppealsAppealed30d, Model.AppealsTotalEligible30d]
                    }
                </span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">
                    <span class="stat-strip__dot" style="background: var(--em-warn);"></span>
                    @Localizer["StatFlagsLabel"]
                </span>
                <div class="stat-strip__value">@Model.FlagsPercentage30d.ToString("0.#")%</div>
                <span class="stat-strip__caption">
                    @if (Model.FlagsTotalEligible30d == 0)
                    {
                        @Localizer["StatFlagsNoData"]
                    }
                    else
                    {
                        @Localizer["StatFlagsCaption", Model.FlagsFlagged30d, Model.FlagsTotalEligible30d]
                    }
                </span>
            </div>
        </div>

        @if (Model.DistrictBreakdown30d.Any())
        {
            <div class="auth-card mb-4">
                <h2 class="h5 fw-700 mb-3"><i class="bi bi-bounding-box me-2"></i>@Localizer["DistrictHeading"]</h2>
                @{
                    var maxTotal = Math.Max(1, Model.DistrictBreakdown30d.Max(d => d.Total));
                }
                <div class="d-flex flex-column gap-3">
                    @foreach (var slice in Model.DistrictBreakdown30d)
                    {
                        var pct = (int)Math.Round(slice.Total * 100.0 / maxTotal);
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-600">
                                    <span class="district-badge" style="background:@slice.ColorHex;">
                                        <i class="bi bi-geo-alt-fill"></i>@slice.NameRu
                                    </span>
                                </span>
                                <span class="text-muted small">
                                    @Localizer["DistrictTotalSuffix", slice.Total]
                                    @if (slice.Resolved > 0 || slice.Rejected > 0 || slice.InProgress > 0)
                                    {
                                        @Localizer["DistrictDetailSuffix", slice.Resolved, slice.InProgress, slice.Rejected]
                                    }
                                </span>
                            </div>
                            <div style="height:10px;background:#F3F4F6;border-radius:6px;overflow:hidden;">
                                <div style="height:100%;width:@pct%;background:@slice.ColorHex;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="auth-card">
            <h2 class="h5 fw-700 mb-3">@Localizer["QuickActionsHeading"]</h2>
            <div class="row g-3">
                <div class="col-md-3">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="quick-link">
                        <i class="bi bi-people-fill"></i>
                        <span>@Localizer["QuickActionManageUsers"]</span>
                    </a>
                </div>
                <div class="col-md-3">
                    <a asp-area="Admin" asp-controller="Containers" asp-action="Index" class="quick-link">
                        <i class="bi bi-trash3"></i>
                        <span>@Localizer["QuickActionManageContainers"]</span>
                    </a>
                </div>
                <div class="col-md-3">
                    <a asp-area="" asp-controller="Map" asp-action="Index" class="quick-link">
                        <i class="bi bi-map"></i>
                        <span>@Localizer["QuickActionPublicMap"]</span>
                    </a>
                </div>
                <div class="col-md-3">
                    <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="quick-link">
                        <i class="bi bi-flag"></i>
                        <span>@Localizer["QuickActionViewReports"]</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @* JSON i18n bridge for the inline analytics JS. The seven strings
       below are referenced as window.__dashboardI18n.<key> inside the
       Chart.js setup and the fetch error / empty-state handlers.
       Russian pluralization on JsTooltipStations* uses two forms
       (singular vs many); counts 2–4 in Russian technically take a
       third form ("few") which is not handled — translator should
       refine if exact pluralization matters. *@
    <script>
        window.__dashboardI18n = {
            datasetReports:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsChartDatasetReports"].Value)),
            datasetAqi:        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsChartDatasetAqi"].Value)),
            loadFailed:        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsChartLoadFailed"].Value)),
            statusEmpty:       @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsChartStatusEmpty"].Value)),
            aqiEmpty:          @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsChartAqiEmpty"].Value)),
            stationSingular:   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsTooltipStationSingular"].Value)),
            stationsPlural:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["JsTooltipStationsPlural"].Value))
        };
    </script>
    <script>
        (function initAnalytics() {
            if (typeof Chart === 'undefined') {
                setTimeout(initAnalytics, 200);
                return;
            }

            var i18n = window.__dashboardI18n;
            var BRAND_PRIMARY = '#2D6A4F';
            var BRAND_ACCENT = '#74C69D';
            var TEXT_MUTED = '#6C757D';

            function formatDayLabel(isoDate) {
                var d = new Date(isoDate + 'T00:00:00Z');
                return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
            }

            function showEmpty(canvasId, message) {
                var canvas = document.getElementById(canvasId);
                if (!canvas) return;
                var parent = canvas.parentElement;
                canvas.remove();
                var empty = document.createElement('div');
                empty.className = 'chart-empty';
                empty.textContent = message;
                parent.appendChild(empty);
            }

            fetch('/Admin/Analytics/Data', { credentials: 'same-origin' })
                .then(function (r) {
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    return r.json();
                })
                .then(function (data) {
                    renderReportsByDay(data.reportsByDay || []);
                    renderStatusBreakdown(data.statusBreakdown || []);
                    renderAqiByDay(data.aqiByDay || []);
                })
                .catch(function (err) {
                    console.error('Analytics load failed', err);
                    showEmpty('chart-reports-by-day', i18n.loadFailed);
                    showEmpty('chart-status-breakdown', i18n.loadFailed);
                    showEmpty('chart-aqi-by-day', i18n.loadFailed);
                });

            function renderReportsByDay(rows) {
                var canvas = document.getElementById('chart-reports-by-day');
                if (!canvas) return;
                var labels = rows.map(function (r) { return formatDayLabel(r.date); });
                var values = rows.map(function (r) { return r.count; });

                new Chart(canvas.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: i18n.datasetReports,
                            data: values,
                            borderColor: BRAND_PRIMARY,
                            backgroundColor: 'rgba(45, 106, 79, 0.12)',
                            tension: 0.3,
                            fill: true,
                            pointRadius: 2,
                            pointHoverRadius: 5,
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: { mode: 'index', intersect: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { precision: 0, color: TEXT_MUTED },
                                grid: { color: 'rgba(0,0,0,0.05)' }
                            },
                            x: {
                                ticks: { color: TEXT_MUTED, maxRotation: 0, autoSkip: true, maxTicksLimit: 10 },
                                grid: { display: false }
                            }
                        }
                    }
                });
            }

            function renderStatusBreakdown(rows) {
                var canvas = document.getElementById('chart-status-breakdown');
                if (!canvas) return;

                if (rows.length === 0) {
                    showEmpty('chart-status-breakdown', i18n.statusEmpty);
                    return;
                }

                var labels = rows.map(function (r) { return r.statusName; });
                var values = rows.map(function (r) { return r.count; });
                var colors = rows.map(function (r) { return r.colorHex; });

                new Chart(canvas.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: values,
                            backgroundColor: colors,
                            borderColor: '#FFFFFF',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '62%',
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: { color: TEXT_MUTED, boxWidth: 12, padding: 12 }
                            }
                        }
                    }
                });
            }

            function renderAqiByDay(rows) {
                var canvas = document.getElementById('chart-aqi-by-day');
                if (!canvas) return;

                var hasAny = rows.some(function (r) { return r.avgAqiUs !== null && r.avgAqiUs !== undefined; });
                if (!hasAny) {
                    showEmpty('chart-aqi-by-day', i18n.aqiEmpty);
                    return;
                }

                var labels = rows.map(function (r) { return formatDayLabel(r.date); });
                var aqi = rows.map(function (r) { return r.avgAqiUs; });
                var stations = rows.map(function (r) { return r.stationCount; });

                new Chart(canvas.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: i18n.datasetAqi,
                            data: aqi,
                            borderColor: BRAND_ACCENT,
                            backgroundColor: 'rgba(116, 198, 157, 0.18)',
                            tension: 0.3,
                            fill: true,
                            spanGaps: true,
                            pointRadius: 3,
                            pointHoverRadius: 5,
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                callbacks: {
                                    afterLabel: function (ctx) {
                                        var s = stations[ctx.dataIndex];
                                        return s + (s === 1 ? i18n.stationSingular : i18n.stationsPlural);
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { color: TEXT_MUTED },
                                grid: { color: 'rgba(0,0,0,0.05)' }
                            },
                            x: {
                                ticks: { color: TEXT_MUTED },
                                grid: { display: false }
                            }
                        }
                    }
                });
            }
        })();
    </script>
}
