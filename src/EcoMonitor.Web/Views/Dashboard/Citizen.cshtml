@model CitizenDashboardViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var botUsername = Configuration["Telegram:BotUsername"];
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-person-heart"></i>
                    <span>@Localizer["Badge"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
                <p class="text-muted mb-0">@Localizer["WelcomeBack", Model.FullName]</p>
            </div>
            <div class="text-muted small mt-3 mt-sm-0">@DateTime.Now.ToString("dddd, d MMMM yyyy")</div>
        </div>

        <vc:air-quality-summary />

        <div class="cta-card mb-5">
            <div class="row align-items-center g-4">
                <div class="col-md-8">
                    <span class="hero-badge mb-2">
                        <i class="bi bi-megaphone"></i>
                        <span>@Localizer["CtaBadge"]</span>
                    </span>
                    <h2 class="h4 fw-700 mt-3 mb-2">@Localizer["CtaTitle"]</h2>
                    <p class="text-muted mb-0">@Localizer["CtaSubtitle"]</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a asp-controller="Citizen" asp-action="Create" class="btn btn-primary btn-lg">
                        <i class="bi bi-camera me-2"></i>
                        <span>@Localizer["CtaButton"]</span>
                    </a>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(botUsername))
            {
                <p class="text-muted small mb-0 mt-3">
                    <i class="bi bi-telegram me-1" style="color: #0088cc;"></i>
                    @Localizer["TelegramHint"]
                    <a href="https://t.me/@botUsername" target="_blank" rel="noopener">@@@botUsername</a>
                </p>
            }
        </div>

        <div class="auth-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 fw-700 mb-0">@Localizer["YourReports"]</h2>
                <a asp-controller="Citizen" asp-action="Reports" class="small">
                    @Localizer["ViewAll", Model.TotalReports] <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>

            @if (Model.RecentReports.Count == 0)
            {
                var emptyState = new EmptyStateViewModel
                {
                    Icon = "bi-clipboard-plus",
                    Title = Localizer["EmptyTitle"].Value,
                    Subtitle = Localizer["EmptySubtitle"].Value
                };
                <partial name="_EmptyState" model="emptyState" />
            }
            else
            {
                <div class="report-list">
                    @foreach (var report in Model.RecentReports)
                    {
                        <a asp-controller="Citizen" asp-action="Details" asp-route-id="@report.Id"
                           class="report-row d-block text-decoration-none text-reset">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="flex-grow-1">
                                    <p class="mb-1 fw-500">@report.Description</p>
                                    <span class="text-muted small">
                                        @DateHelpers.FormatRelative(report.CreatedAt)
                                        &middot; @report.Latitude.ToString("F4"), @report.Longitude.ToString("F4")
                                    </span>
                                </div>
                                <partial name="_StatusBadge" model="report.Status" />
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</section>
