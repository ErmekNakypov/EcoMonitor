@model InspectorDashboardViewModel
@{
    ViewData["Title"] = "Inspector dashboard";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Inspector</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Field operations</h1>
                <p class="text-muted mb-0">Welcome back, @Model.FullName</p>
            </div>
            <div class="text-muted small mt-3 mt-sm-0">@DateTime.Now.ToString("dddd, d MMMM yyyy")</div>
        </div>

        @* Stat strip — single shared surface, hairline dividers, no corner
           icons, no uppercase labels. All three stats are absolute counts
           (not rates with semantic state), so no dot accent before the
           label — the strip stays neutral. Skill section "Dashboards and
           KPI stats (anti-AI patterns)". *@
        <div class="stat-strip mb-5">
            <div class="stat-strip__item">
                <span class="stat-strip__label">Queue size</span>
                <div class="stat-strip__value">@Model.QueueSize</div>
                <span class="stat-strip__caption">Unassigned new reports</span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">My active</span>
                <div class="stat-strip__value">@Model.MyActiveReports</div>
                <span class="stat-strip__caption">In review or confirmed</span>
            </div>
            <div class="stat-strip__item">
                <span class="stat-strip__label">My resolved</span>
                <div class="stat-strip__value">@Model.MyResolvedReports</div>
                <span class="stat-strip__caption">Closed cases</span>
            </div>
        </div>

        <div class="auth-card text-center">
            <h2 class="h5 fw-700 mb-2">Where would you like to start?</h2>
            <p class="text-muted mb-4">Pick up new reports from the queue or continue handling cases assigned to you.</p>
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a asp-controller="Inspector" asp-action="Queue" class="btn btn-primary btn-lg">
                    <i class="bi bi-inboxes me-2"></i>Open queue
                </a>
                <a asp-controller="Inspector" asp-action="MyReports" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-clipboard-check me-2"></i>My reports
                </a>
            </div>
        </div>
    </div>
</section>
