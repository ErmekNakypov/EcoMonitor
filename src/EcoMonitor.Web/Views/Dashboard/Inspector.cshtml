@model InspectorDashboardViewModel
@{
    ViewData["Title"] = "Inspector dashboard";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Inspector</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Field operations</h1>
                <p class="text-muted mb-0">Welcome back, @Model.FullName</p>
            </div>
            <div class="text-muted small mt-3 mt-sm-0">@DateTime.Now.ToString("dddd, d MMMM yyyy")</div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="stat-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="stat-label">My assigned reports</span>
                        <i class="bi bi-person-check stat-icon"></i>
                    </div>
                    <div class="stat-value">@Model.AssignedReports</div>
                    <span class="text-muted small">Awaiting your review</span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="stat-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="stat-label">New unassigned</span>
                        <i class="bi bi-bell stat-icon"></i>
                    </div>
                    <div class="stat-value">@Model.NewUnassignedReports</div>
                    <span class="text-muted small">Available to claim</span>
                </div>
            </div>
        </div>

        <div class="auth-card text-center">
            <h2 class="h5 fw-700 mb-2">Ready to work the queue?</h2>
            <p class="text-muted mb-4">Pick up new reports, update statuses, and close out resolved cases.</p>
            <a href="#" class="btn btn-primary btn-lg">
                <i class="bi bi-list-check me-2"></i>
                <span>View report queue</span>
            </a>
        </div>
    </div>
</section>
