@model AppealUpheldEmailModel
@{
    ViewBag.Title = "Appeal upheld";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#065F46;font-size:20px;">Your appeal was accepted</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.ReporterName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    Inspector <strong>@Model.InspectorName</strong> reviewed your appeal on
    report <strong>@refId</strong> and agreed. The cleanup crew will return to
    the site to redo the work.
</p>
@if (!string.IsNullOrWhiteSpace(Model.InspectorNotes))
{
    <div style="background:#D1FAE5;border-left:4px solid #10B981;padding:12px 16px;margin:16px 0;border-radius:6px;">
        <strong style="display:block;margin-bottom:4px;color:#065F46;">Inspector notes</strong>
        <p style="margin:0;font-size:14px;color:#064E3B;line-height:1.5;">@Model.InspectorNotes</p>
    </div>
}
<p style="margin:16px 0 0 0;font-size:14px;color:#6B7280;line-height:1.6;">
    Reviewed @Model.ReviewedAt.ToString("MMM d, yyyy HH:mm") UTC. You'll receive
    another update when cleanup is completed again.
</p>
