@model CleanupCrewNewTaskEmailModel
@{
    ViewBag.Title = "New cleanup task available";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#1F2937;font-size:20px;">New cleanup task available</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.CrewName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    A new confirmed dumpsite is now queued for cleanup. First crew to claim
    the task gets the assignment.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;background:#F9FAFB;border-radius:8px;padding:16px;margin:16px 0;">
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Report ID</td>
        <td style="padding:8px 0;font-size:14px;font-weight:700;text-align:right;">@refId</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;vertical-align:top;">Description</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.ReportDescription</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Location</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")</td>
    </tr>
</table>
<p style="margin:24px 0;">
    <a href="@Model.ReportUrl" style="background:#2D6A4F;color:#FFFFFF;padding:12px 24px;text-decoration:none;border-radius:8px;display:inline-block;font-weight:600;">Open task</a>
</p>
