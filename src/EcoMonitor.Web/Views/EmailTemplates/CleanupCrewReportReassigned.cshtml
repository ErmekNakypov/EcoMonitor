@model CleanupCrewReportReassignedEmailModel
@{
    ViewBag.Title = "Report available for pickup";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#92400E;font-size:20px;">Report available — please check carefully</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.CrewName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    Report <strong>@refId</strong> was previously flagged by another cleanup
    crew. Inspector <strong>@Model.InspectorName</strong> reviewed the evidence
    and decided the dumpsite is valid. The report is now back in the cleanup
    queue and any crew member may pick it up.
</p>
<p style="margin:0 0 16px 0;font-size:14px;color:#92400E;">
    Reassign count: @Model.ReassignCount &middot; please verify on site carefully before flagging again.
</p>
@if (!string.IsNullOrWhiteSpace(Model.InspectorNotes))
{
    <div style="background:#FEF3C7;border-left:4px solid #F59E0B;padding:12px 16px;margin:16px 0;border-radius:6px;">
        <strong style="display:block;margin-bottom:4px;color:#92400E;">Inspector's note</strong>
        <p style="margin:0;font-size:14px;color:#78350F;line-height:1.5;white-space:pre-wrap;">@Model.InspectorNotes</p>
    </div>
}
<p style="margin:24px 0;">
    <a href="@Model.ReportUrl" style="background:#2D6A4F;color:#FFFFFF;padding:12px 24px;text-decoration:none;border-radius:8px;display:inline-block;font-weight:600;">Open queue</a>
</p>
