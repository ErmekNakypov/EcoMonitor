@model CleanupCrewReportReturnedEmailModel
@{
    ViewBag.Title = "Inspector reviewed your flag";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#065F46;font-size:20px;">Please re-check the site</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.CrewName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    Inspector <strong>@Model.InspectorName</strong> reviewed the flag you submitted
    for report <strong>@refId</strong> and confirmed that a dumpsite does exist
    at the reported location. The report has been returned to you for another
    on-site check.
</p>
@if (!string.IsNullOrWhiteSpace(Model.InspectorNotes))
{
    <div style="background:#D1FAE5;border-left:4px solid #10B981;padding:12px 16px;margin:16px 0;border-radius:6px;">
        <strong style="display:block;margin-bottom:4px;color:#065F46;">Inspector's note</strong>
        <p style="margin:0;font-size:14px;color:#064E3B;line-height:1.5;white-space:pre-wrap;">@Model.InspectorNotes</p>
    </div>
}
<p style="margin:24px 0;">
    <a href="@Model.ReportUrl" style="background:#2D6A4F;color:#FFFFFF;padding:12px 24px;text-decoration:none;border-radius:8px;display:inline-block;font-weight:600;">Open report</a>
</p>
