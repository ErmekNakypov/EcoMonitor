@model CleanupStartedEmailModel
@{
    ViewBag.Title = "Cleanup in progress";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#1F2937;font-size:20px;">Cleanup is now in progress</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.ReporterName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    The cleanup crew has arrived on site and started work on the dumpsite you reported.
    We'll send another update once they are done and the inspector has verified the result.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;background:#F9FAFB;border-radius:8px;padding:16px;margin:16px 0;">
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Reference ID</td>
        <td style="padding:8px 0;font-size:14px;font-weight:700;text-align:right;">@refId</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Cleanup started</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.StartedAt.ToString("MMM d, yyyy HH:mm")</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Status</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">
            <span style="background:#E0E7FF;color:#3730A3;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;">Cleanup in progress</span>
        </td>
    </tr>
</table>
