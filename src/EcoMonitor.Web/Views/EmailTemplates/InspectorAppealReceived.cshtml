@model InspectorAppealReceivedEmailModel
@{
    ViewBag.Title = "Citizen appeal received";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#92400E;font-size:20px;">Citizen appealed a closed report</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.InspectorName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    A citizen disagrees with the resolution of report <strong>@refId</strong>
    and has filed an appeal. Please open the report, review the appeal context
    and photos, and either uphold the appeal (cleanup will redo the work) or
    dismiss it with a written explanation.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;background:#F9FAFB;border-radius:8px;padding:16px;margin:16px 0;">
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Report ID</td>
        <td style="padding:8px 0;font-size:14px;font-weight:700;text-align:right;">@refId</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;vertical-align:top;">Original description</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.ReportDescription</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Appealed</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.AppealedAt.ToString("dd MMM yyyy, HH:mm")</td>
    </tr>
</table>
<div style="background:#FEF3C7;border-left:4px solid #F59E0B;padding:12px 16px;margin:16px 0;border-radius:6px;">
    <strong style="display:block;margin-bottom:4px;color:#92400E;">Citizen's reason</strong>
    <p style="margin:0;font-size:14px;color:#78350F;line-height:1.5;">@Model.AppealReason</p>
</div>
<p style="margin:24px 0;">
    <a href="@Model.ReportUrl" style="background:#2D6A4F;color:#FFFFFF;padding:12px 24px;text-decoration:none;border-radius:8px;display:inline-block;font-weight:600;">Open report</a>
</p>
