@model ReportConfirmedEmailModel
@{
    Layout = "_Layout";
    ViewBag.Title = "Report confirmed";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#1F2937;font-size:20px;">Your report has been confirmed</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.ReporterName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    Good news — your report has been confirmed by inspector <strong>@Model.InspectorName</strong> and is now being processed for cleanup.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;background:#F9FAFB;border-radius:8px;padding:16px;margin:16px 0;">
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Reference ID</td>
        <td style="padding:8px 0;font-size:14px;font-weight:700;text-align:right;">@refId</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Confirmed</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.ConfirmedAt.ToString("MMM d, yyyy HH:mm")</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Status</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">
            <span style="background:#FED7AA;color:#9A3412;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;">Confirmed</span>
        </td>
    </tr>
</table>
<p style="margin:16px 0 0 0;font-size:14px;color:#6B7280;line-height:1.6;">
    We will send you another update once the dumpsite is resolved. Thank you for helping keep Bishkek clean.
</p>
