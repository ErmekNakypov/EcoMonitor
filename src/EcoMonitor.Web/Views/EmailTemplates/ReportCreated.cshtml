@model ReportCreatedEmailModel
@{
    ViewBag.Title = "Report received";
    var refId = Model.ReportId.ToString().Substring(0, 8).ToUpperInvariant();
}
<h2 style="margin:0 0 16px 0;color:#1F2937;font-size:20px;">Your dumpsite report has been received</h2>
<p style="margin:0 0 12px 0;font-size:15px;line-height:1.6;">Hello @Model.ReporterName,</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
    Thank you for reporting an unauthorized dumpsite. Your report has been registered in the system and forwarded to our inspector team for review.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;background:#F9FAFB;border-radius:8px;padding:16px;margin:16px 0;">
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Reference ID</td>
        <td style="padding:8px 0;font-size:14px;font-weight:700;text-align:right;">@refId</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Submitted</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">@Model.CreatedAt.ToString("MMM d, yyyy HH:mm")</td>
    </tr>
    <tr>
        <td style="padding:8px 0;font-size:14px;color:#6B7280;">Status</td>
        <td style="padding:8px 0;font-size:14px;text-align:right;">
            <span style="background:#9CA3AF;color:#fff;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;">New</span>
        </td>
    </tr>
</table>
<p style="margin:16px 0 0 0;font-size:14px;color:#6B7280;line-height:1.6;">
    You will receive further updates as your report is reviewed and processed. You can also track its status on the EcoMonitor website.
</p>
