@{
    ViewData["Title"] = "Home";
}

<section class="text-center py-5">
    <h1 class="display-3 fw-semibold mb-3">EcoMonitor</h1>
    <p class="lead text-muted mb-0">Environmental monitoring and waste management system for Bishkek</p>
</section>

<section class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="feature-card h-100 p-4 rounded-3 shadow-sm bg-white text-center">
            <div class="feature-icon mb-3"><i class="bi bi-wind"></i></div>
            <h3 class="h5">Air Quality Monitoring</h3>
            <p class="text-muted mb-0">Real-time air quality data from sensor stations across the city</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card h-100 p-4 rounded-3 shadow-sm bg-white text-center">
            <div class="feature-icon mb-3"><i class="bi bi-trash"></i></div>
            <h3 class="h5">Waste Management</h3>
            <p class="text-muted mb-0">Track waste containers and optimize collection routes</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card h-100 p-4 rounded-3 shadow-sm bg-white text-center">
            <div class="feature-icon mb-3"><i class="bi bi-pin-map"></i></div>
            <h3 class="h5">Citizen Reports</h3>
            <p class="text-muted mb-0">Report unauthorized dumpsites and track resolution</p>
        </div>
    </div>
</section>

<section class="text-center pb-5">
    <a href="#" class="btn btn-primary btn-lg me-2">
        <i class="bi bi-box-arrow-in-right me-1"></i>Sign in
    </a>
    <a href="#" class="btn btn-outline-secondary btn-lg">
        <i class="bi bi-person-plus me-1"></i>Register
    </a>
</section>
