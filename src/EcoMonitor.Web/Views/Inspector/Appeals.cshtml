@using EcoMonitor.Application.Features.DumpsiteReports.Inspector.Queries.GetAppealsQueue
@model IReadOnlyList<AppealsQueueItemDto>
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Home"].Value,    Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = SharedLocalizer["Nav.Appeals"].Value });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2" style="background:#FEE2E2;color:#991B1B;">
                    <i class="bi bi-exclamation-octagon"></i>
                    <span>@Localizer["Title"]</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">@Localizer["Heading"]</h1>
                <p class="text-muted mb-0">@Localizer["HeaderSummary", totalCount]</p>
            </div>
        </div>

        <div class="d-flex gap-2 mb-3">
            <a asp-controller="Inspector" asp-action="Queue" class="filter-chip">
                <i class="bi bi-inboxes"></i><span>@SharedLocalizer["Nav.Queue"]</span>
            </a>
            <a asp-controller="Inspector" asp-action="MyReports" class="filter-chip">
                <i class="bi bi-clipboard-check"></i><span>@SharedLocalizer["Nav.MyReports"]</span>
            </a>
            <a asp-controller="Inspector" asp-action="Appeals" class="filter-chip active">
                <i class="bi bi-exclamation-octagon"></i><span>@SharedLocalizer["Nav.Appeals"]</span>
            </a>
        </div>

        <form method="get" asp-controller="Inspector" asp-action="Appeals" class="queue-toolbar">
            <div class="filter-group">
                <input type="search" name="search" placeholder="@Localizer["SearchPlaceholder"]" class="form-control" value="@ViewBag.Search" />
                <select name="sortBy" class="form-select">
                    <option value="oldest" selected="@(ViewBag.Sort == "oldest" || string.IsNullOrEmpty((string?)ViewBag.Sort))">@Localizer["SortOldestFirst"]</option>
                    <option value="newest" selected="@(ViewBag.Sort == "newest")">@Localizer["SortNewestFirst"]</option>
                </select>
                <button type="submit" class="btn btn-primary">@SharedLocalizer["Common.Apply"]</button>
            </div>
        </form>

        @if (Model.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-emoji-smile",
                Title = Localizer["EmptyTitle"].Value,
                Subtitle = Localizer["EmptySubtitle"].Value
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var item in Model)
                {
                    <div class="report-card" style="border-left:4px solid #DC2626;">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                {
                                    <img src="@item.FirstPhotoPath" alt="@Localizer["ReportPhotoAlt"]" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@item.ShortDescription</p>
                                <p class="mb-2 small text-danger">
                                    <i class="bi bi-quote me-1"></i>@item.AppealReason
                                </p>
                                <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                                    <span><i class="bi bi-geo-alt me-1"></i>@item.Latitude.ToString("F4"), @item.Longitude.ToString("F4")</span>
                                    <span><i class="bi bi-clock me-1"></i>@Localizer["AppealedAt", DateHelpers.FormatRelative(item.AppealedAt)]</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Inspector" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-danger">
                                    @Localizer["ReviewButton"] <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-4" aria-label="@Localizer["PaginationAriaLabel"]">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Appeals" asp-route-page="@(page - 1)">@SharedLocalizer["Common.Previous"]</a>
                        </li>
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Inspector" asp-action="Appeals" asp-route-page="@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(page >= totalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Appeals" asp-route-page="@(page + 1)">@SharedLocalizer["Common.Next"]</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
