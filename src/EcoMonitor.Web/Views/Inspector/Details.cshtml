@model ReportViewModel
@{
    var headline = Model.Description.Length > 80 ? Model.Description[..80] + "…" : Model.Description;
    if (string.IsNullOrWhiteSpace(headline)) headline = "Dumpsite report";
    ViewData["Title"] = "Report details";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "Queue", Url = Url.Action("Queue", "Inspector") },
        new BreadcrumbItem { Label = headline });

    // 5-stage stepper: Submitted, In review, Confirmed, Cleanup, Resolved
    int statusIndex = Model.Status switch
    {
        DumpsiteStatus.New => 0,
        DumpsiteStatus.InReview => 1,
        DumpsiteStatus.Confirmed => 2,
        DumpsiteStatus.CleanupInProgress => 3,
        DumpsiteStatus.AwaitingVerification => 3,
        DumpsiteStatus.Resolved => 4,
        DumpsiteStatus.Rejected => 2,
        _ => 0
    };

    string StepClass(int step)
    {
        if (Model.Status == DumpsiteStatus.Rejected && step == 2) return "active rejected";
        if (step < statusIndex) return "done";
        if (step == statusIndex) return "active";
        return string.Empty;
    }

    string Step3Label = Model.Status == DumpsiteStatus.Rejected ? "Rejected" : "Confirmed";

    string assignedLabel = Model.AssignedInspectorId is null
        ? "Unassigned"
        : Model.IsAssignedToCurrentUser
            ? "Assigned to you"
            : $"Assigned to {Model.AssignedInspectorEmail}";
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />

        <div class="mb-4">
            <div class="mb-2 d-flex flex-wrap gap-2">
                <partial name="_StatusBadge" model="Model.Status" />
                <partial name="_SourceBadge" model="Model.Source" />
            </div>
            <h1 class="h3 fw-700 mt-2 mb-1">@headline</h1>
            <p class="text-muted small mb-0">
                @if (Model.Source == ReportSource.Telegram)
                {
                    var handle = string.IsNullOrWhiteSpace(Model.TelegramUserName) ? "(anonymous)" : "@" + Model.TelegramUserName;
                    <text>Reported via Telegram by <span class="fw-500">@handle</span></text>
                }
                else
                {
                    <text>Reported by <span class="fw-500">@(Model.ReporterFullName ?? "(unknown)")</span> (@Model.ReporterEmail)</text>
                }
                @DateHelpers.FormatRelative(Model.CreatedAt) (@DateHelpers.FormatShort(Model.CreatedAt))
                &middot; @assignedLabel
            </p>
        </div>

        <div class="auth-card mb-4">
            <h2 class="h6 fw-700 mb-3">Progress</h2>
            <div class="status-stepper">
                <div class="status-step @StepClass(0)">
                    <span class="status-step-bullet">1</span>
                    <div class="status-step-label">Submitted</div>
                </div>
                <div class="status-step @StepClass(1)">
                    <span class="status-step-bullet">2</span>
                    <div class="status-step-label">In review</div>
                </div>
                <div class="status-step @StepClass(2)">
                    <span class="status-step-bullet">3</span>
                    <div class="status-step-label">@Step3Label</div>
                </div>
                <div class="status-step @StepClass(3)">
                    <span class="status-step-bullet">4</span>
                    <div class="status-step-label">Cleanup</div>
                </div>
                <div class="status-step @StepClass(4)">
                    <span class="status-step-bullet">5</span>
                    <div class="status-step-label">Resolved</div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-7">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-2">Description</h2>
                    <p class="mb-0">@Model.Description</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.InspectorObservations))
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">Inspector observations</h2>
                        <p class="mb-0">@Model.InspectorObservations</p>
                    </div>
                }

                @if (Model.PhotoPaths.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">Citizen photos (@Model.PhotoPaths.Count)</h2>
                        <div class="photo-gallery">
                            @for (int i = 0; i < Model.PhotoPaths.Count; i++)
                            {
                                var path = Model.PhotoPaths[i];
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@path">
                                    <img src="@path" alt="Citizen photo @(i + 1)" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.InspectionPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">Inspector verification photos (@Model.InspectionPhotos.Count)</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.InspectionPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="Inspector photo" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.CleanupBeforePhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">Before cleanup (@Model.CleanupBeforePhotos.Count)</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.CleanupBeforePhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="Before cleanup" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.CleanupAfterPhotos.Count > 0)
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-3">After cleanup (@Model.CleanupAfterPhotos.Count)</h2>
                        <div class="photo-gallery">
                            @foreach (var p in Model.CleanupAfterPhotos)
                            {
                                <a href="#" class="photo-tile" data-bs-toggle="modal" data-bs-target="#photo-modal" data-photo-src="@p">
                                    <img src="@p" alt="After cleanup" />
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.CleanupNotes))
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">Cleanup crew notes</h2>
                        <p class="mb-0" style="white-space: pre-wrap;">@Model.CleanupNotes</p>
                    </div>
                }

                @if ((Model.Status == DumpsiteStatus.Resolved || Model.Status == DumpsiteStatus.Rejected) && !string.IsNullOrWhiteSpace(Model.ResolutionNotes))
                {
                    <div class="auth-card mb-4">
                        <h2 class="h6 fw-700 mb-2">@(Model.Status == DumpsiteStatus.Rejected ? "Rejection reason" : "Resolution")</h2>
                        <p class="mb-2">@Model.ResolutionNotes</p>
                        @if (Model.ResolvedAt.HasValue)
                        {
                            <p class="text-muted small mb-0">Closed on @DateHelpers.FormatShort(Model.ResolvedAt.Value)</p>
                        }
                    </div>
                }
            </div>

            <div class="col-md-5">
                <div class="auth-card mb-4">
                    <h2 class="h6 fw-700 mb-3">Location</h2>
                    <div id="details-map"></div>
                    <p class="text-muted small mb-0 mt-2">@Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")</p>
                </div>

                <div class="action-panel">
                    <h2 class="h6 fw-700 mb-3">Actions</h2>

                    @if (Model.CanTake)
                    {
                        <form asp-controller="Inspector" asp-action="Take" asp-route-id="@Model.Id" method="post" class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-hand-thumbs-up me-2"></i>Take this report
                            </button>
                        </form>
                    }
                    else if (Model.CanConfirm || Model.CanReject)
                    {
                        <div class="d-grid gap-2">
                            @if (Model.CanConfirm)
                            {
                                <button type="button" class="btn btn-primary btn-lg w-100"
                                        data-bs-toggle="modal" data-bs-target="#confirm-modal">
                                    <i class="bi bi-check2-circle me-2"></i>Confirm with photos
                                </button>
                            }
                            @if (Model.CanReject)
                            {
                                <button type="button" class="btn btn-outline-secondary btn-lg" data-bs-toggle="modal" data-bs-target="#reject-modal">
                                    <i class="bi bi-x-circle me-2"></i>Reject
                                </button>
                            }
                        </div>
                    }
                    else if (Model.Status == DumpsiteStatus.Confirmed)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-info-circle me-2"></i>This report is now in the cleanup queue.
                            @if (!string.IsNullOrEmpty(Model.CleanupCrewName))
                            {
                                <text>Crew member <strong>@Model.CleanupCrewName</strong> has taken it.</text>
                            }
                            else
                            {
                                <text>A cleanup crew member will pick it up.</text>
                            }
                        </p>
                    }
                    else if (Model.Status == DumpsiteStatus.CleanupInProgress)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-hourglass-split me-2"></i>Cleanup in progress.
                            @if (Model.CleanupStartedAt.HasValue)
                            {
                                <text>Started @DateHelpers.FormatRelative(Model.CleanupStartedAt.Value).</text>
                            }
                        </p>
                    }
                    else if (Model.CanVerify)
                    {
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary btn-lg w-100"
                                    data-bs-toggle="modal" data-bs-target="#verify-modal">
                                <i class="bi bi-check2-all me-2"></i>Verify and close
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-lg"
                                    data-bs-toggle="modal" data-bs-target="#rework-modal">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Send back for rework
                            </button>
                        </div>
                    }
                    else if (Model.Status == DumpsiteStatus.Resolved || Model.Status == DumpsiteStatus.Rejected)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-lock me-2"></i>This report is closed.
                        </p>
                    }
                    else if (Model.AssignedInspectorId is not null && !Model.IsAssignedToCurrentUser)
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-person-check me-2"></i>This report is being handled by @Model.AssignedInspectorEmail.
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model.CanConfirm)
{
    <div class="modal fade" id="confirm-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-controller="Inspector" asp-action="Confirm" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">Confirm dumpsite</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">Upload at least one photo proving the dumpsite exists at the reported location.</p>
                        <div class="mb-3">
                            <label class="form-label fw-500" for="confirm-photos">Inspection photos</label>
                            <input id="confirm-photos" name="Photos" type="file" class="form-control" multiple accept="image/*" required />
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="confirm-observations">Observations (optional)</label>
                            <textarea id="confirm-observations" name="Observations" rows="3" class="form-control" maxlength="1000" placeholder="Estimated volume, type of waste, accessibility, hazards…"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-2"></i>Confirm and send to cleanup queue
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.CanReject)
{
    <div class="modal fade" id="reject-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-controller="Inspector" asp-action="Reject" asp-route-id="@Model.Id" method="post">
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">Reject report</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">Tell the citizen and your colleagues why this report is being rejected.</p>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="reject-reason">Reason</label>
                            <textarea id="reject-reason" name="Reason" rows="4" class="form-control" minlength="10" maxlength="1000" required></textarea>
                        </div>
                        <div class="form-text">10–1000 characters.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-x-circle me-2"></i>Reject report
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.CanVerify)
{
    <div class="modal fade" id="verify-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-controller="Inspector" asp-action="Resolve" asp-route-id="@Model.Id" method="post">
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">Verify cleanup and close</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">Confirm the cleanup is complete and add a short note for the citizen.</p>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="verify-notes">Verification notes</label>
                            <textarea id="verify-notes" name="Notes" rows="3" class="form-control" minlength="10" maxlength="1000" required></textarea>
                        </div>
                        <div class="form-text">10–1000 characters.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-all me-2"></i>Verify and close
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="rework-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-controller="Inspector" asp-action="RejectCleanup" asp-route-id="@Model.Id" method="post">
                    <div class="modal-header">
                        <h2 class="h5 fw-700 modal-title mb-0">Send back for rework</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">Tell the cleanup crew what needs to be done before this can be closed.</p>
                        <div class="mb-2">
                            <label class="form-label fw-500" for="rework-reason">What needs rework</label>
                            <textarea id="rework-reason" name="Reason" rows="4" class="form-control" minlength="10" maxlength="1000" required></textarea>
                        </div>
                        <div class="form-text">10–1000 characters.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-arrow-counterclockwise me-2"></i>Send back
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="photo-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img id="photo-modal-img" src="" alt="Report photo" class="w-100 rounded" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const map = L.map('details-map', {
                zoomControl: true,
                scrollWheelZoom: false
            }).setView([lat, lng], 15);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map);

            const photoModal = document.getElementById('photo-modal');
            if (photoModal) {
                photoModal.addEventListener('show.bs.modal', function (event) {
                    const trigger = event.relatedTarget;
                    const src = trigger ? trigger.getAttribute('data-photo-src') : null;
                    if (src) {
                        document.getElementById('photo-modal-img').setAttribute('src', src);
                    }
                });
            }
        })();
    </script>
}
