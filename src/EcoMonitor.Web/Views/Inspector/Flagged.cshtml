@using EcoMonitor.Application.Features.DumpsiteReports.Inspector.Queries.GetFlaggedReports
@model IReadOnlyList<FlaggedReportItemDto>
@{
    ViewData["Title"] = "Flagged reports";
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "Flagged reports" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2" style="background:#FEF3C7;color:#92400E;">
                    <i class="bi bi-flag-fill"></i>
                    <span>Flagged by cleanup crew</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Reports flagged on site</h1>
                <p class="text-muted mb-0">@totalCount waiting &middot; oldest first</p>
            </div>
        </div>

        <div class="d-flex gap-2 mb-3 flex-wrap">
            <a asp-controller="Inspector" asp-action="Queue" class="filter-chip">
                <i class="bi bi-inboxes"></i><span>Queue</span>
            </a>
            <a asp-controller="Inspector" asp-action="MyReports" class="filter-chip">
                <i class="bi bi-clipboard-check"></i><span>My reports</span>
            </a>
            <a asp-controller="Inspector" asp-action="Verification" class="filter-chip">
                <i class="bi bi-shield-check"></i><span>Verification</span>
            </a>
            <a asp-controller="Inspector" asp-action="Appeals" class="filter-chip">
                <i class="bi bi-exclamation-octagon"></i><span>Appeals</span>
            </a>
            <a asp-controller="Inspector" asp-action="Flagged" class="filter-chip active">
                <i class="bi bi-flag-fill"></i><span>Flagged</span>
            </a>
        </div>

        <form method="get" asp-controller="Inspector" asp-action="Flagged" class="queue-toolbar">
            <div class="filter-group">
                <input type="search" name="search" placeholder="Search by description…" class="form-control" value="@ViewBag.Search" />
                <select name="sortBy" class="form-select">
                    <option value="oldest" selected="@(ViewBag.Sort == "oldest" || string.IsNullOrEmpty((string?)ViewBag.Sort))">Oldest first</option>
                    <option value="newest" selected="@(ViewBag.Sort == "newest")">Newest first</option>
                </select>
                <button type="submit" class="btn btn-primary">Apply</button>
            </div>
        </form>

        @if (Model.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-check2-circle",
                Title = "No flagged reports",
                Subtitle = "All cleanup crew assignments are progressing normally."
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var item in Model)
                {
                    <div class="report-card" style="border-left:4px solid #F59E0B;">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                {
                                    <img src="@item.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@item.ShortDescription</p>
                                <p class="mb-2 small" style="color:#92400E;">
                                    <i class="bi bi-flag-fill me-1"></i>@item.FlagReasonDisplay
                                    @if (!string.IsNullOrEmpty(item.FlagNotes))
                                    {
                                        <text> &mdash; @item.FlagNotes</text>
                                    }
                                </p>
                                <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                                    <span><i class="bi bi-geo-alt me-1"></i>@item.Latitude.ToString("F4"), @item.Longitude.ToString("F4")</span>
                                    <span><i class="bi bi-clock me-1"></i>Flagged @DateHelpers.FormatRelative(item.FlaggedAt)</span>
                                    @if (!string.IsNullOrEmpty(item.CrewName))
                                    {
                                        <span><i class="bi bi-person me-1"></i>@item.CrewName</span>
                                    }
                                    @if (item.ReassignCount > 0)
                                    {
                                        <span class="badge bg-warning text-dark">Reassigned @item.ReassignCount&times;</span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Inspector" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-warning">
                                    Review <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-4" aria-label="Flagged pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Flagged" asp-route-page="@(page - 1)">Previous</a>
                        </li>
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Inspector" asp-action="Flagged" asp-route-page="@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(page >= totalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Flagged" asp-route-page="@(page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
