@model MyAssignedViewModel
@{
    ViewData["Title"] = "My assigned reports";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "My reports" });

    string TabClass(string tab) => Model.Tab == tab ? "nav-link active" : "nav-link";

    string EmptyTitle = Model.Tab switch
    {
        "completed" => "No completed reports yet",
        "all" => "You haven't taken any reports yet",
        _ => "Nothing active right now"
    };
    string EmptySubtitle = Model.Tab switch
    {
        "completed" => "Reports you have closed, rejected, or sent to cleanup will appear here.",
        "all" => "Pick up a report from the queue to start handling cases.",
        _ => "Pick up a report from the queue or wait for an appeal to come in."
    };
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-clipboard-check"></i>
                    <span>My reports</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Reports assigned to me</h1>
                <p class="text-muted mb-0">@Model.OverallCount total</p>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">
            <a asp-controller="Inspector" asp-action="Queue" class="filter-chip">
                <i class="bi bi-inboxes"></i><span>Queue</span>
            </a>
            <a asp-controller="Inspector" asp-action="MyReports" class="filter-chip active">
                <i class="bi bi-clipboard-check"></i><span>My reports</span>
            </a>
        </div>

        <ul class="nav nav-pills role-tabs mb-3" role="tablist">
            <li class="nav-item">
                <a class="@TabClass("active")" asp-controller="Inspector" asp-action="MyReports" asp-route-tab="active">
                    Active <span class="role-tab-count">@Model.ActiveCount</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="@TabClass("completed")" asp-controller="Inspector" asp-action="MyReports" asp-route-tab="completed">
                    Completed <span class="role-tab-count">@Model.CompletedCount</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="@TabClass("all")" asp-controller="Inspector" asp-action="MyReports" asp-route-tab="all">
                    All <span class="role-tab-count">@Model.OverallCount</span>
                </a>
            </li>
        </ul>

        @if (Model.Items.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-clipboard",
                Title = EmptyTitle,
                Subtitle = EmptySubtitle
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var item in Model.Items)
                {
                    string? footnote = item.Status switch
                    {
                        DumpsiteStatus.Resolved when item.ResolvedAt.HasValue => $"Resolved {DateHelpers.FormatRelative(item.ResolvedAt.Value)}",
                        DumpsiteStatus.Closed when item.ClosedAt.HasValue => $"Closed {DateHelpers.FormatRelative(item.ClosedAt.Value)}",
                        DumpsiteStatus.Rejected when item.ResolvedAt.HasValue => $"Rejected {DateHelpers.FormatRelative(item.ResolvedAt.Value)}",
                        _ => null
                    };

                    var rolesPlayed = new List<string>();
                    if (item.WasAssigned) rolesPlayed.Add("reviewed");
                    if (item.WasVerifier) rolesPlayed.Add("verified cleanup");
                    if (item.WasAppealReviewer) rolesPlayed.Add("reviewed appeal");

                    <div class="report-card">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                {
                                    <img src="@item.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <div class="mb-2"><partial name="_StatusBadge" model="item.Status" /></div>
                                <p class="mb-2 fw-500">@item.ShortDescription</p>
                                @if (rolesPlayed.Count > 0)
                                {
                                    <div class="text-muted small mb-1">
                                        <i class="bi bi-person-check me-1"></i>You: @string.Join(" · ", rolesPlayed)
                                    </div>
                                }
                                <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                                    <span><i class="bi bi-clock me-1"></i>Updated @DateHelpers.FormatRelative(item.UpdatedAt)</span>
                                    @if (!string.IsNullOrEmpty(footnote))
                                    {
                                        <span><i class="bi bi-check2-circle me-1"></i>@footnote</span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Inspector" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                    Open <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="My reports pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="MyReports"
                               asp-route-page="@(Model.Page - 1)" asp-route-tab="@Model.Tab">Previous</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Inspector" asp-action="MyReports"
                                   asp-route-page="@p" asp-route-tab="@Model.Tab">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="MyReports"
                               asp-route-page="@(Model.Page + 1)" asp-route-tab="@Model.Tab">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
