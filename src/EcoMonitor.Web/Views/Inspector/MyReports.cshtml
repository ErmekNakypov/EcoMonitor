@model MyAssignedViewModel
@{
    ViewData["Title"] = "My assigned reports";

    string ChipClass(DumpsiteStatus? value) =>
        Model.StatusFilter == value ? "filter-chip active" : "filter-chip";

    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "My reports" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-clipboard-check"></i>
                    <span>My reports</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">Reports assigned to me</h1>
                <p class="text-muted mb-0">@Model.TotalCount total</p>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">
            <a asp-controller="Inspector" asp-action="Queue" class="filter-chip">
                <i class="bi bi-inboxes"></i><span>Queue</span>
            </a>
            <a asp-controller="Inspector" asp-action="MyReports" class="filter-chip active">
                <i class="bi bi-clipboard-check"></i><span>My reports</span>
            </a>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-controller="Inspector" asp-action="MyReports" class="@ChipClass(null)">All</a>
            <a asp-controller="Inspector" asp-action="MyReports" asp-route-status="@DumpsiteStatus.InReview" class="@ChipClass(DumpsiteStatus.InReview)">In review</a>
            <a asp-controller="Inspector" asp-action="MyReports" asp-route-status="@DumpsiteStatus.Confirmed" class="@ChipClass(DumpsiteStatus.Confirmed)">Confirmed</a>
            <a asp-controller="Inspector" asp-action="MyReports" asp-route-status="@DumpsiteStatus.Resolved" class="@ChipClass(DumpsiteStatus.Resolved)">Resolved</a>
            <a asp-controller="Inspector" asp-action="MyReports" asp-route-status="@DumpsiteStatus.Rejected" class="@ChipClass(DumpsiteStatus.Rejected)">Rejected</a>
        </div>

        @if (Model.Items.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-clipboard",
                Title = "No reports here",
                Subtitle = "Pick up a report from the queue to start handling cases."
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var item in Model.Items)
                {
                    <div class="report-card">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                {
                                    <img src="@item.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@item.ShortDescription</p>
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <partial name="_StatusBadge" model="item.Status" />
                                    <span class="text-muted small"><i class="bi bi-clock me-1"></i>Updated @DateHelpers.FormatRelative(item.UpdatedAt)</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Inspector" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                    Open <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="My reports pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="MyReports"
                               asp-route-page="@(Model.Page - 1)" asp-route-status="@Model.StatusFilter">Previous</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Inspector" asp-action="MyReports"
                                   asp-route-page="@p" asp-route-status="@Model.StatusFilter">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="MyReports"
                               asp-route-page="@(Model.Page + 1)" asp-route-status="@Model.StatusFilter">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
