@model QueueListViewModel
@{
    ViewData["Title"] = "Inspector queue";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-inboxes"></i>
                    <span>Inspector queue</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">New reports waiting for review</h1>
                <p class="text-muted mb-0">@Model.TotalCount in queue &middot; oldest first</p>
            </div>
        </div>

        <div class="d-flex gap-2 mb-4">
            <a asp-controller="Inspector" asp-action="Queue" class="filter-chip active">
                <i class="bi bi-inboxes"></i><span>Queue</span>
            </a>
            <a asp-controller="Inspector" asp-action="MyReports" class="filter-chip">
                <i class="bi bi-clipboard-check"></i><span>My reports</span>
            </a>
        </div>

        @if (Model.Items.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-check2-circle",
                Title = "All caught up!",
                Subtitle = "No new reports right now. Check back soon."
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var item in Model.Items)
                {
                    <div class="report-card">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                {
                                    <img src="@item.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                }
                                else
                                {
                                    <div class="report-thumb report-thumb-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-7">
                                <p class="mb-2 fw-500">@item.ShortDescription</p>
                                <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                                    <span><i class="bi bi-geo-alt me-1"></i>@item.Latitude.ToString("F4"), @item.Longitude.ToString("F4")</span>
                                    <span><i class="bi bi-clock me-1"></i>Reported @DateHelpers.FormatRelative(item.CreatedAt)</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-md-end">
                                <a asp-controller="Inspector" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                    Open <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Queue pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Queue" asp-route-page="@(Model.Page - 1)">Previous</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Inspector" asp-action="Queue" asp-route-page="@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Queue" asp-route-page="@(Model.Page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
