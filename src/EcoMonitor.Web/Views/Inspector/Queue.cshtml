@model QueueListViewModel
@{
    ViewData["Title"] = "Report queue";
    var breadcrumbs = Breadcrumbs.Build(
        new BreadcrumbItem { Label = "Home", Url = Url.Action("Index", "Home") },
        new BreadcrumbItem { Label = "Queue" });
}

<section class="py-5">
    <div class="container">
        <partial name="_Breadcrumbs" model="breadcrumbs" />
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-4">
            <div>
                <span class="hero-badge mb-2">
                    <i class="bi bi-inboxes"></i>
                    <span>Inspector queue</span>
                </span>
                <h1 class="h2 fw-700 mt-3 mb-1">New reports waiting for review</h1>
                <p class="text-muted mb-0">@Model.TotalCount in queue &middot; oldest first</p>
            </div>
        </div>

        <div class="d-flex gap-2 mb-3">
            <a asp-controller="Inspector" asp-action="Queue" class="filter-chip active">
                <i class="bi bi-inboxes"></i><span>Queue</span>
            </a>
            <a asp-controller="Inspector" asp-action="MyReports" class="filter-chip">
                <i class="bi bi-clipboard-check"></i><span>My reports</span>
            </a>
        </div>

        <form method="get" asp-controller="Inspector" asp-action="Queue" class="queue-toolbar">
            <div class="filter-group">
                <input type="search" name="search" placeholder="Search by description…" class="form-control" value="@ViewBag.Search" />
                <select name="sortBy" class="form-select">
                    <option value="oldest" selected="@(ViewBag.Sort == "oldest" || string.IsNullOrEmpty((string?)ViewBag.Sort))">Oldest first</option>
                    <option value="newest" selected="@(ViewBag.Sort == "newest")">Newest first</option>
                </select>
                <select name="source" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty((string?)ViewBag.Source))">All sources</option>
                    <option value="web" selected="@(ViewBag.Source == "web")">Web only</option>
                    <option value="telegram" selected="@(ViewBag.Source == "telegram")">Telegram only</option>
                </select>
                <button type="submit" class="btn btn-primary">Apply</button>
            </div>
            @{
                var hasDistrict = ViewBag.InspectorHasDistrict as bool? ?? false;
                var districtToggled = ViewBag.MyDistrictOnly as bool? ?? false;
            }
            @if (hasDistrict)
            {
                <div class="form-check form-switch mt-2">
                    <input class="form-check-input" type="checkbox" id="districtFilter" name="myDistrictOnly" value="true" @(districtToggled ? "checked" : "")>
                    <label class="form-check-label" for="districtFilter">Show only reports in my district</label>
                </div>
            }
            else
            {
                <div class="text-muted small mt-2">
                    <i class="bi bi-info-circle me-1"></i>You are a city-wide inspector (no district assigned).
                </div>
            }
        </form>

        @if (Model.Items.Count == 0)
        {
            var emptyState = new EmptyStateViewModel
            {
                Icon = "bi-check2-circle",
                Title = "All caught up!",
                Subtitle = "No new reports right now. Check back soon."
            };
            <div class="auth-card">
                <partial name="_EmptyState" model="emptyState" />
            </div>
        }
        else
        {
            <form asp-controller="Inspector" asp-action="BuildRoute" method="post" id="route-form">
                @Html.AntiForgeryToken()
                @* Filled by the click handler below when the browser grants
                   geolocation. Left empty otherwise — the server treats null
                   StartLat/StartLng as "no origin, fall back to first stop". *@
                <input type="hidden" name="startLat" id="route-start-lat" value="" />
                <input type="hidden" name="startLng" id="route-start-lng" value="" />
                <div class="route-select-bar">
                    <span class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i>Tick 2–15 reports to plan an inspection route.
                    </span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small" id="route-selected-count">0 selected</span>
                        <button type="submit" class="btn btn-primary btn-sm" id="route-build-btn" disabled>
                            <i class="bi bi-signpost-split me-1"></i>Build inspection route
                        </button>
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model.Items)
                    {
                        <div class="report-card">
                            <div class="row g-3 align-items-center">
                                <div class="col-md-1 d-flex justify-content-center">
                                    <input class="form-check-input route-checkbox" type="checkbox" name="selectedIds" value="@item.Id" aria-label="Select report for route" />
                                </div>
                                <div class="col-md-2">
                                    @if (!string.IsNullOrEmpty(item.FirstPhotoPath))
                                    {
                                        <img src="@item.FirstPhotoPath" alt="Report photo" class="report-thumb" />
                                    }
                                    else
                                    {
                                        <div class="report-thumb report-thumb-placeholder">
                                            <i class="bi bi-camera"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-6">
                                    <p class="mb-2 fw-500">@item.ShortDescription</p>
                                    <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                                        <span><i class="bi bi-geo-alt me-1"></i>@item.Latitude.ToString("F4"), @item.Longitude.ToString("F4")</span>
                                        <span><i class="bi bi-clock me-1"></i>Reported @DateHelpers.FormatRelative(item.CreatedAt)</span>
                                        <partial name="_SourceBadge" model="item.Source" />
                                        @if (!string.IsNullOrEmpty(item.DistrictNameRu))
                                        {
                                            <span class="district-badge" style="background:@item.DistrictColorHex;">
                                                <i class="bi bi-geo-alt-fill me-1"></i>@item.DistrictNameRu
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-3 text-md-end">
                                    <a asp-controller="Inspector" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                        Open <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </form>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Queue pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Queue" asp-route-page="@(Model.Page - 1)">Previous</a>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" asp-controller="Inspector" asp-action="Queue" asp-route-page="@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                            <a class="page-link" asp-controller="Inspector" asp-action="Queue" asp-route-page="@(Model.Page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const checkboxes = document.querySelectorAll('.route-checkbox');
            const btn = document.getElementById('route-build-btn');
            const counter = document.getElementById('route-selected-count');
            const form = document.getElementById('route-form');
            const latInput = document.getElementById('route-start-lat');
            const lngInput = document.getElementById('route-start-lng');
            if (!btn || !counter) return;
            function update() {
                const count = document.querySelectorAll('.route-checkbox:checked').length;
                counter.textContent = count + ' selected';
                btn.disabled = count < 2 || count > 15;
            }
            checkboxes.forEach(cb => cb.addEventListener('change', update));

            // Capture the user's location at click time and submit it as
            // hidden startLat/startLng fields so the server can prepend a
            // virtual origin to the nearest-neighbor input.
            //
            // Degrades gracefully on denial, timeout, position-unavailable,
            // or no geolocation API at all: in any of those cases the inputs
            // stay empty and the form is submitted as before, producing
            // today's "start from the first selected report" behaviour.
            //
            // Note: navigator.geolocation only resolves on https origins or
            // localhost; on plain http to a non-localhost host the prompt
            // never appears and the error path is taken.
            let geoInFlight = false;
            if (form && latInput && lngInput) {
                btn.addEventListener('click', function (e) {
                    if (geoInFlight) { e.preventDefault(); return; }
                    if (!('geolocation' in navigator)) { return; /* native submit */ }
                    e.preventDefault();
                    geoInFlight = true;
                    function done() {
                        geoInFlight = false;
                        if (typeof form.requestSubmit === 'function') {
                            form.requestSubmit(btn);
                        } else {
                            form.submit();
                        }
                    }
                    navigator.geolocation.getCurrentPosition(
                        function (pos) {
                            latInput.value = pos.coords.latitude;
                            lngInput.value = pos.coords.longitude;
                            done();
                        },
                        function (_err) { done(); /* denial/timeout/unavailable */ },
                        { enableHighAccuracy: false, timeout: 8000, maximumAge: 60000 }
                    );
                });
            }
        })();
    </script>
}
