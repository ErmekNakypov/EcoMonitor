@{
    ViewData["Title"] = "City map";
}

<section class="py-5">
    <div class="container">
        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-geo-alt"></i>
                <span>City map</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">Bishkek environmental map</h1>
            <p class="text-muted mb-0">Containers, dumpsite reports, and air quality stations across the city.</p>
        </div>

        <div class="auth-card text-center py-5">
            <div class="empty-state">
                <div class="empty-icon mb-3">
                    <i class="bi bi-map"></i>
                </div>
                <h2 class="h4 fw-700 mb-2">Full city map is coming soon</h2>
                <p class="text-muted mb-0" style="max-width: 560px; margin: 0 auto;">
                    We're integrating waste containers, dumpsite reports, and air quality data into one interactive view.
                </p>
            </div>
        </div>
    </div>
</section>
