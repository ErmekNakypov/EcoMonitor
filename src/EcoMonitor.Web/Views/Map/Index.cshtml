@{
    ViewData["Title"] = "City map";

    var legend = new (AqiLevel Level, string Range)[]
    {
        (AqiLevel.Good, "0–12"),
        (AqiLevel.Moderate, "12–35"),
        (AqiLevel.UnhealthyForSensitive, "35–55"),
        (AqiLevel.Unhealthy, "55–150"),
        (AqiLevel.VeryUnhealthy, "150–250"),
        (AqiLevel.Hazardous, "250+")
    };
}

<section class="py-5">
    <div class="container">
        <div class="mb-4">
            <span class="hero-badge mb-2">
                <i class="bi bi-geo-alt-fill"></i>
                <span>Air quality</span>
            </span>
            <h1 class="h2 fw-700 mt-3 mb-1">Bishkek air quality</h1>
            <p class="text-muted mb-1">Real-time air quality monitoring across the city</p>
            <p class="text-muted small mb-0">Data from Clarity sensor network via OpenAQ. Updates automatically every minute.</p>
        </div>

        <div class="aqi-legend mb-4">
            @foreach (var item in legend)
            {
                var color = AqiHelper.GetColorHex(item.Level);
                var darkText = item.Level == AqiLevel.Moderate;
                <span class="aqi-pill" style="background:@color; color:@(darkText ? "#78350F" : "#fff")">
                    <span>@AqiHelper.GetLabel(item.Level)</span>
                    <span class="range">@item.Range</span>
                </span>
            }
        </div>

        <div id="city-map"></div>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <div class="auth-card">
                    <h2 class="h6 fw-700 mb-3">Stations</h2>
                    <div class="table-responsive">
                        <table id="stations-table" class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Station</th>
                                    <th>PM2.5</th>
                                    <th>Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td colspan="3" class="text-muted small">Loading…</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="auth-card">
                    <h2 class="h6 fw-700 mb-3">Right now</h2>
                    <div class="d-flex align-items-baseline gap-2 mb-1">
                        <span id="avgPm25" class="display-5 fw-800">—</span>
                        <span class="text-muted small">µg/m³ PM2.5 average</span>
                    </div>
                    <p class="text-muted small mb-3">
                        <span id="activeStations">—</span> stations active in the last 24 hours
                    </p>
                    <div class="d-flex flex-column gap-2 small">
                        <div>
                            <span class="text-muted">Worst:</span>
                            <a id="worstStation" href="#" class="ms-1">—</a>
                        </div>
                        <div>
                            <span class="text-muted">Best:</span>
                            <a id="bestStation" href="#" class="ms-1">—</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const map = L.map('city-map').setView([42.8746, 74.5698], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 18
            }).addTo(map);

            let markers = [];

            function escapeHtml(s) {
                return String(s ?? '')
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            function valueDisplay(s) {
                if (s.pm25 == null) return '<em class="text-muted">No data</em>';
                const text = s.pm25.toFixed(1) + ' µg/m³';
                return '<strong>' + text + '</strong> <span class="badge" style="background:' + s.color + ';color:#fff;font-weight:600">' + escapeHtml(s.aqiLabel) + '</span>';
            }

            function updateSidebarStats(data) {
                const fresh = data.filter(d => !d.isVeryStale && d.pm25 != null);
                const avgEl = document.getElementById('avgPm25');
                const activeEl = document.getElementById('activeStations');

                if (fresh.length > 0) {
                    const avg = fresh.reduce((sum, d) => sum + d.pm25, 0) / fresh.length;
                    avgEl.textContent = avg.toFixed(1);
                    activeEl.textContent = fresh.length;

                    const worst = fresh.reduce((a, b) => a.pm25 > b.pm25 ? a : b);
                    const best = fresh.reduce((a, b) => a.pm25 < b.pm25 ? a : b);

                    const worstEl = document.getElementById('worstStation');
                    worstEl.textContent = worst.name + ' (' + worst.pm25.toFixed(1) + ')';
                    worstEl.setAttribute('href', '/Air/Station/' + worst.id);

                    const bestEl = document.getElementById('bestStation');
                    bestEl.textContent = best.name + ' (' + best.pm25.toFixed(1) + ')';
                    bestEl.setAttribute('href', '/Air/Station/' + best.id);
                } else {
                    avgEl.textContent = '—';
                    activeEl.textContent = '0';
                }

                const tbody = document.querySelector('#stations-table tbody');
                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="3" class="text-muted small">No stations found.</td></tr>';
                    return;
                }
                tbody.innerHTML = data.map(s => {
                    const pmText = s.pm25 != null ? s.pm25.toFixed(1) : 'n/a';
                    const stale = s.isStale ? ' station-stale' : '';
                    return '<tr class="' + stale.trim() + '">' +
                        '<td><a href="/Air/Station/' + s.id + '">' + escapeHtml(s.name) + '</a></td>' +
                        '<td><span class="aqi-dot" style="background:' + s.color + '"></span> ' + pmText + '</td>' +
                        '<td class="text-muted small">' + escapeHtml(s.measuredRelative) + '</td>' +
                    '</tr>';
                }).join('');
            }

            async function loadStations() {
                try {
                    const r = await fetch('/api/map/air-quality');
                    if (!r.ok) return;
                    const data = await r.json();

                    markers.forEach(m => map.removeLayer(m));
                    markers = [];

                    data.forEach(s => {
                        const marker = L.circleMarker([s.latitude, s.longitude], {
                            radius: 14,
                            color: '#fff',
                            weight: 2,
                            fillColor: s.color,
                            fillOpacity: s.isStale ? 0.45 : 0.9
                        }).addTo(map);

                        const stalePart = s.isStale
                            ? '<div class="text-warning small mt-1"><i class="bi bi-exclamation-triangle"></i> Last seen ' + escapeHtml(s.measuredRelative) + '</div>'
                            : '';

                        marker.bindPopup(
                            '<div style="min-width:220px">' +
                                '<div class="fw-700 mb-1">' + escapeHtml(s.name) + '</div>' +
                                (s.providerName ? '<div class="text-muted small mb-2">' + escapeHtml(s.providerName) + '</div>' : '') +
                                '<div>PM2.5: ' + valueDisplay(s) + '</div>' +
                                '<div class="text-muted small mt-1">' + escapeHtml(s.measuredRelative) + '</div>' +
                                stalePart +
                                '<div class="mt-2"><a href="/Air/Station/' + s.id + '" class="btn btn-sm btn-outline-primary">Details</a></div>' +
                            '</div>'
                        );
                        markers.push(marker);
                    });

                    updateSidebarStats(data);
                } catch (e) {
                    console.warn('Failed to load stations', e);
                }
            }

            loadStations();
            setInterval(loadStations, 60000);
        })();
    </script>
}
