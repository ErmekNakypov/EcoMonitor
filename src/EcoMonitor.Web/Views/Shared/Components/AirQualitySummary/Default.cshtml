@model EcoMonitor.Web.Models.Air.AirQualitySummaryViewModel
@using System.Globalization
@using EcoMonitor.Web.Helpers

@{
    var color = AqiHelper.GetColorHex(Model.AqiLevel);
    var label = AqiHelper.GetLabel(Model.AqiLevel);
    var darkText = Model.AqiLevel == AqiLevel.Moderate;
}

<div class="air-summary-card mb-4" style="border-left: 4px solid @color">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <div class="text-muted text-uppercase small fw-600">Air quality right now</div>
            <div class="d-flex align-items-baseline gap-2 mt-2">
                <span class="display-5 fw-800">@(Model.AverageAqiUs.HasValue ? Math.Round(Model.AverageAqiUs.Value).ToString("0", CultureInfo.InvariantCulture) : "—")</span>
                <span class="text-muted small">AQI US (average)</span>
            </div>
            <span class="aqi-pill mt-2" style="background:@color; color:@(darkText ? "#78350F" : "#fff")">@label</span>
        </div>
        <i class="bi bi-wind" style="font-size: 2.5rem; color: @color; opacity: 0.5;"></i>
    </div>
    <div class="text-muted small mt-3">@Model.ActiveStations of @Model.TotalStations stations active in the last 24 hours</div>
    <div class="mt-3">
        <a href="/Map" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-geo-alt me-1"></i>View map
        </a>
    </div>
</div>
