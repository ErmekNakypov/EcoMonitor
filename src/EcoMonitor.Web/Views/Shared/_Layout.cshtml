@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isSignedIn = SignInManager.IsSignedIn(User);
    ApplicationUser? currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name;
    var roleNames = currentUser is not null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EcoMonitor — Environmental monitoring and waste management system for Bishkek, Kyrgyzstan." />
    <meta name="theme-color" content="#2D6A4F" />
    <title>@ViewData["Title"] - EcoMonitor</title>

    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&display=swap" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcoMonitor.Web.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tree-fill"></i>
                    <span>EcoMonitor</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i>
                                <span>Home</span>
                            </a>
                        </li>
                        @if (isSignedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-grid"></i>
                                    <span>Dashboard</span>
                                </a>
                            </li>
                            @if (User.IsInRole(RoleNames.Inspector))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="inspectorMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-clipboard-check"></i>
                                        <span>Reports</span>
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="inspectorMenu">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Inspector" asp-action="Queue">
                                                <i class="bi bi-inboxes me-2"></i>Queue
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Inspector" asp-action="MyReports">
                                                <i class="bi bi-clipboard-check me-2"></i>My reports
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(RoleNames.Administrator))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-gear"></i>
                                        <span>Admin</span>
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminMenu">
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                                <i class="bi bi-people me-2"></i>Users
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-controller="Containers" asp-action="Index">
                                                <i class="bi bi-trash3 me-2"></i>Containers
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-controller="Containers" asp-action="Map">
                                                <i class="bi bi-map me-2"></i>Containers map
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-sm-center gap-2">
                        <li class="nav-item dropdown">
                            <button type="button" class="lang-toggle dropdown-toggle" id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate"></i>
                                <span>Language</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                                <li><a class="dropdown-item" href="#" data-culture="ru-RU">Русский</a></li>
                                <li><a class="dropdown-item" href="#" data-culture="en-US">English</a></li>
                                <li><a class="dropdown-item" href="#" data-culture="ky-KG">Кыргызча</a></li>
                            </ul>
                        </li>

                        @if (!isSignedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="Account" asp-action="Register">
                                    <span>Get started</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <button type="button" class="lang-toggle dropdown-toggle" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@displayName</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li>
                                        <span class="dropdown-item-text small text-muted">
                                            @(roleNames.Count > 0 ? string.Join(", ", roleNames) : "No roles")
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i>
                                                <span>Sign out</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="footer py-3 mt-auto">
        <div class="container text-center">
            <span>&copy; 2026 EcoMonitor</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/forms.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_Toasts" />
</body>
</html>
