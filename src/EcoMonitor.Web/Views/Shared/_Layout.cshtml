@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@functions {
    bool IsActive(string? area, string controller, params string[] actions)
    {
        var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        if (!string.Equals(currentArea, area ?? string.Empty, StringComparison.OrdinalIgnoreCase)) return false;
        if (!string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)) return false;
        if (actions.Length == 0) return true;
        foreach (var a in actions)
        {
            if (string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase)) return true;
        }
        return false;
    }
}
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isSignedIn = SignInManager.IsSignedIn(User);
    ApplicationUser? currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name;
    var roleNames = currentUser is not null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
    var isAdmin = isSignedIn && User.IsInRole(RoleNames.Administrator);
    var isInspector = isSignedIn && User.IsInRole(RoleNames.Inspector);
    var isCitizen = isSignedIn && User.IsInRole(RoleNames.Citizen);
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EcoMonitor — Environmental monitoring and waste management system for Bishkek, Kyrgyzstan." />
    <meta name="theme-color" content="#2D6A4F" />
    <title>@ViewData["Title"] - EcoMonitor</title>

    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&display=swap" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@@1.5.3/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@@1.5.3/dist/MarkerCluster.Default.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcoMonitor.Web.styles.css" asp-append-version="true" />

    <script defer src="https://cdn.jsdelivr.net/npm/chart.js@@4.4.7"></script>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tree-fill"></i>
                    <span>EcoMonitor</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-md-center gap-md-2">
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Dashboard") ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Map") ? "active" : "")" asp-area="" asp-controller="Map" asp-action="Index">
                                    <i class="bi bi-geo-alt"></i><span>Map</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Admin", "Containers") ? "active" : "")" asp-area="Admin" asp-controller="Containers" asp-action="Index">
                                    <i class="bi bi-trash3"></i><span>Containers</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Admin", "Users") ? "active" : "")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-people"></i><span>Users</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Admin", "Reports") ? "active" : "")" asp-area="Admin" asp-controller="Reports" asp-action="Index">
                                    <i class="bi bi-flag"></i><span>Reports</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                @{
                                    var systemActive = IsActive("Admin", "Devices")
                                        || IsActive("Admin", "Telegram")
                                        || IsActive("Admin", "Email")
                                        || IsActive("Admin", "Diagnostics");
                                }
                                <a class="nav-link dropdown-toggle @(systemActive ? "active" : "")"
                                   href="#" role="button" id="systemMenu"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear"></i><span>System</span>
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="systemMenu">
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Devices" asp-action="Index">
                                            <i class="bi bi-cpu me-2"></i>IoT devices
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Telegram" asp-action="Index">
                                            <i class="bi bi-telegram me-2"></i>Telegram bot
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Email" asp-action="Index">
                                            <i class="bi bi-envelope me-2"></i>Email diagnostics
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Diagnostics" asp-action="Index">
                                            <i class="bi bi-tools me-2"></i>System diagnostics
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else if (isInspector)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Home") ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i><span>Home</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm d-inline-flex align-items-center gap-2 navbar-cta" asp-controller="Inspector" asp-action="Queue">
                                    <i class="bi bi-inboxes"></i><span>Queue</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Inspector", "MyReports") ? "active" : "")" asp-controller="Inspector" asp-action="MyReports">
                                    <i class="bi bi-clipboard-check"></i><span>My reports</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Map") ? "active" : "")" asp-controller="Map" asp-action="Index">
                                    <i class="bi bi-geo-alt"></i><span>Map</span>
                                </a>
                            </li>
                        }
                        else if (isCitizen)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Home") ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i><span>Home</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Map") ? "active" : "")" asp-controller="Map" asp-action="Index">
                                    <i class="bi bi-geo-alt"></i><span>Map</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm d-inline-flex align-items-center gap-2 navbar-cta" asp-controller="Citizen" asp-action="Create">
                                    <i class="bi bi-plus-circle"></i><span>Report dumpsite</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Citizen", "Reports", "Details") ? "active" : "")" asp-controller="Citizen" asp-action="Reports">
                                    <i class="bi bi-list-check"></i><span>My reports</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Home") ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i><span>Home</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActive(null, "Map") ? "active" : "")" asp-controller="Map" asp-action="Index">
                                    <i class="bi bi-geo-alt"></i><span>Map</span>
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-md-center gap-md-2">
                        <li class="nav-item dropdown">
                            <button type="button" class="lang-toggle dropdown-toggle" id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate"></i>
                                <span>Language</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                                <li><a class="dropdown-item" href="#" data-culture="ru-RU">Русский</a></li>
                                <li><a class="dropdown-item" href="#" data-culture="en-US">English</a></li>
                                <li><a class="dropdown-item" href="#" data-culture="ky-KG">Кыргызча</a></li>
                            </ul>
                        </li>

                        @if (!isSignedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Sign in</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-area="" asp-controller="Account" asp-action="Register">
                                    <span>Get started</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <button type="button" class="lang-toggle dropdown-toggle" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@displayName</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li>
                                        <span class="dropdown-item-text small text-muted">
                                            @(roleNames.Count > 0 ? string.Join(", ", roleNames) : "No roles")
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i>
                                                <span>Sign out</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="footer py-3 mt-auto">
        <div class="container text-center">
            <span>&copy; 2026 EcoMonitor</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/forms.js" asp-append-version="true"></script>
    <script src="~/js/clickable-rows.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_Toasts" />
</body>
</html>
